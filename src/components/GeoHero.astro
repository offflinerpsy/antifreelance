---
// GeoHero — "Your customers are asking AI. Are you the answer?"
// Scanner form + AI platform logos
---

<section class="geo-hero" id="scanner">
  <div class="container">
    <h1 class="geo-hero__title reveal">
      <span data-i18n="geo.hero.h1">Your customers are asking AI.</span><br>
      <span class="accent" data-i18n="geo.hero.h1em">Are you the answer?</span>
    </h1>
    <p class="geo-hero__sub reveal" data-i18n="geo.hero.sub">People now ask ChatGPT, Siri, and Google AI where to eat, who to see, and who to trust. We make sure AI recommends you.</p>

    <form class="geo-hero__form reveal" id="geoScannerForm">
      <input
        type="text"
        name="business"
        placeholder="Enter your business name or website"
        data-i18n-placeholder="geo.hero.placeholder"
        autocomplete="off"
        required
      />
      <button type="submit" class="btn-primary" data-i18n="geo.hero.cta">Scan Now</button>
    </form>

    <p class="geo-hero__trust reveal">
      <span class="trust-check">&#10003;</span>
      <span data-i18n="geo.hero.trust">Free &middot; 30 seconds &middot; Instant AI visibility report</span>
    </p>

    <div class="geo-hero__platforms reveal">
      <span class="platforms-label" data-i18n="geo.hero.platforms">We optimize for</span>
      <div class="platforms-row">
        <div class="platform-icon" title="ChatGPT"><img src="/assets/geo/chatgpt-logo.png" alt="ChatGPT" width="20" height="20" loading="lazy" /></div>
        <div class="platform-icon" title="Gemini"><img src="/assets/geo/gemini-logo.png" alt="Gemini" width="20" height="20" loading="lazy" /></div>
        <div class="platform-icon" title="Perplexity"><img src="/assets/geo/perplexity-logo.png" alt="Perplexity" width="20" height="20" loading="lazy" /></div>
        <div class="platform-icon" title="Claude"><img src="/assets/geo/claude-logo.svg" alt="Claude" width="20" height="20" loading="lazy" /></div>
        <div class="platform-icon" title="Microsoft Copilot"><img src="/assets/geo/copilot-logo.svg" alt="Copilot" width="20" height="20" loading="lazy" /></div>
        <div class="platform-icon" title="Google AI Overview"><img src="/assets/geo/google-ai-logo.svg" alt="Google AI" width="20" height="20" loading="lazy" /></div>
        <div class="platform-icon" title="Grok"><img src="/assets/geo/grok-logo.svg" alt="Grok" width="20" height="20" loading="lazy" /></div>
        <div class="platform-more">+3</div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('geoScannerForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = (e.target as HTMLFormElement).querySelector('input');
    if (input?.value) {
      const contactSection = document.getElementById('contact');
      if (contactSection) {
        contactSection.scrollIntoView({ behavior: 'smooth' });
      }
    }
  });
</script>

<style>
  .geo-hero {
    background: var(--color-surface);
    padding: clamp(140px, 22vw, 220px) 20px clamp(60px, 10vw, 100px);
    text-align: center;
  }
  .container { max-width: var(--container-max); margin: 0 auto; }

  .geo-hero__title {
    font-family: var(--font-heading);
    font-size: var(--text-hero);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }
  .accent { color: var(--color-accent); }

  .geo-hero__sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto var(--space-10);
    line-height: var(--leading-normal);
  }

  .geo-hero__form {
    display: flex;
    align-items: center;
    max-width: 560px;
    margin: 0 auto var(--space-5);
    background: var(--color-surface-2);
    border: 1px solid var(--color-surface-4);
    border-radius: var(--radius-full);
    padding: 6px 6px 6px 24px;
    transition: border-color var(--duration-base), box-shadow var(--duration-base);
  }
  .geo-hero__form:focus-within {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-glow-sm);
  }
  .geo-hero__form input {
    flex: 1;
    border: none;
    outline: none;
    background: none;
    font-size: 15px;
    color: var(--color-text);
    padding: 12px 0;
    font-family: var(--font-body);
  }
  .geo-hero__form input::placeholder { color: var(--color-text-subtle); }
  .geo-hero__form .btn-primary {
    white-space: nowrap;
    padding: 12px 28px;
  }

  .geo-hero__trust {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-bottom: var(--space-8);
  }
  .trust-check { color: var(--color-accent); }

  .geo-hero__platforms {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-surface-4);
  }
  .platforms-label {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }
  .platforms-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .platform-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--color-surface-2);
    border: 1px solid var(--color-surface-4);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--duration-base), border-color var(--duration-base);
  }
  .platform-icon:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary);
  }
  .platform-icon img { width: 20px; height: 20px; object-fit: contain; }
  .platform-more {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(255, 94, 0, 0.1);
    border: 1px solid rgba(255, 94, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .geo-hero__form {
      flex-direction: column;
      border-radius: var(--radius-md);
      padding: 8px;
    }
    .geo-hero__form input {
      padding: 14px 16px;
      width: 100%;
    }
    .geo-hero__form .btn-primary {
      width: 100%;
      justify-content: center;
      border-radius: 10px;
    }
    .geo-hero__platforms { flex-direction: column; gap: 12px; }
    .platforms-row { flex-wrap: wrap; justify-content: center; }
  }
</style>

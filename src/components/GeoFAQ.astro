---
// GeoFAQ — 5 questions about GEO services
const faqs = [
  {
    q: 'How long until I see results?',
    a: 'Most businesses see first AI mentions within 30-60 days. Technical optimizations (schema, llms.txt) take effect within weeks. Review Engine results build momentum over months — the more reviews, the stronger your AI signal gets.',
    qi18n: 'geo.faq.q1', ai18n: 'geo.faq.a1'
  },
  {
    q: 'What if AI changes its algorithms?',
    a: 'We monitor all 7+ AI platforms continuously. When algorithms shift, we adapt your strategy the same week. That\'s the advantage of working with a GEO-focused agency — we live and breathe this, so you don\'t have to.',
    qi18n: 'geo.faq.q2', ai18n: 'geo.faq.a2'
  },
  {
    q: 'I already do SEO. Why do I need GEO?',
    a: 'SEO gets you on Google\'s blue links. GEO gets you recommended by ChatGPT, Perplexity, Gemini, and Claude. 59% of local searches now happen through AI — not Google. SEO and GEO complement each other, but GEO targets the fastest-growing search channel.',
    qi18n: 'geo.faq.q3', ai18n: 'geo.faq.a3'
  },
  {
    q: 'What makes Override different from other agencies?',
    a: 'Two things: price and our Review Engine. Most GEO agencies charge $3,000-$12,000/month. We start at $499. And our Review Engine is our secret weapon — we help your customers write reviews that contain the exact keywords AI uses to make recommendations.',
    qi18n: 'geo.faq.q4', ai18n: 'geo.faq.a4'
  },
  {
    q: 'Can I cancel anytime?',
    a: 'We ask for a 90-day minimum because AI optimization takes time to compound. After that, cancel with 30 days notice — no penalties, no hidden fees. And if you don\'t see results within 90 days, we keep working for free.',
    qi18n: 'geo.faq.q5', ai18n: 'geo.faq.a5'
  },
];
---

<section class="geo-faq" id="geo-faq">
  <div class="container">
    <div class="geo-faq__header reveal">
      <p class="section-tag" data-i18n="geo.faq.tag">Questions</p>
      <h2 class="geo-faq__headline" data-i18n="geo.faq.h2">Still thinking it over?</h2>
      <p class="geo-faq__sub" data-i18n="geo.faq.sub">Here are the answers to the questions that usually stop people from getting started.</p>
    </div>

    <div class="geo-faq__list">
      {faqs.map((f) => (
        <details class="geo-faq__item reveal">
          <summary data-i18n={f.qi18n}>{f.q}</summary>
          <p data-i18n={f.ai18n}>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .geo-faq {
    background: var(--color-surface);
    padding: var(--section-padding) 20px;
  }
  .container { max-width: var(--container-max); margin: 0 auto; }
  .section-tag {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .geo-faq__header { text-align: center; }
  .geo-faq__headline {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }
  .geo-faq__sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--leading-normal);
  }

  .geo-faq__list {
    max-width: 720px;
    margin: var(--space-12) auto 0;
  }
  .geo-faq__item {
    border-bottom: 1px solid var(--color-surface-4);
  }
  .geo-faq__item summary {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 600;
    color: var(--color-text);
    padding: var(--space-6) 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: color var(--duration-base);
  }
  .geo-faq__item summary::-webkit-details-marker { display: none; }
  .geo-faq__item summary::after {
    content: '+';
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--color-primary);
    flex-shrink: 0;
    transition: transform var(--duration-base);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--color-surface-4);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
  }
  .geo-faq__item[open] summary::after {
    transform: rotate(45deg);
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }
  .geo-faq__item summary:hover { color: var(--color-primary); }
  .geo-faq__item p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    padding: 0 0 var(--space-6);
    max-width: 640px;
  }
</style>

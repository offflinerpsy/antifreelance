---
const techStack = [
  { name: 'Anthropic', icon: '/assets/logos/anthropic.png' },
  { name: 'Claude', icon: '/assets/logos/claude.png' },
  { name: 'Gemini', icon: '/assets/logos/gemini.png' },
  { name: 'GitHub', icon: '/assets/logos/github.png' },
  { name: 'Groq', icon: '/assets/logos/groq.png' },
  { name: 'Meta', icon: '/assets/logos/meta.png' },
  { name: 'Microsoft', icon: '/assets/logos/microsoft.png' },
  { name: 'Mistral', icon: '/assets/logos/mistral.png' },
  { name: 'Ollama', icon: '/assets/logos/ollama.png' },
  { name: 'OpenAI', icon: '/assets/logos/openai.png' },
  { name: 'Qwen', icon: '/assets/logos/qwen.png' },
  { name: 'HubSpot', icon: '/assets/tech/hubspot.svg' },
  { name: 'Salesforce', icon: '/assets/tech/salesforce.svg' },
  { name: 'Slack', icon: '/assets/tech/slack.svg' },
  { name: 'Zapier', icon: '/assets/tech/zapier.svg' },
  { name: 'Calendly', icon: '/assets/tech/calendly.svg' },
  { name: 'Google Calendar', icon: '/assets/tech/google-calendar.svg' },
  { name: 'WordPress', icon: '/assets/tech/wordpress.svg' },
];
---

<section class="tech-stack-section">
  <div class="container">
    <div class="carousel-container">
      <div class="carousel-track">
        {techStack.map((tech) => (
          <div class="tech-item">
            <img src={tech.icon} alt={tech.name} class="tech-icon" loading="lazy" />
            <span class="tech-name">{tech.name}</span>
          </div>
        ))}
        {/* Duplicate for infinite scroll */}
        {techStack.map((tech) => (
          <div class="tech-item">
            <img src={tech.icon} alt={tech.name} class="tech-icon" loading="lazy" />
            <span class="tech-name">{tech.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .tech-stack-section {
    padding: 40px 0;
    background: var(--black);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    overflow: hidden;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .carousel-track {
    display: flex;
    align-items: center;
    gap: 60px;
    width: max-content;
    animation: scrollTech 30s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  .tech-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 24px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: default;
    filter: grayscale(100%) opacity(0.5);
  }

  .tech-item:hover {
    filter: grayscale(0%) opacity(1);
  }

  .tech-icon {
    width: 24px;
    height: 24px;
    object-fit: contain;
  }

  .tech-name {
    font-size: 1rem;
    font-weight: 500;
    color: var(--white);
    white-space: nowrap;
  }

  @keyframes scrollTech {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 30px)); } /* -50% of total width minus half the gap */
  }

  @media (max-width: 768px) {
    .tech-item {
      padding: 10px 20px;
    }
    .tech-name {
      font-size: 0.9rem;
    }
    .carousel-track {
      gap: 40px;
    }
    @keyframes scrollTech {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-50% - 20px)); }
    }
  }
</style>
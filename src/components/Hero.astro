---
<section class="hero">
  <div class="hero-bg-text" aria-hidden="true">BOT AI BOT AI</div>
  <div class="hero-meta">
    <div class="hero-tag">AI Automation for Business &middot; 2026</div>
    <div class="hero-author">@Gypno_Man</div>
  </div>
  <h1 id="hero-title" aria-label="Tired of losing customers?">
    <span class="line line1" data-text="Tired of">Tired of</span>
    <span class="line line2"><span class="invert" data-text="losing">losing</span></span>
    <span class="line line3" data-text="customers?">customers?</span>
  </h1>
  <div class="hero-bottom">
    <p class="hero-desc">An AI bot responds instantly, works 24/7, and costs 4&ndash;8x less than a human agent. Launch in 2&ndash;3 days.</p>
    <div class="hero-stats-row">
      <div class="h-stat">
        <div class="h-stat-n" data-count="15">15</div>
        <div class="h-stat-l">Years of Experience</div>
      </div>
      <div class="h-stat">
        <div class="h-stat-n" data-count="50">50<span class="stat-plus">+</span></div>
        <div class="h-stat-l">Bots Built</div>
      </div>
      <div class="h-stat">
        <div class="h-stat-n">24/7</div>
        <div class="h-stat-l">Always On</div>
      </div>
    </div>
    <div class="hero-cta">
      <a href="https://t.me/Gypno_Man" class="btn-primary">Free Consultation &rarr;</a>
    </div>
  </div>
</section>

<style>
  /* ═══════════════ HERO SECTION ═══════════════ */
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(100px, 14vh, 140px) clamp(20px, 5vw, 60px) clamp(40px, 6vh, 80px);
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #FF5E00 0%, #FF7A29 100%);
  }

  /* Bottom gradient: bridges hero → dark features section */
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 260px;
    background: linear-gradient(to bottom, transparent 0%, rgba(18,18,18,0.22) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Background watermark */
  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(100px, 22vw, 260px);
    color: rgba(255,255,255,0.07);
    white-space: nowrap;
    pointer-events: none;
    letter-spacing: -0.02em;
    user-select: none;
  }

  /* Top meta bar */
  .hero-meta {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: clamp(16px, 3vw, 28px);
    flex-wrap: wrap;
    gap: 16px;
    opacity: 0;
  }
  .hero-tag {
    font-size: clamp(10px, 1.5vw, 13px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(0,0,0,0.6);
    background: rgba(0,0,0,0.1);
    padding: 6px 14px;
    border-radius: 100px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    backdrop-filter: blur(4px);
  }
  .hero-tag::before { content: '●'; color: var(--black); font-size: 8px; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.2} }
  .hero-author {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1rem, 3vw, 1.3rem);
    color: rgba(0,0,0,0.5);
    letter-spacing: 0.1em;
  }

  /* ═══ H1: THE BIG TEXT ═══ */
  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 13vw, 14rem);
    line-height: 0.88;
    letter-spacing: -0.02em;
    color: var(--black);
    position: relative;
    z-index: 2;
    max-width: 100%;
    text-transform: uppercase;
    perspective: 1200px;
  }
  .hero h1 .line {
    display: block;
    padding-bottom: 4px;
    visibility: hidden; /* Prevent flash of raw text before GSAP char-split */
  }

  /* Individual characters (injected by JS) */
  .hero h1 .char {
    display: inline-block;
    opacity: 0;
    will-change: transform, opacity;
    backface-visibility: hidden;
  }

  /* "LOSING" inverted block */
  .hero h1 .invert {
    color: var(--white);
    display: inline-block;
    background: var(--black);
    padding: 0 16px;
    line-height: 1.05;
    margin: 6px 0;
    /* NO overflow:hidden on invert either — chars need room to rotate */
    perspective: 1000px;
    /* clip-path for dramatic reveal — JS wipes this open */
    clip-path: inset(0 100% 0 0);
  }
  .hero h1 .invert .char { color: var(--white); }

  /* ═══ BOTTOM BAR: desc + stats + CTA ═══ */
  .hero-bottom {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: clamp(20px, 4vw, 36px);
    border-top: 2px solid rgba(0,0,0,0.15);
    flex-wrap: wrap;
    gap: clamp(20px, 3vw, 32px);
    margin-top: clamp(16px, 4vw, 28px);
    opacity: 0;
  }
  .hero-desc {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(0,0,0,0.8);
    max-width: 420px;
    line-height: 1.7;
    font-weight: 500;
  }

  /* Stats row */
  .hero-stats-row {
    display: flex;
    gap: clamp(28px, 5vw, 56px);
    flex-wrap: wrap;
  }
  .h-stat { text-align: center; }
  .h-stat-n {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 7vw, 4.5rem);
    color: var(--black);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .stat-plus {
    font-size: 0.6em;
    vertical-align: super;
    margin-left: -2px;
  }
  .h-stat-l {
    font-size: clamp(11px, 1.2vw, 14px);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(0,0,0,0.65);
    margin-top: 4px;
    font-weight: 700;
  }

  /* CTA */
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
  }
  .hero-cta .btn-primary { width: 100%; }

  @media (min-width: 768px) {
    .hero-cta { width: auto; }
    .hero-cta .btn-primary { width: auto; }
  }

  @media (max-width: 768px) {
    .hero { padding: 120px 20px 40px; }
    .hero-meta { flex-direction: column; align-items: flex-start; }
    .hero-bottom { flex-direction: column; align-items: flex-start; }
    .hero-stats-row { width: 100%; justify-content: space-between; }
  }
</style>

<!-- is:inline = NO Vite module wrapping, runs synchronously, guaranteed access to GSAP global -->
<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    // ─── Guard: bail if GSAP CDN failed to load ───
    if (typeof gsap === 'undefined') {
      document.querySelectorAll('.hero-meta, .hero-bottom').forEach(function(el) {
        el.style.opacity = '1';
      });
      document.querySelectorAll('.hero h1 .line').forEach(function(el) {
        el.style.visibility = 'visible';
      });
      var inv = document.querySelector('.hero h1 .invert');
      if (inv) inv.style.clipPath = 'inset(0 0 0 0)';
      return;
    }

    // ─── Custom character splitter ───
    function splitChars(el) {
      var text = el.textContent || '';
      el.innerHTML = '';
      var chars = [];
      for (var i = 0; i < text.length; i++) {
        var ch = text[i];
        var s = document.createElement('span');
        s.className = 'char';
        s.textContent = ch === ' ' ? '\u00A0' : ch;
        s.style.display = 'inline-block';
        el.appendChild(s);
        chars.push(s);
      }
      return chars;
    }

    // Split heading lines into individual characters
    var line1El = document.querySelector('.line1');
    var invertEl = document.querySelector('.hero h1 .invert');
    var line3El = document.querySelector('.line3');

    var c1 = line1El ? splitChars(line1El) : [];
    var c2 = invertEl ? splitChars(invertEl) : [];
    var c3 = line3El ? splitChars(line3El) : [];
    var allChars = c1.concat(c2, c3);

    // Reveal line containers now that chars are split (hidden in CSS to prevent FOUT)
    document.querySelectorAll('.hero h1 .line').forEach(function(el) { el.style.visibility = 'visible'; });

    // ─── Counter animation helper ───
    function animateCounters() {
      document.querySelectorAll('.h-stat-n[data-count]').forEach(function(el) {
        var target = parseInt(el.getAttribute('data-count') || '0');
        var plusEl = el.querySelector('.stat-plus');
        // Set to 0 first
        el.textContent = '0';
        if (plusEl) el.appendChild(plusEl);
        var obj = { val: 0 };
        gsap.to(obj, {
          val: target,
          duration: 1.5,
          ease: 'power2.out',
          onUpdate: function() {
            var rounded = Math.round(obj.val);
            el.textContent = String(rounded);
            if (plusEl) el.appendChild(plusEl);
          }
        });
      });
    }

    var mm = gsap.matchMedia();

    // ═══════════════════════════════════════════
    // DESKTOP — full cinematic reveal
    // ═══════════════════════════════════════════
    mm.add("(min-width: 768px)", function() {
      // Initial states — characters invisible and rotated
      gsap.set(c1, { rotateY: 90, opacity: 0, transformOrigin: '0% 50%' });
      gsap.set(c2, { rotateX: -90, y: 60, opacity: 0, transformOrigin: '50% 0%' });
      gsap.set(c3, { rotateY: -90, opacity: 0, transformOrigin: '100% 50%' });
      gsap.set('.hero-bottom', { y: 60, opacity: 0 });
      gsap.set('.hero-meta', { y: -20, opacity: 0 });

      // Master timeline — slow and dramatic
      var tl = gsap.timeline({ delay: 0.2 });

      // 0s — Meta bar slides in
      tl.to('.hero-meta', {
        opacity: 1, y: 0,
        duration: 0.8, ease: 'power3.out'
      }, 0);

      // 0.3s — "TIRED OF" — airport departure board flip
      tl.to(c1, {
        rotateY: 0, opacity: 1,
        duration: 1.0,
        stagger: { each: 0.06, ease: 'power2.in' },
        ease: 'back.out(1.4)',
      }, 0.3);

      // 0.9s — Black "LOSING" box wipes open left-to-right
      tl.to('.hero h1 .invert', {
        clipPath: 'inset(0 0% 0 0)',
        duration: 0.6,
        ease: 'power4.inOut',
      }, 0.9);

      // 1.1s — "LOSING" chars flip up with elastic bounce
      tl.to(c2, {
        rotateX: 0, y: 0, opacity: 1,
        duration: 0.8,
        stagger: 0.07,
        ease: 'elastic.out(1.2, 0.5)',
      }, 1.1);

      // 1.5s — "CUSTOMERS?" — chars rotate in from right
      tl.to(c3, {
        rotateY: 0, opacity: 1,
        duration: 1.0,
        stagger: { each: 0.04, ease: 'power1.in' },
        ease: 'back.out(1.7)',
      }, 1.5);

      // 2.3s — Bottom bar rises up
      tl.to('.hero-bottom', {
        opacity: 1, y: 0,
        duration: 0.9, ease: 'power2.out'
      }, 2.3);

      // 2.5s — Counter animation (15, 50)
      tl.add(animateCounters, 2.5);

      // Parallax on scroll
      gsap.to('.hero-bg-text', {
        y: '-20%', ease: 'none',
        scrollTrigger: { trigger: '.hero', scrub: 1 }
      });
    });

    // ═══════════════════════════════════════════
    // MOBILE — lighter but still impressive
    // ═══════════════════════════════════════════
    mm.add("(max-width: 767px)", function() {
      gsap.set(c1, { y: 50, opacity: 0, rotateX: -60 });
      gsap.set(c2, { y: -40, opacity: 0, rotateX: 60 });
      gsap.set(c3, { y: 50, opacity: 0, rotateX: -60 });
      gsap.set('.hero-bottom', { y: 30, opacity: 0 });
      gsap.set('.hero-meta', { opacity: 0, y: -10 });

      var tl = gsap.timeline({ delay: 0.15 });

      tl.to('.hero-meta', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, 0);

      tl.to(c1, {
        y: 0, opacity: 1, rotateX: 0,
        duration: 0.7, stagger: 0.04, ease: 'back.out(1.5)'
      }, 0.2);

      // Clip-path reveal for "LOSING"
      tl.to('.hero h1 .invert', {
        clipPath: 'inset(0 0% 0 0)',
        duration: 0.4, ease: 'power3.inOut'
      }, 0.6);

      tl.to(c2, {
        y: 0, opacity: 1, rotateX: 0,
        duration: 0.6, stagger: 0.05, ease: 'back.out(1.5)'
      }, 0.7);

      tl.to(c3, {
        y: 0, opacity: 1, rotateX: 0,
        duration: 0.7, stagger: 0.03, ease: 'back.out(1.5)'
      }, 1.0);

      tl.to('.hero-bottom', {
        opacity: 1, y: 0, duration: 0.6, ease: 'power2.out'
      }, 1.3);

      // Counter animation
      tl.add(animateCounters, 1.4);
    });
  });
</script>
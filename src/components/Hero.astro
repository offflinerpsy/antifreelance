---
---
<section class="hero">
  <div class="hero-bg-text" aria-hidden="true">BOT AI BOT AI</div>
  <div class="hero-meta">
    <!-- RU: AI-автоматизация для бизнеса · 2026 -->
    <div class="hero-tag">AI Automation for Business · 2026</div>
    <div class="hero-author">@Gypno_Man</div>
  </div>
  <!-- RU: Устали терять клиентов? -->
  <h1 id="hero-title" aria-label="Tired of losing customers?">
    <span class="line line1" data-text="Tired of">Tired of</span>
    <span class="line line2"><span class="invert" data-text="losing">losing</span></span>
    <span class="line line3" data-text="customers?">customers?</span>
  </h1>
  <div class="hero-bottom">
    <!-- RU: Telegram-бот отвечает мгновенно, работает 24/7 и стоит в 4–8 раз дешевле менеджера. Запуск за 2–3 дня. -->
    <p class="hero-desc">
      A Telegram bot responds instantly, works 24/7, and costs 4–8x less than a human agent. Launch in 2–3 days.
    </p>
    <div class="hero-stats-row">
      <!-- RU: лет опыта | ботов | без выходных -->
      <div class="h-stat"><div class="h-stat-n" data-count="15">15</div><div class="h-stat-l">years of experience</div></div>
      <div class="h-stat"><div class="h-stat-n">50+</div><div class="h-stat-l">bots built</div></div>
      <div class="h-stat"><div class="h-stat-n">24/7</div><div class="h-stat-l">always on</div></div>
    </div>
    <div class="hero-cta">
      <!-- RU: Консультация бесплатно → -->
      <a href="https://t.me/Gypno_Man" class="btn-primary">Free Consultation →</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 40px 60px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #FF5E00 0%, #FF7A29 100%);
  }
  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(80px, 20vw, 220px);
    color: rgba(255,255,255,0.07);
    white-space: nowrap;
    pointer-events: none;
    letter-spacing: -0.02em;
    user-select: none;
  }
  .hero-meta {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 16px;
    opacity: 0;
  }
  .hero-tag {
    font-size: clamp(10px, 2vw, 12px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(0,0,0,0.6);
    background: rgba(0,0,0,0.1);
    padding: 6px 14px;
    border-radius: 100px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    backdrop-filter: blur(4px);
  }
  .hero-tag::before { content: '●'; color: var(--black); font-size: 8px; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.2} }
  
  .hero-author {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1rem, 3vw, 1.2rem);
    color: rgba(0,0,0,0.5);
    letter-spacing: 0.1em;
  }

  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 12vw, 10rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    color: var(--black);
    position: relative;
    z-index: 2;
    max-width: 1200px;
    text-transform: uppercase;
    /* 3D perspective for character rotation */
    perspective: 1000px;
  }

  /* Each line is a block */
  .hero h1 .line {
    display: block;
    overflow: hidden;
  }

  /* Individual characters (injected by JS) */
  .hero h1 .char {
    display: inline-block;
    opacity: 0;
    transform-origin: 50% 100%;
    /* Enable 3D transforms */
    will-change: transform, opacity;
    backface-visibility: hidden;
  }

  .hero h1 .invert {
    color: var(--white);
    display: inline-block;
    background: var(--black);
    padding: 0 12px;
    line-height: 1;
    margin: 4px 0;
    overflow: hidden;
    /* perspectivе for .invert children */
    perspective: 800px;
  }
  .hero h1 .invert .char {
    color: var(--white);
  }

  /* Bottom section */
  .hero-bottom {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: clamp(20px, 5vw, 40px);
    border-top: 2px solid rgba(0,0,0,0.15);
    flex-wrap: wrap;
    gap: 24px;
    margin-top: clamp(20px, 5vw, 32px);
    opacity: 0;
  }
  .hero-desc {
    font-size: clamp(0.9rem, 2vw, 1rem);
    color: rgba(0,0,0,0.75);
    max-width: 380px;
    line-height: 1.65;
    font-weight: 500;
  }
  .hero-stats-row { display: flex; gap: clamp(20px, 5vw, 40px); flex-wrap: wrap; }
  .h-stat { text-align: center; }
  .h-stat-n {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 3rem);
    color: var(--black);
    line-height: 1;
  }
  .h-stat-l {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(0,0,0,0.6);
    margin-top: 2px;
    font-weight: 600;
  }
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
  }
  .hero-cta .btn-primary {
    width: 100%;
  }

  @media (min-width: 768px) {
    .hero-cta { width: auto; }
    .hero-cta .btn-primary { width: auto; }
  }

  @media (max-width: 768px) {
    .hero { padding: 120px 20px 40px; }
    .hero-meta { flex-direction: column; align-items: flex-start; }
    .hero-bottom { flex-direction: column; align-items: flex-start; }
    .hero-stats-row { width: 100%; justify-content: space-between; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // ─── Custom SplitText (no plugin needed) ───
    // Wraps each character in a <span class="char"> for animation
    function splitTextToChars(el) {
      const text = el.textContent || '';
      el.textContent = '';
      const chars = [];
      for (const char of text) {
        const span = document.createElement('span');
        span.className = 'char';
        span.textContent = char === ' ' ? '\u00A0' : char; // non-breaking space for spaces
        span.style.display = 'inline-block';
        el.appendChild(span);
        chars.push(span);
      }
      return chars;
    }

    // Split all lines into characters
    const line1 = document.querySelector('.line1');
    const invertEl = document.querySelector('.hero h1 .invert');
    const line3 = document.querySelector('.line3');
    
    let allChars = [];
    let line1Chars = [], line2Chars = [], line3Chars = [];

    if (line1) {
      // line1 has text directly: "Tired of"
      line1Chars = splitTextToChars(line1);
    }
    if (invertEl) {
      // line2 is inside .invert: "losing"
      line2Chars = splitTextToChars(invertEl);
    }
    if (line3) {
      // line3: "customers?"
      line3Chars = splitTextToChars(line3);
    }

    allChars = [...line1Chars, ...line2Chars, ...line3Chars];

    // ─── Detect motion preference ───
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      // No fancy animation — just show everything
      allChars.forEach(c => { c.style.opacity = '1'; c.style.transform = 'none'; });
      const meta = document.querySelector('.hero-meta');
      const bottom = document.querySelector('.hero-bottom');
      if (meta) meta.style.opacity = '1';
      if (bottom) bottom.style.opacity = '1';
      return;
    }

    // @ts-ignore
    let mm = gsap.matchMedia();

    mm.add("(min-width: 768px)", () => {
      // ─── DESKTOP: Cinematic character-by-character reveal ───
      
      // Set initial state for chars: rotated, translated, invisible
      // @ts-ignore
      gsap.set(line1Chars, { 
        rotationX: -90, 
        y: 80, 
        opacity: 0,
        transformOrigin: '50% 100%'
      });
      // @ts-ignore
      gsap.set(line2Chars, { 
        rotationX: 90, 
        y: -60, 
        opacity: 0,
        scaleY: 0.3,
        transformOrigin: '50% 0%'
      });
      // @ts-ignore
      gsap.set(line3Chars, { 
        rotationX: -90, 
        y: 80, 
        opacity: 0,
        transformOrigin: '50% 100%'
      });

      // @ts-ignore
      gsap.set('.hero-bottom', { y: 40, opacity: 0 });
      // @ts-ignore
      gsap.set('.hero-meta', { y: -30, opacity: 0 });

      // @ts-ignore
      const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

      // Meta bar fades in first
      tl.to('.hero-meta', { opacity: 1, y: 0, duration: 0.6 }, 0);

      // Line 1: "Tired of" — characters flip in from below, one by one
      tl.to(line1Chars, {
        rotationX: 0,
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.04,
        ease: 'back.out(2)',
      }, 0.2);

      // Line 2 "LOSING" (inverted) — characters drop in from top with scale
      tl.to(line2Chars, {
        rotationX: 0,
        y: 0,
        opacity: 1,
        scaleY: 1,
        duration: 0.7,
        stagger: 0.05,
        ease: 'elastic.out(1, 0.5)',
      }, 0.6);

      // Line 3: "customers?" — same flip from below, slightly delayed
      tl.to(line3Chars, {
        rotationX: 0,
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.03,
        ease: 'back.out(1.7)',
      }, 0.9);

      // Bottom bar (desc, stats, CTA) — slides up
      tl.to('.hero-bottom', {
        opacity: 1,
        y: 0,
        duration: 0.7,
        ease: 'power2.out'
      }, 1.4);

      // Parallax on scroll for background text
      // @ts-ignore
      gsap.to('.hero-bg-text', {
        y: '-20%',
        ease: 'none',
        // @ts-ignore
        scrollTrigger: { trigger: '.hero', scrub: 1 }
      });
    });

    mm.add("(max-width: 767px)", () => {
      // ─── MOBILE: Lighter but still impressive character animation ───
      
      // @ts-ignore
      gsap.set(line1Chars, { y: 40, opacity: 0, rotationX: -45 });
      // @ts-ignore
      gsap.set(line2Chars, { y: -30, opacity: 0, rotationX: 45 });
      // @ts-ignore
      gsap.set(line3Chars, { y: 40, opacity: 0, rotationX: -45 });
      // @ts-ignore
      gsap.set('.hero-bottom', { y: 20, opacity: 0 });
      // @ts-ignore
      gsap.set('.hero-meta', { opacity: 0 });

      // @ts-ignore
      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

      tl.to('.hero-meta', { opacity: 1, duration: 0.4 }, 0);

      tl.to(line1Chars, {
        y: 0, opacity: 1, rotationX: 0,
        duration: 0.5, stagger: 0.03
      }, 0.15);

      tl.to(line2Chars, {
        y: 0, opacity: 1, rotationX: 0,
        duration: 0.5, stagger: 0.04,
        ease: 'back.out(1.5)'
      }, 0.4);

      tl.to(line3Chars, {
        y: 0, opacity: 1, rotationX: 0,
        duration: 0.5, stagger: 0.03
      }, 0.6);

      tl.to('.hero-bottom', {
        opacity: 1, y: 0, duration: 0.5
      }, 0.9);
    });
  });
</script>
---
---
<section class="hero">
  <div class="hero-bg-text">BOT AI BOT AI</div>
  <div class="hero-meta">
    <!-- RU: AI-автоматизация для бизнеса · 2026 -->
    <div class="hero-tag">AI Automation for Business · 2026</div>
    <div class="hero-author">@Gypno_Man</div>
  </div>
  <!-- RU: Устали терять клиентов? -->
  <h1 id="hero-title">
    <span class="line1">Tired of</span><br>
    <span class="line2"><span class="invert">losing</span></span><br>
    <span class="line3">customers?</span>
  </h1>
  <div class="hero-bottom">
    <!-- RU: Telegram-бот отвечает мгновенно, работает 24/7 и стоит в 4–8 раз дешевле менеджера. Запуск за 2–3 дня. -->
    <p class="hero-desc">
      A Telegram bot responds instantly, works 24/7, and costs 4–8x less than a human agent. Launch in 2–3 days.
    </p>
    <div class="hero-stats-row">
      <!-- RU: лет опыта | ботов | без выходных -->
      <div class="h-stat"><div class="h-stat-n">15</div><div class="h-stat-l">years of experience</div></div>
      <div class="h-stat"><div class="h-stat-n">50+</div><div class="h-stat-l">bots built</div></div>
      <div class="h-stat"><div class="h-stat-n">24/7</div><div class="h-stat-l">always on</div></div>
    </div>
    <div class="hero-cta">
      <!-- RU: Консультация бесплатно → -->
      <a href="https://t.me/Gypno_Man" class="btn-primary">Free Consultation →</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 40px 60px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #FF5E00 0%, #FF7A29 100%);
  }
  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(80px, 20vw, 220px);
    color: rgba(255,255,255,0.07);
    white-space: nowrap;
    pointer-events: none;
    letter-spacing: -0.02em;
    user-select: none;
  }
  .hero-meta {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .hero-tag {
    font-size: clamp(10px, 2vw, 12px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(0,0,0,0.6);
    background: rgba(0,0,0,0.1);
    padding: 6px 14px;
    border-radius: 100px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    backdrop-filter: blur(4px);
  }
  .hero-tag::before { content: '●'; color: var(--black); font-size: 8px; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.2} }
  
  .hero-author {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1rem, 3vw, 1.2rem);
    color: rgba(0,0,0,0.5);
    letter-spacing: 0.1em;
  }

  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 12vw, 10rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
    color: var(--black);
    position: relative;
    z-index: 2;
    max-width: 1200px;
    text-transform: uppercase;
  }
  .hero h1 .invert {
    color: var(--white);
    display: inline-block;
    background: var(--black);
    padding: 0 12px;
    line-height: 1;
    margin: 4px 0;
  }

  .hero-bottom {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding-top: clamp(20px, 5vw, 40px);
    border-top: 2px solid rgba(0,0,0,0.15);
    flex-wrap: wrap;
    gap: 24px;
    margin-top: clamp(20px, 5vw, 32px);
  }
  .hero-desc {
    font-size: clamp(0.9rem, 2vw, 1rem);
    color: rgba(0,0,0,0.75);
    max-width: 380px;
    line-height: 1.65;
    font-weight: 500;
  }
  .hero-stats-row { display: flex; gap: clamp(20px, 5vw, 40px); flex-wrap: wrap; }
  .h-stat { text-align: center; }
  .h-stat-n {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 3rem);
    color: var(--black);
    line-height: 1;
  }
  .h-stat-l { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(0,0,0,0.6); margin-top: 2px; font-weight: 600; }
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
  }
  .hero-cta .btn-primary {
    width: 100%;
  }

  @media (min-width: 768px) {
    .hero-cta { width: auto; }
    .hero-cta .btn-primary { width: auto; }
  }

  @media (max-width: 768px) {
    .hero { padding: 120px 20px 40px; }
    .hero-meta { flex-direction: column; align-items: flex-start; }
    .hero-bottom { flex-direction: column; align-items: flex-start; }
    .hero-stats-row { width: 100%; justify-content: space-between; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // @ts-ignore
    let mm = gsap.matchMedia();

    mm.add("(min-width: 768px)", () => {
      // Desktop animations
      // @ts-ignore
      const tl = gsap.timeline();
      tl.from('.line1', { y: 120, opacity: 0, duration: 0.7, ease: 'power4.out' }, 0.1)
        .from('.line2', { y: 120, opacity: 0, duration: 0.7, ease: 'power4.out' }, 0.25)
        .from('.line3', { y: 120, opacity: 0, duration: 0.7, ease: 'power4.out' }, 0.4)
        .from('.hero-bottom', { opacity: 0, y: 30, duration: 0.6, ease: 'power2.out' }, 0.7)
        .from('.hero-meta', { opacity: 0, y: -20, duration: 0.5, ease: 'power2.out' }, 0.1);

      // @ts-ignore
      gsap.to('.hero-bg-text', {
        y: '-20%',
        ease: 'none',
        // @ts-ignore
        scrollTrigger: { trigger: '.hero', scrub: 1 }
      });
    });

    mm.add("(max-width: 767px)", () => {
      // Mobile animations (lighter)
      // @ts-ignore
      const tl = gsap.timeline();
      tl.from('.line1, .line2, .line3', { y: 50, opacity: 0, duration: 0.6, stagger: 0.1, ease: 'power3.out' }, 0.1)
        .from('.hero-bottom', { opacity: 0, y: 20, duration: 0.5, ease: 'power2.out' }, 0.5)
        .from('.hero-meta', { opacity: 0, duration: 0.5 }, 0.1);
        
      // Disable heavy parallax on mobile to save battery and prevent jank
    });
  });
</script>
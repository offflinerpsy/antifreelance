---
/* RU:
  Секция «Live Demo» — два устройства в бесконечном цикле:
  1. Смартфон: чат → календарь (сканер) → подтверждение
  2. Ноутбук (MacBook): сайт с чат-виджетом → сбор данных → подтверждение
  Цикл: телефон → кросс-фейд → ноутбук → кросс-фейд → телефон → ...
  GSAP is:inline.
*/
---

<section class="demo-section" id="demo">
  <div class="demo-header">
    <div class="section-num reveal">03 — Live Demo</div>
    <h2 class="section-big-title reveal">See how it<br><span class="accent">actually works</span></h2>
    <p class="demo-subtitle reveal">Your AI assistant handles the entire booking flow — on any device, any platform. No human needed.</p>
  </div>

  <div class="demo-stage" id="demo-stage">

    <!-- ═══════════ DEVICE 1: PHONE ═══════════ -->
    <div class="device-wrap" id="demo-phone-wrap">
      <div class="device-glow device-glow--orange"></div>
      <div class="phone-device" id="phone-device">
        <div class="ph-statusbar">
          <span class="ph-time">9:41</span>
          <div class="ph-notch"></div>
          <div class="ph-icons">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="17" y="4" width="5" height="16" rx="1"/><rect x="11" y="8" width="5" height="12" rx="1"/><rect x="5" y="12" width="5" height="8" rx="1"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="2" y="6" width="18" height="12" rx="2" stroke="currentColor" stroke-width="2" fill="none"/><rect x="21" y="10" width="2" height="4" rx="0.5"/><rect x="4" y="8" width="10" height="8" rx="1" fill="currentColor"/></svg>
          </div>
        </div>
        <div class="ph-screens">
          <!-- Chat screen -->
          <div class="ph-screen" id="ph-chat">
            <div class="ph-chat-header">
              <div class="ph-avatar"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><circle cx="12" cy="5" r="4"/></svg></div>
              <div><div class="ph-chat-name">Override AI</div><div class="ph-chat-status">Online</div></div>
            </div>
            <div class="ph-chat-body">
              <div class="ph-msg ph-msg-user" id="ph-msg-user">I need to book a haircut for Saturday</div>
              <div class="ph-msg ph-msg-bot" id="ph-msg-bot">
                <span class="ph-typing" id="ph-typing"><span></span><span></span><span></span></span>
                <span class="ph-bot-text" id="ph-bot-text">Got it! Let me find available slots for Saturday...</span>
              </div>
            </div>
            <div class="ph-chat-input"><div class="ph-input-bar">Type a message...</div><div class="ph-send-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg></div></div>
          </div>
          <!-- Calendar screen -->
          <div class="ph-screen" id="ph-calendar">
            <div class="ph-cal-header">
              <span class="ph-cal-title">October 2026</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div class="ph-cal-days"><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span></div>
            <div class="ph-cal-grid" id="ph-cal-grid">
              <span class="ph-day ph-day-muted">28</span><span class="ph-day ph-day-muted">29</span><span class="ph-day ph-day-muted">30</span>
              <span class="ph-day">1</span><span class="ph-day">2</span><span class="ph-day" id="ph-day-target">3</span><span class="ph-day">4</span>
              <span class="ph-day">5</span><span class="ph-day">6</span><span class="ph-day">7</span><span class="ph-day">8</span><span class="ph-day">9</span><span class="ph-day">10</span><span class="ph-day">11</span>
              <span class="ph-day">12</span><span class="ph-day">13</span><span class="ph-day">14</span><span class="ph-day">15</span><span class="ph-day">16</span><span class="ph-day">17</span><span class="ph-day">18</span>
            </div>
            <div class="ph-scanner" id="ph-scanner"></div>
            <div class="ph-slots" id="ph-slots">
              <div class="ph-slot-label">Available on Sat, Oct 3</div>
              <div class="ph-slot" id="ph-slot-1"><span class="ph-slot-time">10:00 AM</span><span class="ph-slot-tag">Available</span></div>
              <div class="ph-slot" id="ph-slot-2"><span class="ph-slot-time">2:30 PM</span><span class="ph-slot-tag">Available</span></div>
            </div>
          </div>
          <!-- Confirmation screen -->
          <div class="ph-screen" id="ph-confirm">
            <div class="ph-confirm-card" id="ph-confirm-card">
              <div class="ph-confirm-icon"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg></div>
              <div class="ph-confirm-title">Booked!</div>
              <div class="ph-confirm-detail">
                <div class="ph-confirm-row"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg> Saturday, Oct 3</div>
                <div class="ph-confirm-row"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> 10:00 AM</div>
                <div class="ph-confirm-row"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/><circle cx="12" cy="10" r="3"/></svg> Beauty Salon &middot; downtown</div>
              </div>
              <div class="ph-confirm-btn">View in Calendar</div>
            </div>
          </div>
        </div>
        <div class="ph-home-ind"></div>
      </div>
    </div>

    <!-- ═══════════ DEVICE 2: LAPTOP ═══════════ -->
    <div class="device-wrap" id="demo-laptop-wrap">
      <div class="device-glow device-glow--lime"></div>
      <div class="laptop-device" id="laptop-device">
        <div class="lp-screen">
          <!-- Browser chrome -->
          <div class="lp-browser-bar">
            <div class="lp-dots"><span></span><span></span><span></span></div>
            <div class="lp-url-bar">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              <span>glow-salon.com</span>
            </div>
            <div class="lp-bar-spacer"></div>
          </div>
          <!-- Fake website -->
          <div class="lp-website" id="lp-website">
            <div class="lp-nav">
              <span class="lp-site-name">Glow Salon</span>
              <div class="lp-nav-links"><span>Services</span><span>Gallery</span><span>Book Now</span></div>
            </div>
            <div class="lp-hero">
              <div class="lp-hero-tag">Premium Hair Studio</div>
              <div class="lp-hero-title">Your Style,<br>Perfected.</div>
              <div class="lp-hero-cta">Book Appointment</div>
            </div>
            <div class="lp-cards-row">
              <div class="lp-mini-card"><div class="lp-mc-icon">&#9986;</div><div class="lp-mc-label">Haircut</div></div>
              <div class="lp-mini-card"><div class="lp-mc-icon">&#127912;</div><div class="lp-mc-label">Color</div></div>
              <div class="lp-mini-card"><div class="lp-mc-icon">&#128134;</div><div class="lp-mc-label">Treatment</div></div>
            </div>
            <!-- Chat bubble -->
            <div class="lp-chat-bubble" id="lp-chat-bubble">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </div>
            <!-- Chat widget panel -->
            <div class="lp-chat-widget" id="lp-chat-widget">
              <div class="lp-cw-header">
                <div class="lp-cw-avatar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><circle cx="12" cy="5" r="4"/></svg></div>
                <div><div class="lp-cw-name">Glow Assistant</div><div class="lp-cw-status">Online now</div></div>
              </div>
              <div class="lp-cw-body" id="lp-cw-body">
                <div class="lp-cw-msg lp-cw-bot" id="lp-m1">Hi! I'm Glow's booking assistant. What's your name?</div>
                <div class="lp-cw-msg lp-cw-user" id="lp-m2">Sarah</div>
                <div class="lp-cw-msg lp-cw-bot" id="lp-m3">Nice to meet you, Sarah! What service are you looking for?</div>
                <div class="lp-cw-msg lp-cw-user" id="lp-m4">Haircut &amp; Color</div>
                <div class="lp-cw-msg lp-cw-bot" id="lp-m5">Great choice! When would you like to come in?</div>
                <div class="lp-cw-msg lp-cw-user" id="lp-m6">Next Friday</div>
                <div class="lp-cw-msg lp-cw-bot lp-cw-confirm" id="lp-m7">
                  <strong>All set, Sarah!</strong><br>
                  <span class="lp-m7-detail">Fri, Oct 9 &middot; 2:00 PM<br>Haircut &amp; Color with Alex</span>
                </div>
              </div>
              <div class="lp-cw-input"><div class="lp-cw-input-bar">Type your message...</div></div>
            </div>
          </div>
        </div>
        <!-- Base / keyboard -->
        <div class="lp-base"><div class="lp-trackpad"></div></div>
        <div class="lp-hinge"></div>
      </div>
    </div>

    <!-- Dot indicator -->
    <div class="demo-dots">
      <span class="ddot ddot--active" id="ddot-phone"></span>
      <span class="ddot" id="ddot-laptop"></span>
    </div>
  </div>
</section>

<style>
  /* ═══ SECTION ═══ */
  .demo-section {
    background: var(--black);
    padding: clamp(60px, 10vw, 120px) clamp(20px, 5vw, 40px);
    overflow: hidden;
  }
  .demo-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto clamp(40px, 8vw, 80px);
  }
  .demo-subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
    color: rgba(255,255,255,0.55);
    max-width: 500px;
    margin: 0 auto;
  }

  /* ═══ STAGE ═══ */
  .demo-stage {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .device-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  #demo-laptop-wrap { opacity: 0; }

  /* Glows */
  .device-glow {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(60px);
  }
  .device-glow--orange { background: rgba(255,94,0,0.13); }
  .device-glow--lime   { background: rgba(221,245,22,0.10); }

  /* Dot nav */
  .demo-dots {
    position: absolute;
    bottom: -14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
  }
  .ddot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    transition: all 0.4s;
  }
  .ddot--active {
    background: var(--orange);
    width: 24px;
    border-radius: 4px;
  }

  /* ═══ PHONE DEVICE ═══ */
  .phone-device {
    position: relative;
    width: 280px;
    height: 580px;
    background: #1a1a1a;
    border-radius: 40px;
    border: 3px solid rgba(255,255,255,0.1);
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(255,255,255,0.05), 0 25px 60px rgba(0,0,0,0.6), 0 0 80px rgba(255,94,0,0.08);
    z-index: 1;
    display: flex;
    flex-direction: column;
  }
  .ph-statusbar { height: 48px; display: flex; align-items: flex-end; justify-content: space-between; padding: 0 20px 8px; background: #1a1a1a; position: relative; z-index: 10; flex-shrink: 0; }
  .ph-time { font-size: 13px; font-weight: 600; color: var(--white); }
  .ph-notch { position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 100px; height: 28px; background: #000; border-radius: 0 0 18px 18px; }
  .ph-icons { display: flex; gap: 4px; color: var(--white); opacity: 0.7; }
  .ph-screens { flex: 1; position: relative; overflow: hidden; background: #111; }
  .ph-screen { position: absolute; inset: 0; display: flex; flex-direction: column; opacity: 0; will-change: transform, opacity; }
  #ph-chat { opacity: 1; }

  /* Chat */
  .ph-chat-header { display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: #1a1a1a; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .ph-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--orange); display: flex; align-items: center; justify-content: center; color: #fff; }
  .ph-chat-name { font-size: 13px; font-weight: 600; color: var(--white); }
  .ph-chat-status { font-size: 10px; color: var(--lime); font-weight: 500; }
  .ph-chat-body { flex: 1; display: flex; flex-direction: column; justify-content: flex-end; padding: 16px 14px; gap: 12px; }
  .ph-msg { max-width: 82%; padding: 10px 14px; border-radius: 16px; font-size: 13px; line-height: 1.5; opacity: 0; transform: translateY(10px) scale(0.95); }
  .ph-msg-user { align-self: flex-end; background: var(--orange); color: #fff; border-bottom-right-radius: 4px; }
  .ph-msg-bot { align-self: flex-start; background: rgba(255,255,255,0.08); color: var(--white); border-bottom-left-radius: 4px; }
  .ph-bot-text { display: none; }
  .ph-typing { display: inline-flex; gap: 4px; align-items: center; height: 18px; }
  .ph-typing span { width: 6px; height: 6px; background: rgba(255,255,255,0.4); border-radius: 50%; animation: typingBounce 1.2s infinite; }
  .ph-typing span:nth-child(2) { animation-delay: 0.15s; }
  .ph-typing span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes typingBounce { 0%,60%,100% { transform: translateY(0); opacity: 0.4; } 30% { transform: translateY(-4px); opacity: 1; } }
  .ph-chat-input { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: #1a1a1a; border-top: 1px solid rgba(255,255,255,0.06); }
  .ph-input-bar { flex: 1; height: 36px; background: rgba(255,255,255,0.06); border-radius: 20px; display: flex; align-items: center; padding: 0 14px; font-size: 12px; color: rgba(255,255,255,0.3); }
  .ph-send-btn { width: 36px; height: 36px; background: var(--orange); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }

  /* Calendar */
  #ph-calendar { background: #111; }
  .ph-cal-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .ph-cal-title { font-family: 'Bebas Neue', sans-serif; font-size: 18px; letter-spacing: 0.05em; color: var(--white); }
  .ph-cal-days { display: grid; grid-template-columns: repeat(7, 1fr); padding: 10px 12px 4px; }
  .ph-cal-days span { text-align: center; font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.3); text-transform: uppercase; }
  .ph-cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); padding: 6px 12px; gap: 4px; position: relative; }
  .ph-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; color: rgba(255,255,255,0.7); border-radius: 10px; transition: all 0.3s; }
  .ph-day-muted { color: rgba(255,255,255,0.15); }
  .ph-scanner { position: absolute; left: 12px; right: 12px; top: 105px; height: 2px; background: var(--orange); box-shadow: 0 0 12px rgba(255,94,0,0.6), 0 0 30px rgba(255,94,0,0.2); border-radius: 2px; opacity: 0; z-index: 5; pointer-events: none; }
  .ph-slots { padding: 12px 16px; opacity: 0; }
  .ph-slot-label { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }
  .ph-slot { display: flex; justify-content: space-between; align-items: center; padding: 12px 14px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; margin-bottom: 8px; }
  .ph-slot-time { font-size: 13px; font-weight: 600; color: var(--white); }
  .ph-slot-tag { font-size: 10px; font-weight: 600; color: var(--lime); background: rgba(221,245,22,0.1); padding: 3px 10px; border-radius: 100px; text-transform: uppercase; letter-spacing: 0.05em; }

  /* Confirm */
  #ph-confirm { background: #111; align-items: center; justify-content: center; padding: 24px; }
  .ph-confirm-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 32px 24px; text-align: center; width: 100%; opacity: 0; transform: scale(0.85) translateY(20px); }
  .ph-confirm-icon { width: 64px; height: 64px; border-radius: 50%; background: rgba(255,94,0,0.12); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
  .ph-confirm-title { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--white); letter-spacing: 0.03em; margin-bottom: 16px; }
  .ph-confirm-detail { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
  .ph-confirm-row { display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 13px; color: rgba(255,255,255,0.6); }
  .ph-confirm-btn { display: inline-block; padding: 10px 24px; background: var(--orange); color: #fff; border-radius: 100px; font-size: 13px; font-weight: 600; }
  .ph-home-ind { height: 22px; display: flex; align-items: center; justify-content: center; background: #1a1a1a; flex-shrink: 0; }
  .ph-home-ind::after { content: ''; width: 100px; height: 4px; background: rgba(255,255,255,0.2); border-radius: 4px; }

  /* ═══ LAPTOP DEVICE ═══ */
  .laptop-device {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .lp-screen {
    width: 560px;
    height: 350px;
    background: #0e0e0e;
    border-radius: 12px 12px 0 0;
    border: 2px solid rgba(255,255,255,0.08);
    border-bottom: none;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .lp-browser-bar {
    height: 30px;
    background: #1a1a1a;
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    flex-shrink: 0;
  }
  .lp-dots { display: flex; gap: 5px; }
  .lp-dots span { width: 8px; height: 8px; border-radius: 50%; }
  .lp-dots span:nth-child(1) { background: #ff5f57; }
  .lp-dots span:nth-child(2) { background: #ffbd2e; }
  .lp-dots span:nth-child(3) { background: #28ca41; }
  .lp-url-bar {
    flex: 1; max-width: 260px; height: 20px;
    background: rgba(255,255,255,0.06); border-radius: 5px;
    display: flex; align-items: center; gap: 5px; padding: 0 8px;
    font-size: 10px; color: rgba(255,255,255,0.4); margin: 0 auto;
  }
  .lp-bar-spacer { width: 60px; }

  /* Fake Website */
  .lp-website { flex: 1; background: #111; position: relative; overflow: hidden; }
  .lp-nav { display: flex; align-items: center; justify-content: space-between; padding: 8px 16px; border-bottom: 1px solid rgba(255,255,255,0.04); }
  .lp-site-name { font-family: 'Bebas Neue', sans-serif; font-size: 14px; color: var(--white); letter-spacing: 0.06em; }
  .lp-nav-links { display: flex; gap: 14px; }
  .lp-nav-links span { font-size: 9px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 500; }
  .lp-hero { padding: 20px 16px 12px; }
  .lp-hero-tag { font-size: 8px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--orange); font-weight: 600; margin-bottom: 6px; }
  .lp-hero-title { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--white); line-height: 0.95; margin-bottom: 10px; }
  .lp-hero-cta { display: inline-block; padding: 5px 14px; background: var(--orange); color: #fff; border-radius: 6px; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
  .lp-cards-row { display: flex; gap: 8px; padding: 10px 16px 0; }
  .lp-mini-card { flex: 1; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 8px; text-align: center; }
  .lp-mc-icon { font-size: 14px; margin-bottom: 3px; }
  .lp-mc-label { font-size: 8px; color: rgba(255,255,255,0.5); font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }

  /* Chat bubble */
  .lp-chat-bubble {
    position: absolute; bottom: 12px; right: 12px;
    width: 40px; height: 40px;
    background: var(--orange); border-radius: 50%;
    display: flex; align-items: center; justify-content: center; color: #fff;
    box-shadow: 0 4px 16px rgba(255,94,0,0.4);
    z-index: 10;
  }
  /* Chat widget */
  .lp-chat-widget {
    position: absolute; bottom: 60px; right: 12px;
    width: 220px; max-height: 250px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    display: flex; flex-direction: column;
    z-index: 15;
    box-shadow: 0 8px 30px rgba(0,0,0,0.5);
    opacity: 0; transform: translateY(10px) scale(0.95);
  }
  .lp-cw-header { display: flex; align-items: center; gap: 7px; padding: 8px 10px; background: var(--orange); flex-shrink: 0; }
  .lp-cw-avatar { width: 22px; height: 22px; border-radius: 50%; background: rgba(0,0,0,0.2); display: flex; align-items: center; justify-content: center; }
  .lp-cw-name { font-size: 10px; font-weight: 600; color: #fff; }
  .lp-cw-status { font-size: 8px; color: rgba(255,255,255,0.7); }
  .lp-cw-body { flex: 1; padding: 8px; display: flex; flex-direction: column; gap: 6px; overflow-y: auto; }
  .lp-cw-msg { max-width: 85%; padding: 6px 10px; border-radius: 10px; font-size: 10px; line-height: 1.5; opacity: 0; transform: translateY(6px); }
  .lp-cw-bot { align-self: flex-start; background: rgba(255,255,255,0.08); color: var(--white); border-bottom-left-radius: 3px; }
  .lp-cw-user { align-self: flex-end; background: var(--orange); color: #fff; border-bottom-right-radius: 3px; }
  .lp-cw-confirm { background: rgba(255,94,0,0.12); border: 1px solid rgba(255,94,0,0.2); }
  .lp-m7-detail { font-size: 9px; color: rgba(255,255,255,0.6); display: block; margin-top: 3px; }
  .lp-cw-input { padding: 6px 8px; border-top: 1px solid rgba(255,255,255,0.05); }
  .lp-cw-input-bar { height: 26px; background: rgba(255,255,255,0.06); border-radius: 14px; display: flex; align-items: center; padding: 0 10px; font-size: 9px; color: rgba(255,255,255,0.25); }

  /* Laptop base */
  .lp-base {
    width: 620px; height: 14px;
    background: linear-gradient(to bottom, #2a2a2a, #1a1a1a);
    border-radius: 0 0 8px 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .lp-trackpad { width: 120px; height: 6px; background: rgba(255,255,255,0.04); border-radius: 3px; }
  .lp-hinge {
    width: 640px; height: 4px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
    border-radius: 0 0 2px 2px;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 700px) {
    .demo-stage { min-height: 520px; }
    .phone-device { width: 240px; height: 500px; border-radius: 32px; }
    .ph-notch { width: 80px; height: 24px; }
    .lp-screen { width: 340px; height: 220px; }
    .lp-base { width: 380px; }
    .lp-hinge { width: 390px; }
    .lp-chat-widget { width: 180px; max-height: 200px; }
    .lp-hero-title { font-size: 20px; }
  }
  @media (max-width: 420px) {
    .lp-screen { width: 280px; height: 180px; }
    .lp-base { width: 310px; }
    .lp-hinge { width: 320px; }
    .lp-chat-widget { width: 160px; max-height: 170px; }
    .lp-cards-row { display: none; }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    if (typeof gsap === 'undefined') return;

    /* ─── Helpers ─── */
    function anim(t, p, o) {
      return new Promise(function (r) { gsap.to(t, Object.assign({}, p, o, { onComplete: r })); });
    }
    function setImm(t, p) { gsap.set(t, p); }
    function wait(s) { return new Promise(function (r) { setTimeout(r, s * 1000); }); }

    var running = true;

    /* ═══════════ PHONE SEQUENCE ═══════════ */
    async function phoneSequence() {
      /* Reset */
      setImm('#ph-chat', { opacity: 1, x: '0%' });
      setImm('#ph-calendar', { opacity: 0, x: '100%' });
      setImm('#ph-confirm', { opacity: 0 });
      setImm('#ph-msg-user', { opacity: 0, y: 10, scale: 0.95 });
      setImm('#ph-msg-bot', { opacity: 0, y: 10, scale: 0.95 });
      setImm('#ph-typing', { display: 'inline-flex' });
      setImm('#ph-bot-text', { display: 'none' });
      setImm('#ph-scanner', { opacity: 0, y: 0 });
      setImm('#ph-day-target', { background: 'transparent', color: 'rgba(255,255,255,0.7)', scale: 1 });
      setImm('#ph-slots', { opacity: 0, y: 10 });
      setImm('#ph-slot-1', { background: 'rgba(255,255,255,0.04)', borderColor: 'rgba(255,255,255,0.06)' });
      setImm('#ph-confirm-card', { opacity: 0, scale: 0.85, y: 20 });

      await wait(0.6);

      /* 1. User message */
      await anim('#ph-msg-user', { opacity: 1, y: 0, scale: 1 }, { duration: 0.4, ease: 'back.out(1.7)' });
      await wait(0.8);

      /* 2. Bot typing → reply */
      await anim('#ph-msg-bot', { opacity: 1, y: 0, scale: 1 }, { duration: 0.4, ease: 'back.out(1.7)' });
      await wait(1.2);
      setImm('#ph-typing', { display: 'none' });
      setImm('#ph-bot-text', { display: 'inline' });
      await wait(1.5);

      /* 3. Chat → Calendar */
      await Promise.all([
        anim('#ph-chat', { x: '-100%', opacity: 0 }, { duration: 0.5, ease: 'power2.inOut' }),
        anim('#ph-calendar', { x: '0%', opacity: 1 }, { duration: 0.5, ease: 'power2.inOut' })
      ]);
      await wait(0.3);

      /* 4. Scanner sweep */
      await anim('#ph-scanner', { opacity: 1 }, { duration: 0.15 });
      await anim('#ph-scanner', { y: 110 }, { duration: 1.0, ease: 'none' });
      await anim('#ph-scanner', { opacity: 0 }, { duration: 0.15 });

      /* 5. Highlight date */
      await anim('#ph-day-target', { background: 'var(--orange)', color: '#fff', scale: 1.25 }, { duration: 0.3, ease: 'back.out(2)' });
      await wait(0.3);

      /* 6. Show slots */
      await anim('#ph-slots', { opacity: 1, y: 0 }, { duration: 0.4, ease: 'power2.out' });
      await wait(0.5);

      /* 7. Tap slot */
      await anim('#ph-slot-1', { scale: 0.95 }, { duration: 0.08 });
      await anim('#ph-slot-1', { scale: 1, background: 'var(--orange)', borderColor: 'var(--orange)' }, { duration: 0.2, ease: 'back.out(1.5)' });
      await wait(0.6);

      /* 8. Calendar → Confirmation */
      await anim('#ph-calendar', { opacity: 0 }, { duration: 0.3 });
      setImm('#ph-confirm', { opacity: 1 });
      await anim('#ph-confirm-card', { opacity: 1, scale: 1, y: 0 }, { duration: 0.5, ease: 'back.out(1.7)' });

      /* 9. Hold */
      await wait(3.0);
    }

    /* ═══════════ LAPTOP SEQUENCE ═══════════ */
    async function laptopSequence() {
      var msgs = ['#lp-m1','#lp-m2','#lp-m3','#lp-m4','#lp-m5','#lp-m6','#lp-m7'];
      /* Reset */
      msgs.forEach(function (m) { setImm(m, { opacity: 0, y: 6 }); });
      setImm('#lp-chat-widget', { opacity: 0, y: 10, scale: 0.95 });
      setImm('#lp-chat-bubble', { scale: 1 });
      var body = document.getElementById('lp-cw-body');
      if (body) body.scrollTop = 0;

      await wait(0.5);

      /* Bubble pulse */
      await anim('#lp-chat-bubble', { scale: 1.2 }, { duration: 0.15 });
      await anim('#lp-chat-bubble', { scale: 1 }, { duration: 0.15 });
      await wait(0.3);

      /* Open widget */
      await anim('#lp-chat-widget', { opacity: 1, y: 0, scale: 1 }, { duration: 0.4, ease: 'back.out(1.7)' });
      await wait(0.4);

      /* Conversation */
      var delays = [0.7, 0.9, 0.7, 0.9, 0.7, 0.9, 0.5];
      for (var i = 0; i < msgs.length; i++) {
        await anim(msgs[i], { opacity: 1, y: 0 }, { duration: 0.3, ease: 'back.out(1.5)' });
        if (body) body.scrollTop = body.scrollHeight;
        await wait(delays[i]);
      }

      /* Hold on confirmation */
      await wait(3.0);

      /* Close widget */
      await anim('#lp-chat-widget', { opacity: 0, y: 10, scale: 0.95 }, { duration: 0.35 });
    }

    /* ═══════════ MAIN LOOP ═══════════ */
    async function mainLoop() {
      while (running) {
        /* ── Phone turn ── */
        setImm('#demo-phone-wrap', { opacity: 1, pointerEvents: 'auto' });
        setImm('#demo-laptop-wrap', { opacity: 0, pointerEvents: 'none' });
        setImm('#ddot-phone', { background: 'var(--orange)', width: '24px', borderRadius: '4px' });
        setImm('#ddot-laptop', { background: 'rgba(255,255,255,0.2)', width: '8px', borderRadius: '50%' });

        await phoneSequence();

        /* ── Cross-fade: phone → laptop ── */
        await Promise.all([
          anim('#demo-phone-wrap', { opacity: 0 }, { duration: 0.7, ease: 'power2.inOut' }),
          anim('#demo-laptop-wrap', { opacity: 1 }, { duration: 0.7, ease: 'power2.inOut' })
        ]);
        setImm('#demo-phone-wrap', { pointerEvents: 'none' });
        setImm('#demo-laptop-wrap', { pointerEvents: 'auto' });
        setImm('#ddot-phone', { background: 'rgba(255,255,255,0.2)', width: '8px', borderRadius: '50%' });
        setImm('#ddot-laptop', { background: 'var(--lime)', width: '24px', borderRadius: '4px' });

        /* ── Laptop turn ── */
        await laptopSequence();

        /* ── Cross-fade: laptop → phone ── */
        await Promise.all([
          anim('#demo-laptop-wrap', { opacity: 0 }, { duration: 0.7, ease: 'power2.inOut' }),
          anim('#demo-phone-wrap', { opacity: 1 }, { duration: 0.7, ease: 'power2.inOut' })
        ]);
        setImm('#demo-laptop-wrap', { pointerEvents: 'none' });
        setImm('#demo-phone-wrap', { pointerEvents: 'auto' });
      }
    }

    /* Start on scroll */
    if (typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);
      ScrollTrigger.create({
        trigger: '#demo-stage',
        start: 'top 90%',
        once: true,
        onEnter: function () { mainLoop(); }
      });
    } else {
      mainLoop();
    }
  });
</script>

---
---
<!-- Chat Toggle Button -->
<button class="chat-toggle" id="chat-toggle" aria-label="Open chat">
  <span class="toggle-icon-wrap">
    <svg class="chat-icon-open" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <svg class="chat-icon-close" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </span>
  <span class="chat-badge" id="chat-badge" style="display:none">1</span>
</button>

<!-- Chat Panel -->
<div class="chat-panel" id="chat-panel">

  <!-- Header -->
  <div class="chat-header">
    <div class="chat-avatar-wrap">
      <div class="chat-avatar">
        <svg viewBox="0 0 36 36" width="22" height="22" fill="none">
          <circle cx="18" cy="12" r="5" fill="white" opacity="0.95"/>
          <path d="M6 30c0-6.627 5.373-12 12-12s12 5.373 12 12" stroke="white" stroke-width="2.5" stroke-linecap="round" opacity="0.95"/>
        </svg>
      </div>
      <span class="online-dot"></span>
    </div>
    <div class="chat-header-text">
      <div class="chat-name">BotStudio</div>
      <div class="chat-status" data-i18n="chat.status">AI Assistant · Online</div>
    </div>
    <button class="chat-close" id="chat-close" aria-label="Close">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Messages -->
  <div class="chat-messages" id="chat-messages"></div>

  <!-- Quick Replies -->
  <div class="chat-quick-replies" id="chat-quick-replies"></div>

  <!-- Input -->
  <form class="chat-input-area" id="chat-form">
    <input type="text" id="chat-input" placeholder="Type a message..." autocomplete="off" data-i18n-ph="chat.input_ph" />
    <button type="submit" class="chat-send" aria-label="Send">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2" fill="currentColor" stroke="none"></polygon>
      </svg>
    </button>
  </form>

  <div class="chat-footer-label">Powered by <strong>BotStudio AI</strong></div>
</div>

<style>
  /* ── Toggle Button ─────────────────────────────────── */
  .chat-toggle {
    position: fixed;
    bottom: 28px;
    right: 28px;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff6b00 0%, #ff9500 100%);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 32px rgba(255, 107, 0, 0.45), 0 2px 8px rgba(0,0,0,0.25);
    z-index: 10000;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.25s ease;
    outline: none;
  }
  .chat-toggle:hover {
    transform: scale(1.1);
    box-shadow: 0 12px 40px rgba(255, 107, 0, 0.55), 0 4px 12px rgba(0,0,0,0.3);
  }
  .chat-toggle:active { transform: scale(0.95); }

  .toggle-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease;
  }

  .chat-badge {
    position: absolute;
    top: -3px;
    right: -3px;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #c8f135;
    color: #111;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #0a0a0a;
    animation: badgePop 2s ease-in-out infinite;
  }
  @keyframes badgePop {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.18); }
  }

  /* ── Panel ─────────────────────────────────────────── */
  .chat-panel {
    position: fixed;
    bottom: 100px;
    right: 28px;
    width: 368px;
    max-height: 560px;
    background: #111111;
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    z-index: 9999;
    overflow: hidden;
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.7),
      0 0 0 1px rgba(255, 107, 0, 0.08),
      inset 0 1px 0 rgba(255,255,255,0.06);
    opacity: 0;
    transform: translateY(16px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.28s ease, transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: bottom right;
  }
  .chat-panel.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  @media (max-width: 480px) {
    .chat-panel {
      bottom: 0; right: 0;
      width: 100%; max-height: 100%;
      border-radius: 20px 20px 0 0;
      height: 92vh;
    }
    .chat-toggle { bottom: 16px; right: 16px; }
  }

  /* ── Header ───────────────────────────────────────── */
  .chat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px 16px;
    background: linear-gradient(135deg, rgba(255, 107, 0, 0.18) 0%, rgba(255, 149, 0, 0.08) 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    flex-shrink: 0;
  }

  .chat-avatar-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .chat-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff6b00, #ff9500);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(255, 107, 0, 0.35);
    position: relative;
  }
  .chat-avatar::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 2px solid rgba(255, 107, 0, 0.25);
    animation: avatarPulse 2.5s ease-in-out infinite;
  }
  @keyframes avatarPulse {
    0%, 100% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.12); opacity: 0; }
  }

  .online-dot {
    position: absolute;
    bottom: 1px;
    right: 1px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #22c55e;
    border: 2px solid #111;
    box-shadow: 0 0 8px rgba(34, 197, 94, 0.6);
    animation: onlinePulse 2s ease-in-out infinite;
  }
  @keyframes onlinePulse {
    0%, 100% { box-shadow: 0 0 6px rgba(34, 197, 94, 0.5); }
    50% { box-shadow: 0 0 14px rgba(34, 197, 94, 0.8); }
  }

  .chat-header-text { flex: 1; min-width: 0; }

  .chat-name {
    font-weight: 700;
    font-size: 0.9rem;
    color: #ffffff;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .chat-status {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.45);
    margin-top: 2px;
    line-height: 1;
  }

  .chat-close {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .chat-close:hover {
    background: rgba(255,255,255,0.12);
    color: #fff;
  }

  /* ── Messages ─────────────────────────────────────── */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px 16px 8px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
    overscroll-behavior: contain;
  }
  .chat-messages::-webkit-scrollbar { width: 3px; }
  .chat-messages::-webkit-scrollbar-track { background: transparent; }
  .chat-messages::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
  }

  /* Message bubbles */
  .chat-msg {
    max-width: 82%;
    padding: 10px 14px;
    border-radius: 18px;
    font-size: 0.88rem;
    line-height: 1.55;
    animation: msgSlideIn 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    word-break: break-word;
    position: relative;
  }
  @keyframes msgSlideIn {
    from { opacity: 0; transform: translateY(10px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .chat-msg.bot {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255,255,255,0.9);
    border-bottom-left-radius: 5px;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .chat-msg.user {
    align-self: flex-end;
    background: linear-gradient(135deg, #ff6b00, #ff8c00);
    color: #fff;
    border-bottom-right-radius: 5px;
    box-shadow: 0 4px 16px rgba(255, 107, 0, 0.3);
  }

  .chat-msg.typing {
    align-self: flex-start;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.05);
    border-bottom-left-radius: 5px;
    padding: 12px 16px;
  }
  .typing-dots {
    display: flex;
    gap: 4px;
    align-items: center;
    height: 12px;
  }
  .typing-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    animation: dotBounce 1.3s ease-in-out infinite;
  }
  .typing-dots span:nth-child(2) { animation-delay: 0.15s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes dotBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-6px); opacity: 1; }
  }

  /* Bot avatar on messages */
  .msg-row {
    display: flex;
    align-items: flex-end;
    gap: 8px;
  }
  .msg-row.user { flex-direction: row-reverse; }
  .msg-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff6b00, #ff9500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 700;
    color: white;
    font-family: 'Bebas Neue', sans-serif;
    letter-spacing: 0.05em;
  }
  .msg-avatar.hidden { visibility: hidden; }

  /* ── Quick Replies ──────────────────────────────────── */
  .chat-quick-replies {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    padding: 0 16px 12px;
    flex-shrink: 0;
  }
  .quick-reply-btn {
    padding: 6px 13px;
    border: 1px solid rgba(255, 107, 0, 0.35);
    border-radius: 100px;
    background: rgba(255, 107, 0, 0.08);
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.78rem;
    cursor: pointer;
    transition: all 0.18s ease;
    font-family: 'Space Grotesk', sans-serif;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }
  .quick-reply-btn:hover {
    background: rgba(255, 107, 0, 0.85);
    border-color: transparent;
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(255, 107, 0, 0.3);
  }

  /* ── Input ─────────────────────────────────────────── */
  .chat-input-area {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px 14px;
    border-top: 1px solid rgba(255,255,255,0.05);
    background: rgba(0,0,0,0.25);
    flex-shrink: 0;
  }
  #chat-input {
    flex: 1;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    padding: 10px 16px;
    font-size: 0.875rem;
    color: #fff;
    font-family: 'Space Grotesk', sans-serif;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
  }
  #chat-input::placeholder { color: rgba(255,255,255,0.22); }
  #chat-input:focus {
    border-color: rgba(255, 107, 0, 0.5);
    background: rgba(255,255,255,0.08);
  }

  .chat-send {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff6b00, #ff9500);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, opacity 0.2s, box-shadow 0.2s;
    flex-shrink: 0;
    box-shadow: 0 4px 14px rgba(255, 107, 0, 0.35);
  }
  .chat-send:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(255, 107, 0, 0.5);
  }
  .chat-send:active { transform: scale(0.94); }
  .chat-send:disabled { opacity: 0.35; cursor: not-allowed; transform: none; box-shadow: none; }

  /* ── Footer label ────────────────────────────────── */
  .chat-footer-label {
    text-align: center;
    font-size: 0.67rem;
    color: rgba(255,255,255,0.18);
    padding: 0 16px 10px;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }
  .chat-footer-label strong { color: rgba(255,255,255,0.28); font-weight: 600; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var toggle   = document.getElementById('chat-toggle');
    var panel    = document.getElementById('chat-panel');
    var closeBtn = document.getElementById('chat-close');
    var form     = document.getElementById('chat-form');
    var input    = document.getElementById('chat-input');
    var msgs     = document.getElementById('chat-messages');
    var qrEl     = document.getElementById('chat-quick-replies');
    var badge    = document.getElementById('chat-badge');
    var iconOpen  = toggle.querySelector('.chat-icon-open');
    var iconClose = toggle.querySelector('.chat-icon-close');
    var sendBtn   = form.querySelector('.chat-send');

    var isOpen   = false;
    var isSending = false;
    var hasOpened = false;
    var history   = [];

    var _lang = document.documentElement.getAttribute('data-lang') || 'en';
    var _t    = (window.__TRANS && window.__TRANS[_lang]) || (window.__TRANS && window.__TRANS['en']) || {};
    var GREETING     = _t['chat.greeting'] || "Hey there! 👋 I'm Bot, your AI assistant at BotStudio.\n\nWhat brings you here today?";
    var QUICK_START  = [
      _t['chat.qr.1'] || 'I need a chatbot',
      _t['chat.qr.2'] || 'Website help',
      _t['chat.qr.3'] || 'Full automation',
      _t['chat.qr.4'] || 'Just browsing'
    ];

    /* ── Open / Close ─────────── */
    function toggleChat() {
      isOpen = !isOpen;
      panel.classList.toggle('open', isOpen);
      iconOpen.style.display  = isOpen ? 'none'  : 'block';
      iconClose.style.display = isOpen ? 'block' : 'none';
      badge.style.display = 'none';

      if (isOpen && !hasOpened) {
        hasOpened = true;
        addBot(GREETING);
        showQR(QUICK_START);
      }
      if (isOpen) setTimeout(function() { input.focus(); }, 300);
    }
    toggle.addEventListener('click', toggleChat);
    closeBtn.addEventListener('click', toggleChat);

    /* ── Add messages ─────────── */
    function addRow(role, content) {
      var row = document.createElement('div');
      row.className = 'msg-row ' + role;

      var av = document.createElement('div');
      av.className = 'msg-avatar' + (role === 'user' ? ' hidden' : '');
      av.textContent = role === 'bot' ? 'B' : '';

      var bubble = document.createElement('div');
      bubble.className = 'chat-msg ' + role;
      // Convert newlines to <br>
      bubble.innerHTML = content.replace(/\n/g, '<br>');

      if (role === 'bot') {
        row.appendChild(av);
        row.appendChild(bubble);
      } else {
        row.appendChild(bubble);
        row.appendChild(av);
      }
      msgs.appendChild(row);
      msgs.scrollTop = msgs.scrollHeight;
      return bubble;
    }

    function addBot(text) { history.push({ role: 'assistant', content: text }); addRow('bot', text); }
    function addUser(text){ history.push({ role: 'user',      content: text }); addRow('user', text); }

    function showTyping() {
      var row = document.createElement('div');
      row.className = 'msg-row bot';
      row.id = 'typing-row';

      var av = document.createElement('div');
      av.className = 'msg-avatar';
      av.textContent = 'B';

      var bubble = document.createElement('div');
      bubble.className = 'chat-msg typing';
      bubble.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';

      row.appendChild(av);
      row.appendChild(bubble);
      msgs.appendChild(row);
      msgs.scrollTop = msgs.scrollHeight;
    }
    function hideTyping() {
      var r = document.getElementById('typing-row');
      if (r) r.remove();
    }

    /* ── Quick replies ─────────── */
    function showQR(list) {
      qrEl.innerHTML = '';
      list.forEach(function(txt) {
        var btn = document.createElement('button');
        btn.className = 'quick-reply-btn';
        btn.textContent = txt;
        btn.addEventListener('click', function() { send(txt); });
        qrEl.appendChild(btn);
      });
    }
    function clearQR() { qrEl.innerHTML = ''; }

    /* ── Extract QR from AI response ── */
    function extractQR(text) {
      var res = [], pat = /[A-D][).]\s*([^\n,]+)/g, m;
      while ((m = pat.exec(text)) !== null) res.push(m[1].trim());
      return res;
    }

    /* ── Send ─────────────────── */
    function send(text) {
      text = text.trim();
      if (!text || isSending) return;
      isSending = true;
      sendBtn.disabled = true;
      addUser(text);
      clearQR();
      input.value = '';

      var apiMsgs = history.map(function(m) { return { role: m.role, content: m.content }; });

      showTyping();
      fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: apiMsgs })
      })
      .then(function(r) { if (!r.ok) throw new Error(r.status); return r.json(); })
      .then(function(d) {
        hideTyping();
        var reply = d.choices && d.choices[0] && d.choices[0].message
          ? d.choices[0].message.content
          : (d.error || "Sorry, something went wrong 😅");
        addBot(reply);
        var qr = extractQR(reply);
        if (qr.length) showQR(qr);
      })
      .catch(function() {
        hideTyping();
        addBot("Oops, couldn't reach the server 😅 Try again in a moment!");
      })
      .finally(function() {
        isSending = false;
        sendBtn.disabled = false;
        input.focus();
      });
    }

    form.addEventListener('submit', function(e) { e.preventDefault(); send(input.value); });

    /* Badge hint after 10s */
    setTimeout(function() {
      if (!hasOpened) { badge.style.display = 'flex'; }
    }, 10000);
  });
</script>

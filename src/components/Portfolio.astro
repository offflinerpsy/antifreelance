      { type: 'user', text: 'New York', time: '18:01' },
      { type: 'bot', text: 'The NYC show is October 25 at Club Base. 45 floor tickets left ($75) and 12 VIP ($150). Which ones?', time: '18:01', buttons: [[{text: '💃 Floor ($75)'}, {text: '👑 VIP ($150)'}]] },
      { type: 'user', text: 'Floor ($75)', time: '18:02' },
      { type: 'bot', text: 'Done! Total: $75. Pay via the link below. After payment, tickets will arrive right in this chat.', time: '18:02', buttons: [[{text: '💳 Pay $75', url: 'https://pay.example.com'}]] }

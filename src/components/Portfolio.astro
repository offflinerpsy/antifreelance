---
---
<section class="portfolio-section" id="portfolio">
  <div class="section-num reveal">03 — Портфолио</div>
  <h2 class="section-big-title reveal">Наши <span class="accent">работы</span></h2>
  
  <div class="portfolio-container">
    
    <!-- Case 1 -->
    <div class="portfolio-case">
      <div class="case-info reveal">
        <h3 class="case-title">AI-Бот для Салона Красоты</h3>
        <p class="case-desc">Полная автоматизация записи клиентов. Бот консультирует по услугам, подбирает свободное время, записывает в CRM и отправляет напоминания за сутки.</p>
        <div class="case-stats">
          <div class="stat-item">
            <span class="stat-val">+40%</span>
            <span class="stat-label">Конверсия в запись</span>
          </div>
          <div class="stat-item">
            <span class="stat-val">24/7</span>
            <span class="stat-label">Прием заявок</span>
          </div>
        </div>
      </div>
      
      <div class="case-visual reveal">
        <div class="device-frame phone-frame">
          <div class="device-notch"></div>
          <div class="device-screen">
            <!-- Контент, который будет скроллиться -->
            <div class="scroll-content" data-scroll-speed="1.5">
              <div class="placeholder-media">
                <div class="placeholder-text">
                  <span>Место для твоего скриншота/видео #1</span>
                  <small>(Подготовь вертикальное видео или длинный скриншот чата)</small>
                </div>
                <!-- Имитация длинного контента для демонстрации скролла -->
                <div class="mock-chat">
                  <div class="msg bot">Привет! Я AI-ассистент салона. Чем могу помочь?</div>
                  <div class="msg user">Хочу записаться на стрижку</div>
                  <div class="msg bot">Отлично! К какому мастеру?</div>
                  <div class="msg user">К Анне, на завтра</div>
                  <div class="msg bot">У Анны есть окна завтра в 12:00 и 15:30. Какое время удобнее?</div>
                  <div class="msg user">15:30</div>
                  <div class="msg bot">Записала вас к Анне на завтра в 15:30. Ждем вас!</div>
                  <div class="msg bot">За день до визита я пришлю напоминание.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Case 2 -->
    <div class="portfolio-case reverse">
      <div class="case-info reveal">
        <h3 class="case-title">Бот-поддержка для E-commerce</h3>
        <p class="case-desc">Интеллектуальный агент, обученный на базе знаний магазина (1000+ товаров). Отвечает на вопросы о наличии, размерах, доставке и возвратах.</p>
        <div class="case-stats">
          <div class="stat-item">
            <span class="stat-val">-60%</span>
            <span class="stat-label">Нагрузка на саппорт</span>
          </div>
          <div class="stat-item">
            <span class="stat-val">< 1 сек</span>
            <span class="stat-label">Время ответа</span>
          </div>
        </div>
      </div>
      
      <div class="case-visual reveal">
        <div class="device-frame phone-frame">
          <div class="device-notch"></div>
          <div class="device-screen">
            <div class="scroll-content" data-scroll-speed="1.5">
              <div class="placeholder-media bg-alt">
                <div class="placeholder-text">
                  <span>Место для твоего скриншота/видео #2</span>
                  <small>(Замени этот блок на тег &lt;video autoplay loop muted playsinline&gt;)</small>
                </div>
                <div class="mock-chat">
                  <div class="msg user">Где мой заказ #12345?</div>
                  <div class="msg bot">Секунду, проверяю... Ваш заказ передан в курьерскую службу СДЭК. Ожидаемая дата доставки: завтра до 18:00. Трек-номер: 123456789.</div>
                  <div class="msg user">А как оформить возврат?</div>
                  <div class="msg bot">Возврат можно оформить в течение 14 дней. Вам нужно заполнить форму по ссылке [ссылка] и отнести товар в ближайший пункт выдачи.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .portfolio-section {
    background: var(--black);
    padding: clamp(60px, 10vw, 100px) clamp(20px, 5vw, 40px);
    position: relative;
  }
  
  .portfolio-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(80px, 15vw, 150px);
    margin-top: clamp(40px, 8vw, 80px);
  }

  .portfolio-case {
    display: flex;
    align-items: center;
    gap: clamp(40px, 8vw, 80px);
    justify-content: space-between;
  }
  
  .portfolio-case.reverse {
    flex-direction: row-reverse;
  }

  .case-info {
    flex: 1;
    max-width: 500px;
  }

  .case-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 20px;
    color: var(--white);
    letter-spacing: 0.02em;
  }

  .case-desc {
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    margin-bottom: 32px;
  }

  .case-stats {
    display: flex;
    gap: 32px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    color: var(--lime);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .case-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  /* Device Frame (Phone) */
  .device-frame {
    width: 300px;
    height: 600px;
    background: #111;
    border-radius: 40px;
    border: 12px solid #222;
    position: relative;
    box-shadow: 
      0 20px 50px rgba(0,0,0,0.5),
      inset 0 0 0 2px rgba(255,255,255,0.1);
    overflow: hidden;
    transform: rotateY(-5deg) rotateX(5deg);
    transition: transform 0.5s ease;
  }
  
  .portfolio-case.reverse .device-frame {
    transform: rotateY(5deg) rotateX(5deg);
  }

  .device-frame:hover {
    transform: rotateY(0) rotateX(0) translateY(-10px);
  }

  .device-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 25px;
    background: #222;
    border-bottom-left-radius: 16px;
    border-bottom-right-radius: 16px;
    z-index: 10;
  }

  .device-screen {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
    position: relative;
    overflow: hidden; /* Скрываем всё, что выходит за пределы экрана */
  }

  .scroll-content {
    width: 100%;
    /* Высота больше экрана, чтобы было куда скроллить */
    height: 150%; 
    position: absolute;
    top: 0;
    left: 0;
    will-change: transform;
  }

  /* Placeholder Styles */
  .placeholder-media {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(255,94,0,0.1), rgba(221,245,22,0.1));
    display: flex;
    flex-direction: column;
    padding: 40px 20px;
  }
  
  .placeholder-media.bg-alt {
    background: linear-gradient(135deg, rgba(221,245,22,0.1), rgba(255,94,0,0.1));
  }

  .placeholder-text {
    text-align: center;
    margin-bottom: 40px;
    margin-top: 20px;
  }

  .placeholder-text span {
    display: block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    color: var(--white);
    margin-bottom: 8px;
  }

  .placeholder-text small {
    color: rgba(255,255,255,0.5);
    font-size: 0.8rem;
  }

  .mock-chat {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .msg {
    padding: 12px 16px;
    border-radius: 16px;
    font-size: 0.85rem;
    line-height: 1.4;
    max-width: 85%;
  }

  .msg.bot {
    background: rgba(255,255,255,0.1);
    color: var(--white);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }

  .msg.user {
    background: var(--orange);
    color: var(--white);
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }

  @media (max-width: 992px) {
    .portfolio-case, .portfolio-case.reverse {
      flex-direction: column;
      text-align: center;
      gap: 40px;
    }
    .case-stats {
      justify-content: center;
    }
    .device-frame {
      transform: none !important;
    }
  }
</style>

<script>
  // GSAP ScrollTrigger logic for Scroll-Linked Frames
  document.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      // @ts-ignore
      gsap.registerPlugin(ScrollTrigger);

      const cases = document.querySelectorAll('.portfolio-case');
      
      cases.forEach((caseEl) => {
        const scrollContent = caseEl.querySelector('.scroll-content');
        if (!scrollContent) return;

        // Анимируем контент внутри телефона при скролле секции
        // @ts-ignore
        gsap.to(scrollContent, {
          yPercent: -30, // Прокручиваем контент вверх на 30% от его высоты
          ease: "none",
          scrollTrigger: {
            trigger: caseEl,
            start: "top bottom", // Начинаем, когда верх секции достигает низа окна
            end: "bottom top",   // Заканчиваем, когда низ секции достигает верха окна
            scrub: 1             // Плавная привязка к скроллу (1 сек задержка для плавности)
          }
        });
      });
    }
  });
</script>

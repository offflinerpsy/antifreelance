    botName: 'Fitness AI',
    botStatus: 'bot',
    messages: [
      { type: 'bot', text: 'Good morning! Reminder: you have a yoga session at 7 PM today.', time: '09:00', buttons: [[{text: '✅ Confirm'}, {text: '❌ Cancel'}]] },
      { type: 'user', text: 'Cancel', time: '09:15' },
      { type: 'bot', text: 'No problem. Session canceled. Want to reschedule?', time: '09:15', buttons: [[{text: '📅 Weekly Schedule'}]] },
      { type: 'user', text: 'Weekly Schedule', time: '09:16' },
      { type: 'bot', text: 'Available slots this week:\n\nWednesday: 6 PM, 8 PM\nFriday: 10 AM, 7 PM\nSaturday: 12 PM', time: '09:16', buttons: [[{text: 'Wed 6 PM'}, {text: 'Wed 8 PM'}], [{text: 'Fri 7 PM'}]] }
    ]
  },
  {
    theme: 'green',
    botName: 'MedClinic Bot',
    botStatus: 'bot',
    messages: [
      { type: 'bot', text: 'Hello! I\'m the virtual assistant at HealthFirst Clinic.', time: '11:25', buttons: [[{text: '🩺 Book a Doctor'}, {text: '🧪 Lab Tests'}], [{text: '📄 Results'}, {text: '❓ Question'}]] },
      { type: 'user', text: 'Lab Tests', time: '11:30' },
      { type: 'bot', text: 'Which tests are you interested in?', time: '11:30', buttons: [[{text: '🩸 Complete Blood Count'}], [{text: '🧬 Biochemistry'}], [{text: '🦠 Hormones'}]] },
      { type: 'user', text: 'Complete Blood Count', time: '11:31' },
      { type: 'bot', text: 'Cost: $25.\nTurnaround: 1 day.\nAvailable daily 8 AM–11 AM, fasting required.', time: '11:31', buttons: [[{text: '💳 Pay Online'}, {text: '🏥 Clinic Locations'}]] }
    ]
  },
  {
    theme: 'purple',
    botName: 'Real Estate AI',
    botStatus: 'bot',
    messages: [
      { type: 'bot', text: 'Hi! I\'ll help you find your dream apartment. Where do we start?', time: '16:40', buttons: [[{text: '🏢 New Builds'}, {text: '🏠 Resale'}], [{text: '💰 Mortgage'}]] },
      { type: 'user', text: 'New Builds', time: '16:45' },
      { type: 'bot', text: 'Great! What\'s your budget range?', time: '16:45', buttons: [[{text: 'Under $200K'}, {text: '$200K–$400K'}], [{text: '$400K–$700K'}, {text: '$700K+'}]] },
      { type: 'user', text: '$200K–$400K', time: '16:46' },
      { type: 'bot', text: 'Found 12 matching developments in this budget. Want me to send a selection with floor plans?', time: '16:46', buttons: [[{text: '📥 Download PDF'}, {text: '👀 Browse In-Chat'}]] }
    ]

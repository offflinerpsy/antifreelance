---
import TelegramChat from './TelegramChat.astro';

const botCases = [
  {
    theme: 'dark',
    botName: 'BeautyBot',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Привет! Я AI-ассистент салона красоты. Чем могу помочь?', time: '10:00', buttons: [[{text: '💇‍♀️ Записаться'}, {text: '💰 Прайс-лист'}], [{text: '📍 Как добраться'}]] },
      { type: 'user', text: 'Прайс-лист', time: '10:01' },
      { type: 'bot', text: 'Наши основные услуги:\n\n✂️ Стрижка женская — от 2000₽\n💅 Маникюр с покрытием — от 1800₽\n💆‍♀️ Окрашивание — от 4500₽\n\nХотите записаться?', time: '10:01', buttons: [[{text: '📅 Выбрать время'}, {text: '👩‍🎨 Выбрать мастера'}]] },
      { type: 'user', text: 'Выбрать мастера', time: '10:02' },
      { type: 'bot', text: 'Выберите специалиста:', time: '10:02', buttons: [[{text: 'Анна (Топ-стилист)'}], [{text: 'Мария (Стилист)'}], [{text: 'Елена (Мастер маникюра)'}]] }
    ]
  },
  {
    theme: 'light',
    botName: 'E-com Support',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Добро пожаловать в магазин электроники! Выберите действие:', time: '14:15', buttons: [[{text: '📦 Мои заказы'}, {text: '🔍 Каталог'}], [{text: '🎧 Поддержка'}]] },
      { type: 'user', text: 'Мои заказы', time: '14:20' },
      { type: 'bot', text: 'У вас один активный заказ:\n\n📦 Заказ #12345\n📱 Смартфон iPhone 15 Pro\n🚚 Статус: В пути\n\nОжидаемая дата доставки: завтра до 18:00.', time: '14:20', buttons: [[{text: '📍 Отследить на карте'}], [{text: '❌ Отменить заказ'}, {text: '↩️ Возврат'}]] },
      { type: 'user', text: 'Возврат', time: '14:21' },
      { type: 'bot', text: 'Возврат можно оформить в течение 14 дней. Нажмите кнопку ниже, чтобы заполнить форму.', time: '14:21', buttons: [[{text: '📝 Форма возврата', url: 'https://example.com'}]] }
    ]
  },
  {
    theme: 'blue',
    botName: 'Fitness AI',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Доброе утро! Напоминаю, что сегодня в 19:00 у вас тренировка по йоге.', time: '09:00', buttons: [[{text: '✅ Подтверждаю'}, {text: '❌ Отменить'}]] },
      { type: 'user', text: 'Отменить', time: '09:15' },
      { type: 'bot', text: 'Без проблем. Тренировка отменена. Хотите записаться на другой день?', time: '09:15', buttons: [[{text: '📅 Расписание на неделю'}]] },
      { type: 'user', text: 'Расписание на неделю', time: '09:16' },
      { type: 'bot', text: 'Свободные окна на этой неделе:\n\nСреда: 18:00, 20:00\nПятница: 10:00, 19:00\nСуббота: 12:00', time: '09:16', buttons: [[{text: 'Среда 18:00'}, {text: 'Среда 20:00'}], [{text: 'Пятница 19:00'}]] }
    ]
  },
  {
    theme: 'green',
    botName: 'MedClinic Bot',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Здравствуйте! Я виртуальный помощник клиники "Здоровье".', time: '11:25', buttons: [[{text: '🩺 Запись к врачу'}, {text: '🧪 Анализы'}], [{text: '📄 Результаты'}, {text: '❓ Вопрос'}]] },
      { type: 'user', text: 'Анализы', time: '11:30' },
      { type: 'bot', text: 'Какие именно анализы вас интересуют?', time: '11:30', buttons: [[{text: '🩸 Общий анализ крови'}], [{text: '🧬 Биохимия'}], [{text: '🦠 Гормоны'}]] },
      { type: 'user', text: 'Общий анализ крови', time: '11:31' },
      { type: 'bot', text: 'Стоимость: 800₽.\nСрок готовности: 1 день.\nСдать можно ежедневно с 8:00 до 11:00 натощак.', time: '11:31', buttons: [[{text: '💳 Оплатить онлайн'}, {text: '🏥 Адреса клиник'}]] }
    ]
  },
  {
    theme: 'purple',
    botName: 'Real Estate AI',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Привет! Я помогу подобрать квартиру мечты. С чего начнем?', time: '16:40', buttons: [[{text: '🏢 Новостройки'}, {text: '🏠 Вторичка'}], [{text: '💰 Ипотека'}]] },
      { type: 'user', text: 'Новостройки', time: '16:45' },
      { type: 'bot', text: 'Отлично! Какой бюджет рассматриваем?', time: '16:45', buttons: [[{text: 'До 10 млн'}, {text: '10-15 млн'}], [{text: '15-25 млн'}, {text: 'От 25 млн'}]] },
      { type: 'user', text: '10-15 млн', time: '16:46' },
      { type: 'bot', text: 'Нашел 12 подходящих ЖК в этом бюджете. Отправить подборку с планировками?', time: '16:46', buttons: [[{text: '📥 Скачать PDF'}, {text: '👀 Посмотреть в боте'}]] }
    ]
  },
  {
    theme: 'dark',
    botName: 'AutoService Bot',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Автосервис "Drive". Выберите нужную услугу:', time: '12:05', buttons: [[{text: '🔧 ТО и ремонт'}, {text: '🚗 Шиномонтаж'}], [{text: '🧼 Мойка'}, {text: '📞 Связь с мастером'}]] },
      { type: 'user', text: 'ТО и ремонт', time: '12:10' },
      { type: 'bot', text: 'Что именно нужно сделать?', time: '12:10', buttons: [[{text: '🛢 Замена масла'}, {text: '🛑 Колодки'}], [{text: '⚙️ Диагностика ходовой'}]] },
      { type: 'user', text: 'Замена масла', time: '12:11' },
      { type: 'bot', text: 'Замена масла стоит от 800₽ (работа). Масло и фильтры можно купить у нас или привезти свои. Записать вас?', time: '12:11', buttons: [[{text: '📅 Выбрать дату'}]] }
    ]
  },
  {
    theme: 'light',
    botName: 'Delivery Tracker',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Ваш заказ #9988 собран и передан курьеру. Ожидайте доставку сегодня с 14:00 до 16:00.', time: '13:00', buttons: [[{text: '📍 Где курьер?'}, {text: '📞 Позвонить курьеру'}], [{text: '✏️ Изменить адрес'}]] },
      { type: 'user', text: 'Изменить адрес', time: '13:05' },
      { type: 'bot', text: 'Напишите новый адрес прямо сюда, и я передам его курьеру.', time: '13:05' },
      { type: 'user', text: 'ул. Ленина 15, кв 44', time: '13:06' },
      { type: 'bot', text: 'Адрес успешно изменен! Курьер предупрежден.', time: '13:06', buttons: [[{text: '👍 Спасибо'}]] }
    ]
  },
  {
    theme: 'blue',
    botName: 'HR Assistant',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Привет! Я HR-бот компании. Вижу, ты откликнулся на вакансию "Менеджер по продажам". Готов пройти небольшое интервью?', time: '10:00', buttons: [[{text: '🚀 Начать интервью'}, {text: '⏰ Позже'}]] },
      { type: 'user', text: 'Начать интервью', time: '10:05' },
      { type: 'bot', text: 'Отлично! Первый вопрос: какой у тебя опыт в B2B продажах?', time: '10:05', buttons: [[{text: 'Менее 1 года'}, {text: '1-3 года'}], [{text: 'Более 3 лет'}]] },
      { type: 'user', text: '1-3 года', time: '10:06' },
      { type: 'bot', text: 'Супер. А какой был средний чек?', time: '10:06', buttons: [[{text: 'До 100 тыс.'}, {text: '100-500 тыс.'}], [{text: 'Более 500 тыс.'}]] }
    ]
  },
  {
    theme: 'green',
    botName: 'EcoShop Bot',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Добро пожаловать в эко-маркет! Что ищете?', time: '15:15', buttons: [[{text: '🌿 Косметика'}, {text: '🏠 Для дома'}], [{text: '♻️ Zero Waste'}]] },
      { type: 'user', text: 'Zero Waste', time: '15:20' },
      { type: 'bot', text: 'В категории Zero Waste популярны бамбуковые зубные щетки. В наличии 3 вида: мягкие, средние и жесткие. Цена от 150₽.', time: '15:20', buttons: [[{text: '🛒 Добавить в корзину'}, {text: '👀 Посмотреть фото'}]] },
      { type: 'user', text: 'Посмотреть фото', time: '15:21' },
      { type: 'bot', text: 'Отправляю каталог... [Файл: brushes.pdf]. Для заказа просто нажмите кнопку.', time: '15:21', buttons: [[{text: '🛍 Оформить заказ'}]] }
    ]
  },
  {
    theme: 'purple',
    botName: 'Event Ticket Bot',
    botStatus: 'бот',
    messages: [
      { type: 'bot', text: 'Привет! Я помогу купить билеты на концерт. Какой город?', time: '18:00', buttons: [[{text: 'Москва'}, {text: 'Санкт-Петербург'}], [{text: 'Казань'}, {text: 'Екатеринбург'}]] },
      { type: 'user', text: 'Москва', time: '18:01' },
      { type: 'bot', text: 'В Москве концерт пройдет 25 октября в клубе Base. Осталось 45 билетов на танцпол (2500₽) и 12 VIP (5000₽). Какие берем?', time: '18:01', buttons: [[{text: '💃 Танцпол (2500₽)'}, {text: '👑 VIP (5000₽)'}]] },
      { type: 'user', text: 'Танцпол (2500₽)', time: '18:02' },
      { type: 'bot', text: 'Отлично. Итого 2500₽. Оплатить можно по ссылке ниже. После оплаты билеты придут прямо в этот чат.', time: '18:02', buttons: [[{text: '💳 Оплатить 2500₽', url: 'https://pay.example.com'}]] }
    ]
  }
];
---
<section class="portfolio-section" id="portfolio">
  <div class="section-num reveal">03 — Портфолио</div>
  <h2 class="section-big-title reveal">Наши <span class="accent">работы</span></h2>
  
  <div class="portfolio-container">
    
    <!-- Telegram Bots Slider -->
    <div class="portfolio-case">
      <div class="case-info reveal">
        <h3 class="case-title">AI-Боты для бизнеса</h3>
        <p class="case-desc">Листайте вправо, чтобы посмотреть примеры интерфейсов и сценариев работы наших ботов в Telegram. Мы создаем решения под любой дизайн и логику.</p>
        <div class="case-stats">
          <div class="stat-item">
            <span class="stat-val">50+</span>
            <span class="stat-label">Реализованных ботов</span>
          </div>
          <div class="stat-item">
            <span class="stat-val">100%</span>
            <span class="stat-label">Кастомизация</span>
          </div>
        </div>
        
        <div class="slider-controls">
          <button class="slider-btn prev-btn" aria-label="Назад">←</button>
          <button class="slider-btn next-btn" aria-label="Вперед">→</button>
        </div>
      </div>
      
      <div class="case-visual reveal">
        <div class="device-frame phone-frame">
          <div class="device-notch"></div>
          <div class="device-screen">
            
            <!-- Slider Container -->
            <div class="phone-slider">
              {botCases.map((bot) => (
                <div class="phone-slide">
                  <TelegramChat 
                    theme={bot.theme as any} 
                    botName={bot.botName} 
                    botStatus={bot.botStatus} 
                    messages={bot.messages as any} 
                  />
                </div>
              ))}
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- Web Development Grid -->
    <div class="portfolio-case reverse web-dev-case">
      <div class="case-info reveal">
        <h3 class="case-title">Веб-разработка</h3>
        <p class="case-desc">Помимо ботов, мы создаем современные, быстрые и конверсионные веб-сайты. От лендингов до сложных корпоративных порталов.</p>
        <div class="case-stats">
          <div class="stat-item">
            <span class="stat-val">15+</span>
            <span class="stat-label">Лет опыта</span>
          </div>
          <div class="stat-item">
            <span class="stat-val">Astro</span>
            <span class="stat-label">Современный стек</span>
          </div>
        </div>
      </div>
      
      <div class="case-visual reveal web-visual">
        <div class="web-grid">
          <div class="web-item">
            <img src="/assets/web/D1_Website_Home_Page-1.jpg" alt="Web Project 1" loading="lazy" />
          </div>
          <div class="web-item">
            <img src="/assets/web/D1_Website_Home_Page-2.jpg" alt="Web Project 2" loading="lazy" />
          </div>
          <div class="web-item">
            <img src="/assets/web/D1_Website_Home_Page-3.jpg" alt="Web Project 3" loading="lazy" />
          </div>
          <div class="web-item">
            <img src="/assets/web/Home (4).png" alt="Web Project 4" loading="lazy" />
          </div>
          <div class="web-item">
            <img src="/assets/web/home_pk.png" alt="Web Project 5" loading="lazy" />
          </div>
          <div class="web-item">
            <img src="/assets/web/image_2024-03-04_10-56-29.png" alt="Web Project 6" loading="lazy" />
          </div>
        </div>
      </div>
    </div>

    <!-- Upwork Grid -->
    <div class="portfolio-case upwork-case">
      <div class="case-info reveal">
        <h3 class="case-title">Upwork <span class="accent">Top Rated</span></h3>
        <p class="case-desc">Успешный опыт работы на международной фриланс-бирже Upwork. Десятки довольных клиентов со всего мира, 100% Job Success Score и статус Top Rated.</p>
        <div class="case-stats">
          <div class="stat-item">
            <span class="stat-val">100%</span>
            <span class="stat-label">Job Success</span>
          </div>
          <div class="stat-item">
            <span class="stat-val">Top</span>
            <span class="stat-label">Rated</span>
          </div>
        </div>
      </div>
      
      <div class="case-visual reveal web-visual">
        <div class="web-grid upwork-grid">
          <div class="web-item">
            <img src="/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (1).png" alt="Upwork Review 1" loading="lazy" />
          </div>
          <div class="web-item">
            <img src="/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (2).png" alt="Upwork Review 2" loading="lazy" />
          </div>
          <div class="web-item">
            <img src="/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (3).png" alt="Upwork Review 3" loading="lazy" />
          </div>
          <div class="web-item">
            <img src="/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (4).png" alt="Upwork Review 4" loading="lazy" />
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .portfolio-section {
    background: var(--black);
    padding: clamp(60px, 10vw, 100px) clamp(20px, 5vw, 40px);
    position: relative;
  }
  
  .portfolio-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(80px, 15vw, 150px);
    margin-top: clamp(40px, 8vw, 80px);
  }

  .portfolio-case {
    display: flex;
    align-items: center;
    gap: clamp(40px, 8vw, 80px);
    justify-content: space-between;
  }
  
  .portfolio-case.reverse {
    flex-direction: row-reverse;
  }

  .case-info {
    flex: 1;
    max-width: 500px;
  }

  .case-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 20px;
    color: var(--white);
    letter-spacing: 0.02em;
  }

  .case-desc {
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    margin-bottom: 32px;
  }

  .case-stats {
    display: flex;
    gap: 32px;
    margin-bottom: 32px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    color: var(--lime);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Slider Controls */
  .slider-controls {
    display: flex;
    gap: 16px;
  }
  .slider-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: transparent;
    color: var(--white);
    font-size: 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .slider-btn:hover {
    background: var(--orange);
    border-color: var(--orange);
  }

  .case-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  /* Device Frame (Phone) */
  .device-frame {
    width: 300px;
    height: 600px;
    background: #111;
    border-radius: 40px;
    border: 12px solid #222;
    position: relative;
    box-shadow: 
      0 20px 50px rgba(0,0,0,0.5),
      inset 0 0 0 2px rgba(255,255,255,0.1);
    overflow: hidden;
    transform: rotateY(-5deg) rotateX(5deg);
    transition: transform 0.5s ease;
  }
  
  .device-frame:hover {
    transform: rotateY(0) rotateX(0) translateY(-10px);
  }

  .device-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 25px;
    background: #222;
    border-bottom-left-radius: 16px;
    border-bottom-right-radius: 16px;
    z-index: 100;
  }

  .device-screen {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
    position: relative;
    overflow: hidden;
  }

  /* Phone Slider */
  .phone-slider {
    display: flex;
    width: 100%;
    height: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
    scroll-behavior: smooth;
  }
  .phone-slider::-webkit-scrollbar {
    display: none;
  }
  .phone-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
  }

  /* Web Dev Grid */
  .web-visual {
    width: 100%;
  }
  .web-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    width: 100%;
  }
  .upwork-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .web-item {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
    transition: transform 0.3s ease, border-color 0.3s ease;
    aspect-ratio: 16/9;
  }
  .web-item:first-child {
    grid-column: span 2;
    aspect-ratio: 21/9;
  }
  .upwork-grid .web-item {
    aspect-ratio: auto;
  }
  .upwork-grid .web-item:first-child {
    grid-column: span 1;
    aspect-ratio: auto;
  }
  .web-item:hover {
    transform: translateY(-5px) scale(1.02);
    border-color: var(--orange);
    z-index: 2;
  }
  .web-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  @media (max-width: 992px) {
    .portfolio-case, .portfolio-case.reverse {
      flex-direction: column;
      text-align: center;
      gap: 40px;
    }
    .case-stats {
      justify-content: center;
    }
    .slider-controls {
      justify-content: center;
    }
    .device-frame {
      transform: none !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.querySelector('.phone-slider');
    const prevBtn = document.querySelector('.prev-btn');
    const nextBtn = document.querySelector('.next-btn');

    if (slider && prevBtn && nextBtn) {
      const slideWidth = slider.clientWidth;

      nextBtn.addEventListener('click', () => {
        slider.scrollBy({ left: slideWidth, behavior: 'smooth' });
      });

      prevBtn.addEventListener('click', () => {
        slider.scrollBy({ left: -slideWidth, behavior: 'smooth' });
      });
    }
  });
</script>

---
<section class="portfolio-section" id="portfolio">
  <!-- RU: 03 — Портфолио / Наши работы -->
  <div class="section-num reveal">03 — Portfolio</div>
  <h2 class="section-big-title reveal">Our <span class="accent">Work</span></h2>
  
  <div class="portfolio-container">
    
    <!-- Telegram Bots Slider -->
    <div class="portfolio-case">
      <div class="case-info reveal">
        <!-- RU: AI-Боты для бизнеса -->
        <h3 class="case-title">AI Bots for Business</h3>
        <!-- RU: Листайте вправо, чтобы посмотреть примеры интерфейсов и сценариев работы наших ботов в Telegram. Мы создаем решения под любой дизайн и логику. -->
        <p class="case-desc">Swipe right to browse interface demos and conversation flows of our Telegram bots. We build custom solutions for any design and logic.</p>
        <div class="case-stats">
          <div class="stat-item">
            <span class="stat-val">50+</span>
            <!-- RU: Реализованных ботов -->
            <span class="stat-label">Bots Delivered</span>
          </div>
          <div class="stat-item">
            <span class="stat-val">100%</span>
            <!-- RU: Кастомизация -->
            <span class="stat-label">Customization</span>
          </div>
        </div>
        
        <div class="slider-controls">
          <!-- RU: Назад / Вперед -->
          <button class="slider-btn prev-btn" aria-label="Previous">←</button>
          <button class="slider-btn next-btn" aria-label="Next">→</button>
        </div>
      </div>
      
      <div class="case-visual reveal">
        <div class="device-frame phone-frame">
          <div class="device-notch"></div>
          <div class="device-screen">
            
            <!-- Slider Container -->
            <div class="phone-slider">
              {botCases.map((bot) => (
                <div class="phone-slide">
                  <TelegramChat 
                    theme={bot.theme as any} 
                    botName={bot.botName} 
                    botStatus={bot.botStatus} 
                    messages={bot.messages as any} 
                  />
                </div>
              ))}
            </div>

          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .portfolio-section {
    background: var(--black);
    padding: clamp(60px, 10vw, 100px) clamp(20px, 5vw, 40px);
    position: relative;
  }
  
  .portfolio-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: clamp(80px, 15vw, 150px);
    margin-top: clamp(40px, 8vw, 80px);
  }

  .portfolio-case {
    display: flex;
    align-items: center;
    gap: clamp(40px, 8vw, 80px);
    justify-content: space-between;
  }
  
  .portfolio-case.reverse {
    flex-direction: row-reverse;
  }

  .case-info {
    flex: 1;
    max-width: 500px;
  }

  .case-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 20px;
    color: var(--white);
    letter-spacing: 0.02em;
  }

  .case-desc {
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    margin-bottom: 32px;
  }

  .case-stats {
    display: flex;
    gap: 32px;
    margin-bottom: 32px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.5rem;
    color: var(--lime);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Slider Controls */
  .slider-controls {
    display: flex;
    gap: 16px;
  }
  .slider-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: transparent;
    color: var(--white);
    font-size: 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .slider-btn:hover {
    background: var(--orange);
    border-color: var(--orange);
  }

  .case-visual {
    flex: 1;
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  /* Device Frame (Phone) */
  .device-frame {
    width: 300px;
    height: 600px;
    background: #111;
    border-radius: 40px;
    border: 12px solid #222;
    position: relative;
    box-shadow: 
      0 20px 50px rgba(0,0,0,0.5),
      inset 0 0 0 2px rgba(255,255,255,0.1);
    overflow: hidden;
    transform: rotateY(-5deg) rotateX(5deg);
    transition: transform 0.5s ease;
  }
  
  .device-frame:hover {
    transform: rotateY(0) rotateX(0) translateY(-10px);
  }

  .device-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 25px;
    background: #222;
    border-bottom-left-radius: 16px;
    border-bottom-right-radius: 16px;
    z-index: 100;
  }

  .device-screen {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
    position: relative;
    overflow: hidden;
  }

  /* Phone Slider */
  .phone-slider {
    display: flex;
    width: 100%;
    height: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
    scroll-behavior: smooth;
  }
  .phone-slider::-webkit-scrollbar {
    display: none;
  }
  .phone-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    scroll-snap-align: start;
  }

  @media (max-width: 992px) {
    .portfolio-case, .portfolio-case.reverse {
      flex-direction: column;
      text-align: center;
      gap: 40px;
    }
    .case-stats {
      justify-content: center;
    }
    .slider-controls {
      justify-content: center;
    }
    .device-frame {
      transform: none !important;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.querySelector('.phone-slider');
    const prevBtn = document.querySelector('.prev-btn');
    const nextBtn = document.querySelector('.next-btn');

    if (slider && prevBtn && nextBtn) {
      const slideWidth = slider.clientWidth;

      nextBtn.addEventListener('click', () => {
        slider.scrollBy({ left: slideWidth, behavior: 'smooth' });
      });

      prevBtn.addEventListener('click', () => {
        slider.scrollBy({ left: -slideWidth, behavior: 'smooth' });
      });
    }
  });
</script>

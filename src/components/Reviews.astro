---
/*
  RU: Original review names/texts:
  Алексей, Автосервис | Мария, Салон красоты | Игорь, Барбершоп | Елена, Ресторан | Дмитрий, Фитнес-клуб
  Ольга, Мед. клиника | Сергей, Недвижимость | Анна, Доставка цветов | Виктор, СТО | Наталья, Кофейня
*/
const reviews = [
  { name: "Jake, Auto Repair Shop", text: "Built our bot in 3 days. Now clients book at night while we sleep. Conversions up 30%!" },
  { name: "Sarah, Beauty Salon", text: "Our admin couldn't keep up with Instagram DMs. The bot now handles 80% of the routine." },
  { name: "Mike, Barbershop", text: "A perfect replacement for a manager. The bot reminds clients about haircuts after a month. Repeat visits up 45%." },
  { name: "Jessica, Restaurant", text: "Table reservations are now fully automated. No more mix-ups or double bookings." },
  { name: "Brandon, Fitness Club", text: "Members renew subscriptions through the bot themselves. Revenue up, call center costs down." },
  { name: "Emily, Medical Clinic", text: "The bot collects initial medical history before appointments. Doctors love it — saves tons of time." },
  { name: "Ryan, Real Estate", text: "The AI qualifies leads better than junior agents. Only passes hot prospects to brokers." },
  { name: "Ashley, Flower Delivery", text: "During holidays, the bot saved us from total chaos. Processed 500+ orders in a day without a single error." },
  { name: "David, Auto Service", text: "CRM integration runs like clockwork. Every inquiry lands straight in the pipeline." },
  { name: "Lauren, Coffee Shop", text: "Launched coffee pre-orders through the bot. Morning lines vanished, revenue went up." }
];

// Split into two rows for marquee
const row1 = reviews.slice(0, 5);
const row2 = reviews.slice(5, 10);
---
<section class="reviews-section" id="reviews">
  <!-- RU: 03 — Отзывы / Что говорят клиенты -->
  <div class="section-num reveal" data-i18n="rev.label">03 — Reviews</div>
  <h2 class="section-big-title reveal" data-i18n-html="rev.h2">What Our<br><span class="accent">Clients Say</span></h2>
  
  <div class="marquee-container reveal">
    <div class="marquee-track track-left">
      {[...row1, ...row1].map((r) => (
        <div class="review-card">
          <div class="r-stars">★★★★★</div>
          <p class="r-text">"{r.text}"</p>
          <div class="r-author">— {r.name}</div>
        </div>
      ))}
    </div>
    
    <div class="marquee-track track-right">
      {[...row2, ...row2].map((r) => (
        <div class="review-card">
          <div class="r-stars">★★★★★</div>
          <p class="r-text">"{r.text}"</p>
          <div class="r-author">— {r.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews-section {
    background: var(--white);
    color: var(--black);
    padding: clamp(60px, 10vw, 100px) 0;
    overflow: hidden;
  }
  .reviews-section .section-num,
  .reviews-section .section-big-title {
    padding: 0 clamp(20px, 5vw, 40px);
  }
  .reviews-section .section-num { color: var(--orange); }
  .reviews-section .section-big-title { color: var(--black); }
  .reviews-section .section-big-title .accent { color: var(--orange); }

  .marquee-container {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 3vw, 24px);
    margin-top: clamp(40px, 8vw, 60px);
  }
  
  .marquee-track {
    display: flex;
    gap: clamp(16px, 3vw, 24px);
    width: max-content;
  }
  
  .track-left {
    animation: scrollLeft 40s linear infinite;
  }
  .track-right {
    animation: scrollRight 40s linear infinite;
    transform: translateX(-50%);
  }
  
  @keyframes scrollLeft {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @keyframes scrollRight {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }

  .review-card {
    background: var(--black);
    color: var(--white);
    padding: clamp(24px, 4vw, 32px);
    border-radius: 20px;
    width: clamp(280px, 80vw, 400px);
    flex-shrink: 0;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .r-stars {
    color: var(--lime);
    font-size: clamp(1rem, 2vw, 1.2rem);
    margin-bottom: 16px;
    letter-spacing: 2px;
  }
  .r-text {
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    line-height: 1.6;
    margin-bottom: 24px;
    opacity: 0.9;
  }
  .r-author {
    font-size: clamp(0.75rem, 1.2vw, 0.85rem);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .track-left { animation-duration: 30s; }
    .track-right { animation-duration: 30s; }
  }
</style>
---
// Pricing — 3 tiers: Starter $499 / Growth $999 (popular) / Dominate $1,999
---

<section class="pricing" id="pricing">
  <div class="container">
    <div class="pricing__header reveal">
      <p class="section-tag" data-i18n="geo.price.tag">Pricing</p>
      <h2 class="pricing__headline" data-i18n-html="geo.price.h2">Invest in AI visibility.<br><span class="accent">See results in 30 days.</span></h2>
      <p class="pricing__sub" data-i18n="geo.price.sub">Other agencies charge $3,000-$12,000/month. We deliver better results for a fraction of the cost.</p>
      <p class="pricing__compare reveal" data-i18n-html="geo.price.compare">Average competitor price: <strong>$6,500/mo</strong> — you save up to <strong>92%</strong></p>
    </div>

    <div class="pricing__grid">
      <!-- Starter -->
      <div class="plan reveal">
        <div class="plan-name" data-i18n="geo.price.t1name">Starter</div>
        <div class="plan-price">$499 <span>/mo</span></div>
        <p class="plan-desc" data-i18n="geo.price.t1desc">Get on AI's radar. Perfect for single-location businesses.</p>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li data-i18n="geo.price.t1f1">AI visibility audit (5 platforms)</li>
          <li data-i18n="geo.price.t1f2">4 GEO-optimized articles/month</li>
          <li data-i18n="geo.price.t1f3">Schema markup + llms.txt setup</li>
          <li data-i18n="geo.price.t1f4">5 review templates/month</li>
          <li data-i18n="geo.price.t1f5">Monthly AI visibility report</li>
          <li data-i18n="geo.price.t1f6">Email support</li>
        </ul>
        <div class="plan-cta"><a href="#contact" class="btn-outline" data-i18n="geo.price.t1cta">Get Started</a></div>
      </div>

      <!-- Growth (Featured) -->
      <div class="plan featured reveal">
        <div class="plan-badge" data-i18n="geo.price.badge">Most Popular</div>
        <div class="plan-name" data-i18n="geo.price.t2name">Growth</div>
        <div class="plan-price">$999 <span>/mo</span></div>
        <p class="plan-desc" data-i18n="geo.price.t2desc">Dominate AI recommendations in your city. Our most popular plan.</p>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li data-i18n="geo.price.t2f1">Everything in Starter, plus:</li>
          <li data-i18n="geo.price.t2f2">8 GEO articles + content optimization</li>
          <li data-i18n="geo.price.t2f3">15 review templates + email/SMS automation</li>
          <li data-i18n="geo.price.t2f4">Citation building (20+ platforms)</li>
          <li data-i18n="geo.price.t2f5">Weekly competitor tracking</li>
          <li data-i18n="geo.price.t2f6">Strategy calls (30 min/month)</li>
          <li data-i18n="geo.price.t2f7">Priority support</li>
        </ul>
        <div class="plan-cta"><a href="#contact" class="btn-primary" data-i18n="geo.price.t2cta">Start Growing →</a></div>
      </div>

      <!-- Dominate -->
      <div class="plan reveal">
        <div class="plan-name" data-i18n="geo.price.t3name">Dominate</div>
        <div class="plan-price">$1,999 <span>/mo</span></div>
        <p class="plan-desc" data-i18n="geo.price.t3desc">For multi-location businesses and franchises that want total AI dominance.</p>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          <li data-i18n="geo.price.t3f1">Everything in Growth, plus:</li>
          <li data-i18n="geo.price.t3f2">Up to 5 locations optimized</li>
          <li data-i18n="geo.price.t3f3">Unlimited review templates</li>
          <li data-i18n="geo.price.t3f4">Wikipedia/Wikidata optimization</li>
          <li data-i18n="geo.price.t3f5">Digital PR placements</li>
          <li data-i18n="geo.price.t3f6">Dedicated GEO strategist</li>
          <li data-i18n="geo.price.t3f7">Bi-weekly strategy calls</li>
          <li data-i18n="geo.price.t3f8">A/B content testing</li>
        </ul>
        <div class="plan-cta"><a href="#contact" class="btn-outline" data-i18n="geo.price.t3cta">Talk to Expert</a></div>
      </div>
    </div>

    <p class="pricing__guarantee reveal" data-i18n-html="geo.price.guarantee"><strong>90-day results guarantee.</strong> If you don't see AI mentions within 90 days, we keep working for free until you do.</p>
  </div>
</section>

<style>
  .pricing {
    background: var(--color-surface-2);
    padding: var(--section-padding) 20px;
  }
  .container { max-width: var(--container-max); margin: 0 auto; }
  .section-tag {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .pricing__header { text-align: center; }
  .pricing__headline {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }
  .accent { color: var(--color-accent); }
  .pricing__sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--leading-normal);
  }
  .pricing__compare {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-3);
  }
  .pricing__compare :global(strong) { color: var(--color-primary); font-weight: 700; }

  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: var(--space-12);
    max-width: 1060px;
    margin-left: auto;
    margin-right: auto;
  }

  .plan {
    padding: var(--space-10) var(--space-8);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-surface-4);
    background: var(--color-surface);
    position: relative;
    transition: transform var(--duration-base) var(--ease-spring), box-shadow var(--duration-base);
  }
  .plan:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .plan.featured {
    border-color: var(--color-primary);
    box-shadow: 0 8px 40px rgba(255, 94, 0, 0.12);
    transform: scale(1.03);
  }
  .plan.featured:hover { transform: scale(1.03) translateY(-3px); }

  .plan-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    padding: 5px 16px;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .plan-name {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }
  .plan.featured .plan-name { color: var(--color-primary); }
  .plan-price {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4vw, 2.75rem);
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .plan-price span { font-size: var(--text-base); font-weight: 500; color: var(--color-text-muted); }
  .plan-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    line-height: 1.5;
  }
  .plan-divider { height: 1px; background: var(--color-surface-4); margin-bottom: var(--space-5); }
  .plan-features { list-style: none; padding: 0; }
  .plan-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: 7px 0;
    line-height: 1.45;
  }
  .plan-features li::before {
    content: '✓';
    color: var(--color-primary);
    font-weight: 700;
    font-size: var(--text-sm);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .plan.featured .plan-features li::before { color: var(--color-accent); }

  .plan-cta { margin-top: var(--space-8); }
  .plan-cta a { display: block; text-align: center; padding: 13px; }

  .pricing__guarantee {
    text-align: center;
    margin-top: var(--space-10);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .pricing__guarantee :global(strong) { color: var(--color-text); }

  @media (max-width: 900px) {
    .pricing__grid { grid-template-columns: 1fr; max-width: 420px; }
    .plan.featured { transform: none; }
    .plan.featured:hover { transform: translateY(-3px); }
  }
</style>

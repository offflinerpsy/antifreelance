---
// Evidence — "The numbers don't lie. Neither do the results."
// 3 big counter stats + 4 metric pills
---

<section class="evidence" id="evidence">
  <div class="evidence__bg"></div>
  <div class="container">
    <div class="evidence__header reveal">
      <p class="section-tag" data-i18n="geo.ev.tag">The Evidence</p>
      <h2 class="evidence__headline" data-i18n-html="geo.ev.h2">The numbers don't lie.<br><span class="accent">Neither do the results.</span></h2>
      <p class="evidence__sub" data-i18n="geo.ev.sub">We scanned 500+ local businesses. Here's what we found — and what we fix.</p>
    </div>

    <div class="evidence__stats reveal">
      <div class="evidence__stat">
        <div class="stat-num">78%</div>
        <div class="stat-label" data-i18n="geo.ev.s1label">Zero AI visibility</div>
        <div class="stat-desc" data-i18n="geo.ev.s1desc">Most businesses are completely invisible to AI assistants</div>
      </div>
      <div class="evidence__stat">
        <div class="stat-num">3%</div>
        <div class="stat-label" data-i18n="geo.ev.s2label">Have llms.txt</div>
        <div class="stat-desc" data-i18n="geo.ev.s2desc">Almost nobody is optimized for AI crawlers</div>
      </div>
      <div class="evidence__stat">
        <div class="stat-num">4.4x</div>
        <div class="stat-label" data-i18n="geo.ev.s3label">Purchase intent</div>
        <div class="stat-desc" data-i18n="geo.ev.s3desc">AI referrals convert 4.4x better than paid ads</div>
      </div>
    </div>

    <div class="evidence__pills reveal">
      <div class="evidence__pill">
        <div class="pill-val">7+</div>
        <div class="pill-label" data-i18n="geo.ev.p1">AI platforms we optimize</div>
      </div>
      <div class="evidence__pill">
        <div class="pill-val">30 days</div>
        <div class="pill-label" data-i18n="geo.ev.p2">to first AI mentions</div>
      </div>
      <div class="evidence__pill">
        <div class="pill-val">$0</div>
        <div class="pill-label" data-i18n="geo.ev.p3">per AI referral</div>
      </div>
      <div class="evidence__pill">
        <div class="pill-val">3-6x</div>
        <div class="pill-label" data-i18n="geo.ev.p4">cheaper than agencies</div>
      </div>
    </div>
  </div>
</section>

<style>
  .evidence {
    position: relative;
    overflow: hidden;
    padding: var(--section-padding) 20px;
  }
  .evidence__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, #FF7A2E 50%, var(--color-accent) 100%);
    opacity: 0.15;
  }
  .container { max-width: var(--container-max); margin: 0 auto; position: relative; z-index: 1; }

  .section-tag {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .evidence__header { text-align: center; }
  .evidence__headline {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }
  .accent { color: var(--color-accent); }
  .evidence__sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--leading-normal);
  }

  .evidence__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: var(--space-14);
    margin-bottom: var(--space-12);
  }
  .evidence__stat {
    text-align: center;
    padding: var(--space-12) var(--space-6);
    position: relative;
  }
  .evidence__stat:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 20%;
    bottom: 20%;
    width: 1px;
    background: var(--color-surface-4);
  }
  .stat-num {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 8vw, 6rem);
    line-height: 1;
    color: var(--color-text);
    letter-spacing: -0.06em;
  }
  .stat-label {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-top: var(--space-3);
  }
  .stat-desc {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    margin-top: var(--space-2);
    max-width: 240px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.5;
  }

  .evidence__pills {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .evidence__pill {
    background: var(--color-surface-2);
    border: 1px solid var(--color-surface-4);
    border-radius: var(--radius-md);
    padding: var(--space-6) var(--space-4);
    text-align: center;
    transition: transform var(--duration-base), border-color var(--duration-base);
  }
  .evidence__pill:hover {
    transform: translateY(-3px);
    border-color: var(--color-primary);
  }
  .pill-val {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-primary);
  }
  .pill-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: 4px;
    line-height: 1.4;
  }

  @media (max-width: 900px) {
    .evidence__stats { grid-template-columns: 1fr; gap: var(--space-6); }
    .evidence__stat:not(:last-child)::after { display: none; }
    .evidence__pills { grid-template-columns: repeat(2, 1fr); }
  }
</style>

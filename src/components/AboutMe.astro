---
---
<section class="about-me-section" id="about-me">
  <div class="container">
    <div class="about-grid">
      
      <!-- Left Column: Visuals -->
      <div class="about-visuals">
        <div class="image-container main-image">
          <img src="/assets/me.jpg" alt="Aliaksei Y." loading="lazy" class="profile-img" />
          <div class="image-overlay"></div>
        </div>
        
        <div class="floating-video">
          <video src="/assets/avatar.mp4" autoplay loop muted playsinline class="avatar-video"></video>
          <div class="video-glow"></div>
        </div>
        
        <!-- RU: Лет в IT -->
        <div class="experience-badge">
          <span class="years">15+</span>
          <span class="label">Years in IT</span>
        </div>
      </div>

      <!-- Right Column: Content -->
      <div class="about-content">
        <!-- RU: 04 — Обо мне -->
        <div class="section-num reveal">04 — About Me</div>
        <!-- RU: Привет, я Алексей -->
        <h2 class="section-title reveal">
          <span class="line">Hey, I'm</span>
          <span class="line accent">Aliaksei</span>
        </h2>
        
        <div class="bio-text reveal">
          <!-- RU: Я занимаюсь веб-разработкой более 15 лет... -->
          <p class="lead">I've been in web development for over 15 years. In that time, I've gone from building simple websites to developing complex corporate portals and AI-powered solutions.</p>
          
          <!-- RU: Мой опыт включает международные стажировки... -->
          <p>My experience includes international internships and working with clients worldwide. Since 2021, I've been an independent consultant helping businesses grow and automate their processes.</p>
          
          <!-- RU: Моя главная цель — делать мир и бизнес лучше... -->
          <p>My goal is to make business better through modern technology. I believe that smart automation frees up time for creativity and strategic growth.</p>
        </div>

        <div class="skills-grid reveal">
          <div class="skill-item">
            <div class="skill-icon">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
            </div>
            <div class="skill-info">
              <h4>Web Development</h4>
              <span>Astro, React, Node.js</span>
            </div>
          </div>
          
          <div class="skill-item">
            <div class="skill-icon">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            </div>
            <div class="skill-info">
              <h4>E-commerce</h4>
              <span>Shopify, WooCommerce</span>
            </div>
          </div>
          
          <div class="skill-item">
            <div class="skill-icon">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            </div>
            <div class="skill-info">
              <h4>AI Automation</h4>
              <span>Telegram Bots, LLMs</span>
            </div>
          </div>
          
          <div class="skill-item">
            <div class="skill-icon">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            </div>
            <div class="skill-info">
              <h4>Architecture</h4>
              <span>System Design, APIs</span>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  .about-me-section {
    padding: clamp(80px, 15vw, 150px) 20px;
    background: var(--black);
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(60px, 10vw, 120px);
    align-items: center;
  }

  @media (max-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Visuals Column */
  .about-visuals {
    position: relative;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
  }

  .image-container {
    position: relative;
    border-radius: 30px;
    overflow: hidden;
    aspect-ratio: 4/5;
    transform: rotate(-3deg);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 30px 60px rgba(0,0,0,0.5);
  }

  .about-visuals:hover .image-container {
    transform: rotate(0deg) scale(1.02);
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.2);
    transition: filter 0.5s ease;
  }

  .about-visuals:hover .profile-img {
    filter: grayscale(0%) contrast(1);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 50%);
    pointer-events: none;
  }

  .floating-video {
    position: absolute;
    bottom: -30px;
    right: -30px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid var(--black);
    z-index: 2;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    animation: float 6s ease-in-out infinite;
  }

  .avatar-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-glow {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: var(--orange);
    filter: blur(20px);
    opacity: 0.3;
    z-index: -1;
  }

  .experience-badge {
    position: absolute;
    top: 40px;
    left: -40px;
    background: var(--orange);
    color: var(--white);
    padding: 20px;
    border-radius: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 15px 30px rgba(255, 107, 0, 0.3);
    transform: rotate(10deg);
    z-index: 2;
  }

  .years {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    line-height: 1;
  }

  .label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
    100% { transform: translateY(0px); }
  }

  @media (max-width: 768px) {
    .floating-video {
      width: 120px;
      height: 120px;
      bottom: -15px;
      right: -15px;
    }
    .experience-badge {
      top: 20px;
      left: -10px;
      padding: 15px;
    }
    .years { font-size: 2rem; }
  }

  /* Content Column */
  .about-content {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .section-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    color: var(--orange);
    letter-spacing: 0.1em;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .section-title .line {
    display: block;
  }

  .section-title .accent {
    color: var(--orange);
  }

  .bio-text {
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.7);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .bio-text .lead {
    font-size: 1.2em;
    color: var(--white);
    font-weight: 500;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 20px;
  }

  .skill-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    transition: all 0.3s ease;
  }

  .skill-item:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--orange);
    transform: translateY(-5px);
  }

  .skill-icon {
    color: var(--orange);
    flex-shrink: 0;
  }

  .skill-info h4 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 4px;
    color: var(--white);
  }

  .skill-info span {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 600px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Parallax effect for visuals
    gsap.to('.about-visuals', {
      scrollTrigger: {
        trigger: '.about-me-section',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 1
      },
      y: -50,
      ease: 'none'
    });

    // Reveal animations for content
    const reveals = document.querySelectorAll('.about-content .reveal');
    
    reveals.forEach((el, i) => {
      gsap.fromTo(el, 
        { y: 50, opacity: 0 },
        {
          scrollTrigger: {
            trigger: el,
            start: 'top 85%',
            toggleActions: 'play none none reverse'
          },
          y: 0,
          opacity: 1,
          duration: 0.8,
          ease: 'power3.out',
          delay: i * 0.1
        }
      );
    });
  });
</script>

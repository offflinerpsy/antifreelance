---
interface Props {
  theme?: 'dark' | 'light' | 'blue' | 'green' | 'purple';
  botName: string;
  botStatus?: string;
  messages: {
    type: 'bot' | 'user';
    text: string;
    time?: string;
    buttons?: { text: string; url?: string }[][];
  }[];
}

const { theme = 'dark', botName, botStatus = 'bot', messages } = Astro.props;

const themeClasses = {
  dark: 'tg-dark',
  light: 'tg-light',
  blue: 'tg-blue',
  green: 'tg-green',
  purple: 'tg-purple'
};
---

<div class={`tg-chat-container ${themeClasses[theme]}`}>
  <!-- Header -->
  <div class="tg-header">
    <div class="tg-back">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </div>
    <div class="tg-info">
      <div class="tg-name">{botName}</div>
      <div class="tg-status">{botStatus}</div>
    </div>
    <div class="tg-avatar">
      <div class="tg-avatar-inner">{botName.charAt(0)}</div>
    </div>
  </div>

  <!-- Messages Area -->
  <div class="tg-messages">
    <div class="tg-date">Сегодня</div>
    
    {messages.map((msg) => (
      <div class={`tg-msg-wrapper ${msg.type}`}>
        <div class="tg-msg-content">
          <div class="tg-msg">
            <span class="tg-text" set:html={msg.text}></span>
            <span class="tg-time">{msg.time || '12:00'}</span>
          </div>
          {msg.buttons && msg.buttons.length > 0 && (
            <div class="tg-inline-keyboard">
              {msg.buttons.map(row => (
                <div class="tg-keyboard-row">
                  {row.map(btn => (
                    <div class="tg-keyboard-btn">{btn.text}</div>
                  ))}
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>

  <!-- Input Area -->
  <div class="tg-input-area">
    <div class="tg-attach">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
    </div>
    <div class="tg-input">Сообщение...</div>
    <div class="tg-mic">
      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
    </div>
  </div>
</div>

<style>
  .tg-chat-container {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    font-size: 14px;
    position: relative;
    overflow: hidden;
  }

  /* Themes */
  .tg-dark {
    background: #0e1621;
    --tg-header-bg: #17212b;
    --tg-text: #ffffff;
    --tg-subtext: #7f91a4;
    --tg-bot-msg: #182533;
    --tg-user-msg: #2b5278;
    --tg-input-bg: #17212b;
    --tg-border: #0e1621;
  }
  .tg-light {
    background: #e4eaf0;
    --tg-header-bg: #ffffff;
    --tg-text: #000000;
    --tg-subtext: #707579;
    --tg-bot-msg: #ffffff;
    --tg-user-msg: #eef7d8;
    --tg-input-bg: #ffffff;
    --tg-border: #d2dbe3;
  }
  .tg-blue {
    background: linear-gradient(135deg, #1a2980 0%, #26d0ce 100%);
    --tg-header-bg: rgba(255,255,255,0.1);
    --tg-text: #ffffff;
    --tg-subtext: rgba(255,255,255,0.7);
    --tg-bot-msg: rgba(0,0,0,0.4);
    --tg-user-msg: rgba(255,255,255,0.2);
    --tg-input-bg: rgba(0,0,0,0.3);
    --tg-border: transparent;
  }
  .tg-green {
    background: #1c2826;
    --tg-header-bg: #23332f;
    --tg-text: #e8f0ee;
    --tg-subtext: #8a9e9a;
    --tg-bot-msg: #2a3d38;
    --tg-user-msg: #4a7c59;
    --tg-input-bg: #23332f;
    --tg-border: #1c2826;
  }
  .tg-purple {
    background: #1a1423;
    --tg-header-bg: #241c30;
    --tg-text: #f0e8f5;
    --tg-subtext: #9e8aa6;
    --tg-bot-msg: #2d233c;
    --tg-user-msg: #6b4a8c;
    --tg-input-bg: #241c30;
    --tg-border: #1a1423;
  }

  /* Header */
  .tg-header {
    display: flex;
    align-items: center;
    padding: 10px 16px;
    background: var(--tg-header-bg);
    color: var(--tg-text);
    border-bottom: 1px solid var(--tg-border);
    z-index: 10;
    backdrop-filter: blur(10px);
  }
  .tg-back {
    margin-right: 16px;
    color: var(--tg-subtext);
  }
  .tg-info {
    flex: 1;
  }
  .tg-name {
    font-weight: 600;
    font-size: 16px;
    margin-bottom: 2px;
  }
  .tg-status {
    font-size: 12px;
    color: var(--tg-subtext);
  }
  .tg-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(45deg, #ff8a00, #e52e71);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 16px;
  }

  /* Messages */
  .tg-messages {
    flex: 1;
    padding: 16px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
    /* Hide scrollbar */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .tg-messages::-webkit-scrollbar {
    display: none;
  }

  .tg-date {
    align-self: center;
    background: rgba(0,0,0,0.2);
    color: var(--tg-text);
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    margin-bottom: 12px;
    backdrop-filter: blur(4px);
  }
  .tg-light .tg-date {
    background: rgba(0,0,0,0.1);
  }

  .tg-msg-wrapper {
    display: flex;
    width: 100%;
  }
  .tg-msg-wrapper.bot {
    justify-content: flex-start;
  }
  .tg-msg-wrapper.user {
    justify-content: flex-end;
  }

  .tg-msg-content {
    max-width: 85%;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tg-msg {
    padding: 8px 12px;
    border-radius: 12px;
    position: relative;
    color: var(--tg-text);
    line-height: 1.4;
    display: flex;
    flex-direction: column;
  }
  .tg-msg-wrapper.bot .tg-msg {
    background: var(--tg-bot-msg);
    border-bottom-left-radius: 4px;
  }
  .tg-msg-wrapper.user .tg-msg {
    background: var(--tg-user-msg);
    border-bottom-right-radius: 4px;
  }

  .tg-inline-keyboard {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 100%;
  }
  .tg-keyboard-row {
    display: flex;
    gap: 4px;
    width: 100%;
  }
  .tg-keyboard-btn {
    flex: 1;
    background: rgba(255, 255, 255, 0.1);
    color: var(--tg-text);
    padding: 10px;
    border-radius: 8px;
    text-align: center;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
    backdrop-filter: blur(5px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  .tg-light .tg-keyboard-btn {
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.05);
  }
  .tg-keyboard-btn:hover {
    background: rgba(255, 255, 255, 0.2);
  }
  .tg-light .tg-keyboard-btn:hover {
    background: rgba(0, 0, 0, 0.1);
  }

  .tg-text {
    margin-bottom: 4px;
    word-wrap: break-word;
  }

  .tg-time {
    font-size: 11px;
    color: var(--tg-subtext);
    align-self: flex-end;
    margin-top: -4px;
  }
  .tg-msg-wrapper.user .tg-time {
    color: rgba(255,255,255,0.7);
  }
  .tg-light .tg-msg-wrapper.user .tg-time {
    color: rgba(0,0,0,0.4);
  }

  /* Input Area */
  .tg-input-area {
    display: flex;
    align-items: center;
    padding: 10px 16px;
    background: var(--tg-input-bg);
    color: var(--tg-subtext);
    gap: 16px;
    border-top: 1px solid var(--tg-border);
  }
  .tg-input {
    flex: 1;
    font-size: 15px;
  }
</style>

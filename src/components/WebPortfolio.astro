---
/*
  RU: Original project labels:
  Корпоративный портал, Интернет-магазин, Лендинг, Сайт-визитка, Многостраничный сайт,
  Сложный интерфейс, Интерфейс приложения, Карточка товара, Конфигуратор, Продукт,
  Главная страница, Макет недвижимости, Медицинский портал, Проекты, Контакты, Скриншот проекта
*/
const webProjects = [
  { src: '/assets/web/corporate-portal.webp', alt: 'Project management SaaS platform with clean dark UI', title: 'Project Management SaaS', category: 'Web App', size: 'large' },
  { src: '/assets/web/online-store.webp', alt: 'Cloud database platform landing page with gradient design', title: 'Cloud Database Platform', category: 'SaaS Landing', size: 'tall' },
  { src: '/assets/web/landing-page.webp', alt: 'Developer deployment platform with bold typography', title: 'Dev Deployment Platform', category: 'Landing Page', size: 'small' },
  { src: '/assets/web/business-card.webp', alt: 'Email API platform with minimal modern design', title: 'Email API Platform', category: 'SaaS Landing', size: 'small' },
  { src: '/assets/web/multi-page.webp', alt: 'Productivity app marketing site with dark aesthetic', title: 'Productivity App Site', category: 'Product Website', size: 'wide' },
  { src: '/assets/web/complex-interface.webp', alt: 'Global payments platform with sophisticated interface', title: 'Payments Platform', category: 'Web App', size: 'small' },
  { src: '/assets/web/app-interface.webp', alt: 'Animation platform with vibrant UI and asset library', title: 'Animation Platform', category: 'Web App', size: 'tall' },
  { src: '/assets/web/product-card.webp', alt: 'Scheduling and calendar platform with clean interface', title: 'Scheduling Platform', category: 'SaaS Product', size: 'small' },
  { src: '/assets/web/configurator.webp', alt: 'Real-time collaboration platform for developers', title: 'Collaboration Platform', category: 'Developer Tool', size: 'large' },
  { src: '/assets/web/product-page.webp', alt: 'Modern publishing platform with membership features', title: 'Publishing Platform', category: 'Web Design', size: 'small' },
  { src: '/assets/web/home-page.webp', alt: 'No-code website builder with visual design tools', title: 'Visual Website Builder', category: 'SaaS Product', size: 'wide' },
  { src: '/assets/web/real-estate.webp', alt: 'Cloud infrastructure deployment platform dashboard', title: 'Cloud Infra Platform', category: 'Web App', size: 'large' },
  { src: '/assets/web/medical-portal.webp', alt: 'Team workspace and productivity platform', title: 'Team Workspace App', category: 'SaaS Product', size: 'tall' },
  { src: '/assets/web/projects.webp', alt: 'Background jobs and automation platform for developers', title: 'Dev Automation Tool', category: 'Developer Tool', size: 'small' },
  { src: '/assets/web/contacts.webp', alt: 'Internal tools builder with drag-and-drop interface', title: 'Internal Tools Builder', category: 'Low-code Platform', size: 'small' },
  { src: '/assets/web/screenshot-app.webp', alt: 'Modern collaborative code editor with AI features', title: 'AI-Powered Code Editor', category: 'Desktop App', size: 'small' }
];

const upworkReviews = [
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (1).webp', alt: 'Upwork Review 1' },
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (2).webp', alt: 'Upwork Review 2' },
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (3).webp', alt: 'Upwork Review 3' },
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (4).webp', alt: 'Upwork Review 4' },
];
---

<section class="web-portfolio" id="web-portfolio">
  <div class="container">
    <div class="section-header">
      <!-- RU: Избранные работы -->
      <h2 class="section-title">Featured <span class="accent">Work</span></h2>
      <!-- RU: Каждый проект — это уникальное решение, созданное с вниманием к деталям, производительности и конверсии. -->
      <p class="section-desc">Every project is a unique solution crafted with attention to detail, performance, and conversion.</p>
    </div>

    <!-- Web Projects Grid -->
    <div class="projects-grid">
      {webProjects.map((project) => (
        <div class={`project-card size-${project.size}`}>
          <div class="project-image-wrapper">
            <img src={project.src} alt={project.alt} loading="lazy" class="project-img" />
            <div class="project-overlay">
              <div class="project-info">
                <span class="project-category">{project.category}</span>
                <h3 class="project-name">{project.title}</h3>
              </div>
              <button class="view-btn" data-src={project.src}>
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Upwork Section (Integrated) -->
    <div class="upwork-integrated reveal">
      <div class="upwork-info">
        <h2 class="section-title">Upwork <span class="accent">Top Rated</span></h2>
        <!-- RU: Upwork — крупнейшая мировая фриланс-биржа. Статус Top Rated получают только лучшие специалисты (элита платформы) с безупречной репутацией, 100% Job Success Score и десятками успешно сданных проектов. -->
        <p class="upwork-desc">Upwork is the world's largest freelance marketplace. <strong>Top Rated</strong> status is reserved for the platform's elite — professionals with a flawless reputation, 100% Job Success Score, and dozens of successfully completed projects.</p>
        <div class="upwork-badges">
          <div class="badge">100% Job Success</div>
          <div class="badge">Top Rated</div>
        </div>
      </div>
      
      <div class="upwork-visual">
        <div class="tablet-device mini-tablet">
          <div class="tablet-camera"></div>
          <div class="tablet-screen">
            <div class="tablet-scroll-area auto-scroll">
              <div class="upwork-scroll-track">
                {upworkReviews.map((review) => (
                  <div class="upwork-img-wrapper">
                    <img src={review.src} alt={review.alt} loading="lazy" class="upwork-scroll-img" />
                    <button class="view-btn upwork-view-btn" data-src={review.src}>
                      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
                    </button>
                  </div>
                ))}
                {/* Duplicate for infinite scroll */}
                {upworkReviews.map((review) => (
                  <div class="upwork-img-wrapper">
                    <img src={review.src} alt={review.alt} loading="lazy" class="upwork-scroll-img" />
                    <button class="view-btn upwork-view-btn" data-src={review.src}>
                      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
                    </button>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <div class="tablet-home-button"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tablet Modal -->
  <div class="tablet-modal" id="tablet-modal">
    <div class="tablet-overlay"></div>
    <div class="tablet-container">
      <!-- RU: Закрыть -->
      <button class="tablet-close" aria-label="Close">
        <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      
      <!-- RU: Предыдущий проект -->
      <button class="tablet-nav prev-project" aria-label="Previous project">
        <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>

      <div class="tablet-device">
        <div class="tablet-camera"></div>
        <div class="tablet-screen">
          <div class="tablet-scroll-area">
            <img src="" alt="Full size project" class="tablet-img" />
          </div>
        </div>
        <div class="tablet-home-button"></div>
      </div>

      <!-- RU: Следующий проект -->
      <button class="tablet-nav next-project" aria-label="Next project">
        <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .web-portfolio {
    padding: clamp(80px, 15vw, 150px) 20px;
    background: var(--black);
    position: relative;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: clamp(40px, 8vw, 80px);
    max-width: 800px;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1;
    margin-bottom: 20px;
    color: var(--white);
    letter-spacing: 0.02em;
  }

  .section-desc {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
  }

  /* Projects Grid - Masonry Style */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 300px;
    grid-auto-flow: dense;
    gap: 24px;
    margin-bottom: clamp(80px, 15vw, 150px);
  }

  .project-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transform: translateY(50px);
    opacity: 0;
  }

  /* Tetris Grid Sizes */
  .size-large { grid-column: span 8; grid-row: span 2; }
  .size-wide  { grid-column: span 8; grid-row: span 1; }
  .size-tall  { grid-column: span 4; grid-row: span 2; }
  .size-small { grid-column: span 4; grid-row: span 1; }

  @media (max-width: 1024px) {
    .projects-grid { grid-auto-rows: 250px; }
    .size-large, .size-wide { grid-column: span 12; }
    .size-tall, .size-small { grid-column: span 6; }
  }

  @media (max-width: 768px) {
    .projects-grid { grid-auto-rows: 300px; display: flex; flex-direction: column; }
    .project-card { width: 100%; height: 300px; }
  }

  .project-image-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .size-tall .project-img {
    object-position: center;
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 30px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .project-card:hover .project-img {
    transform: scale(1.05);
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-info {
    transform: translateY(20px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .project-info {
    transform: translateY(0);
  }

  .project-category {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--orange);
    margin-bottom: 8px;
    display: block;
  }

  .project-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--white);
  }

  .view-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--orange);
    color: var(--white);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .view-btn {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .view-btn:hover {
    background: var(--white);
    color: var(--orange);
    transform: translate(-50%, -50%) scale(1.1) !important;
  }

  /* Upwork Integrated Section */
  .upwork-integrated {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    margin-top: 80px;
    padding: 60px;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .upwork-info {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .upwork-desc {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .upwork-badges {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .badge {
    padding: 8px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--lime);
  }

  .upwork-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mini-tablet {
    width: 100%;
    max-width: 400px;
    height: 600px;
    transform: none !important;
    margin: 0;
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
  }

  .auto-scroll {
    overflow: hidden !important;
  }

  .upwork-scroll-track {
    display: flex;
    flex-direction: column;
    gap: 0;
    animation: scrollUpwork 40s linear infinite;
  }

  .upwork-scroll-track:hover {
    animation-play-state: paused;
  }

  .upwork-img-wrapper {
    position: relative;
    width: 100%;
  }

  .upwork-img-wrapper:hover .upwork-view-btn {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .upwork-view-btn {
    z-index: 5;
  }

  .upwork-scroll-img {
    width: 100%;
    height: auto;
    display: block;
    border-bottom: 2px solid #222;
  }

  @keyframes scrollUpwork {
    0% { transform: translateY(0); }
    100% { transform: translateY(-50%); } /* Assuming we duplicate content or just scroll through */
  }

  @media (max-width: 1024px) {
    .upwork-integrated {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 20px;
    }
    .mini-tablet {
      height: 500px;
    }
  }

  /* Tablet Modal */
  .tablet-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .tablet-modal.active {
    opacity: 1;
    pointer-events: all;
  }

  .tablet-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(10px);
  }

  .tablet-container {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .tablet-device {
    width: 100%;
    max-width: 900px;
    height: 85vh;
    background: #1a1a1a;
    border-radius: 32px;
    border: 12px solid #333;
    box-shadow: 
      0 20px 50px rgba(0,0,0,0.5),
      inset 0 0 0 2px rgba(255,255,255,0.1);
    position: relative;
    display: flex;
    flex-direction: column;
    transform: translateY(50px) scale(0.95);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tablet-modal.active .tablet-device {
    transform: translateY(0) scale(1);
  }

  .tablet-camera {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 8px;
    background: #000;
    border-radius: 50%;
    border: 1px solid #222;
    z-index: 10;
  }

  .tablet-screen {
    flex: 1;
    background: #000;
    margin: 30px 10px 24px 10px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .tablet-home-button {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 4px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }

  .tablet-scroll-area {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    scrollbar-color: var(--orange) #222;
  }

  .tablet-scroll-area::-webkit-scrollbar {
    width: 6px;
  }
  .tablet-scroll-area::-webkit-scrollbar-track {
    background: #222;
  }
  .tablet-scroll-area::-webkit-scrollbar-thumb {
    background-color: var(--orange);
    border-radius: 10px;
  }

  .tablet-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .tablet-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    color: var(--white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .tablet-close:hover {
    background: var(--orange);
    border-color: var(--orange);
    transform: scale(1.1);
  }

  .tablet-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    width: 64px;
    height: 64px;
    color: var(--white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .tablet-nav:hover {
    background: var(--orange);
    border-color: var(--orange);
    transform: translateY(-50%) scale(1.1);
  }

  .prev-project {
    left: 40px;
  }

  .next-project {
    right: 40px;
  }

  @media (max-width: 1200px) {
    .tablet-nav {
      width: 48px;
      height: 48px;
    }
    .prev-project { left: 20px; }
    .next-project { right: 20px; }
  }

  @media (max-width: 768px) {
    .tablet-device {
      border-width: 8px;
      border-radius: 24px;
      height: 90vh;
    }
    .tablet-screen {
      margin: 20px 5px 5px 5px;
      border-radius: 8px;
    }
    .tablet-close {
      top: 10px;
      right: 10px;
      width: 40px;
      height: 40px;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
      gsap.registerPlugin(ScrollTrigger);

      var projects = document.querySelectorAll('.project-card');
      projects.forEach(function(project, i) {
        gsap.to(project, {
          scrollTrigger: { trigger: project, start: 'top 85%', toggleActions: 'play none none reverse' },
          y: 0, opacity: 1, duration: 0.8, ease: 'power3.out', delay: (i % 3) * 0.1
        });
      });

      gsap.to('.upwork-integrated', {
        scrollTrigger: { trigger: '.upwork-integrated', start: 'top 80%', toggleActions: 'play none none reverse' },
        y: 0, opacity: 1, duration: 0.8, ease: 'power3.out'
      });
    }

    // Tablet Modal Logic
    var modal = document.getElementById('tablet-modal');
    var modalImg = modal ? modal.querySelector('.tablet-img') : null;
    var closeBtn = modal ? modal.querySelector('.tablet-close') : null;
    var overlay = modal ? modal.querySelector('.tablet-overlay') : null;
    var scrollArea = modal ? modal.querySelector('.tablet-scroll-area') : null;
    var viewBtns = document.querySelectorAll('.view-btn');
    var prevBtn = modal ? modal.querySelector('.prev-project') : null;
    var nextBtn = modal ? modal.querySelector('.next-project') : null;

    var currentProjectIndex = 0;
    var projectImages = Array.from(viewBtns).map(function(btn) { return btn.getAttribute('data-src') || ''; });

    function openModal(index) {
      if (modal && modalImg && projectImages[index]) {
        currentProjectIndex = index;
        modalImg.src = projectImages[index];
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
        if (scrollArea) scrollArea.scrollTop = 0;
      }
    }

    function closeModal() {
      if (modal) {
        modal.classList.remove('active');
        document.body.style.overflow = '';
        setTimeout(function() { if (modalImg) modalImg.src = ''; }, 400);
      }
    }

    function showNextProject() {
      openModal((currentProjectIndex + 1) % projectImages.length);
    }

    function showPrevProject() {
      openModal((currentProjectIndex - 1 + projectImages.length) % projectImages.length);
    }

    viewBtns.forEach(function(btn, index) {
      btn.addEventListener('click', function(e) { e.preventDefault(); openModal(index); });
    });

    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (overlay) overlay.addEventListener('click', closeModal);
    if (nextBtn) nextBtn.addEventListener('click', showNextProject);
    if (prevBtn) prevBtn.addEventListener('click', showPrevProject);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeModal();
      if (modal && modal.classList.contains('active')) {
        if (e.key === 'ArrowRight') showNextProject();
        if (e.key === 'ArrowLeft') showPrevProject();
      }
    });
  });
</script>

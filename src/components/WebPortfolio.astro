---
const webProjects = [
  { src: '/assets/web/D1_Website_Home_Page-1.jpg', alt: 'Web Project 1', title: 'Корпоративный портал', category: 'Web Development' },
  { src: '/assets/web/D1_Website_Home_Page-2.jpg', alt: 'Web Project 2', title: 'Интернет-магазин', category: 'E-commerce' },
  { src: '/assets/web/D1_Website_Home_Page-3.jpg', alt: 'Web Project 3', title: 'Лендинг', category: 'Landing Page' },
  { src: '/assets/web/Home (4).png', alt: 'Web Project 4', title: 'Сайт-визитка', category: 'Corporate' },
  { src: '/assets/web/home_pk.png', alt: 'Web Project 5', title: 'Многостраничный сайт', category: 'Web Development' },
  { src: '/assets/web/image_2024-03-04_10-56-29.png', alt: 'Web Project 6', title: 'Сложный интерфейс', category: 'UI/UX Design' },
];

const upworkReviews = [
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (1).png', alt: 'Upwork Review 1' },
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (2).png', alt: 'Upwork Review 2' },
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (3).png', alt: 'Upwork Review 3' },
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (4).png', alt: 'Upwork Review 4' },
];
---

<section class="web-portfolio" id="web-portfolio">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Избранные <span class="accent">работы</span></h2>
      <p class="section-desc">Каждый проект — это уникальное решение, созданное с вниманием к деталям, производительности и конверсии.</p>
    </div>

    <!-- Web Projects Grid -->
    <div class="projects-grid">
      {webProjects.map((project, index) => (
        <div class={`project-card project-${index + 1}`}>
          <div class="project-image-wrapper">
            <img src={project.src} alt={project.alt} loading="lazy" class="project-img" />
            <div class="project-overlay">
              <div class="project-info">
                <span class="project-category">{project.category}</span>
                <h3 class="project-name">{project.title}</h3>
              </div>
              <button class="view-btn" data-src={project.src}>
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Upwork Section (Integrated) -->
    <div class="upwork-integrated reveal">
      <div class="upwork-info">
        <h2 class="section-title">Upwork <span class="accent">Top Rated</span></h2>
        <p class="upwork-desc">Upwork — крупнейшая мировая фриланс-биржа. Статус <strong>Top Rated</strong> получают только лучшие специалисты (элита платформы) с безупречной репутацией, 100% Job Success Score и десятками успешно сданных проектов.</p>
        <div class="upwork-badges">
          <div class="badge">100% Job Success</div>
          <div class="badge">Top Rated</div>
        </div>
      </div>
      
      <div class="upwork-visual">
        <div class="tablet-device mini-tablet">
          <div class="tablet-camera"></div>
          <div class="tablet-screen">
            <div class="tablet-scroll-area auto-scroll">
              <div class="upwork-scroll-track">
                {upworkReviews.map((review) => (
                  <img src={review.src} alt={review.alt} loading="lazy" class="upwork-scroll-img" />
                ))}
                {/* Duplicate for infinite scroll */}
                {upworkReviews.map((review) => (
                  <img src={review.src} alt={review.alt} loading="lazy" class="upwork-scroll-img" />
                ))}
              </div>
            </div>
          </div>
          <div class="tablet-home-button"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tablet Modal -->
  <div class="tablet-modal" id="tablet-modal">
    <div class="tablet-overlay"></div>
    <div class="tablet-container">
      <button class="tablet-close" aria-label="Закрыть">
        <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      
      <button class="tablet-nav prev-project" aria-label="Предыдущий проект">
        <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>

      <div class="tablet-device">
        <div class="tablet-camera"></div>
        <div class="tablet-screen">
          <div class="tablet-scroll-area">
            <img src="" alt="Full size project" class="tablet-img" />
          </div>
        </div>
        <div class="tablet-home-button"></div>
      </div>

      <button class="tablet-nav next-project" aria-label="Следующий проект">
        <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .web-portfolio {
    padding: clamp(80px, 15vw, 150px) 20px;
    background: var(--black);
    position: relative;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: clamp(40px, 8vw, 80px);
    max-width: 800px;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1;
    margin-bottom: 20px;
    color: var(--white);
    letter-spacing: 0.02em;
  }

  .section-desc {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
  }

  /* Projects Grid - Masonry Style */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 24px;
    margin-bottom: clamp(80px, 15vw, 150px);
  }

  .project-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transform: translateY(50px);
    opacity: 0;
  }

  /* Complex Grid Layout */
  .project-1 { grid-column: span 8; grid-row: span 2; aspect-ratio: 16/9; }
  .project-2 { grid-column: span 4; grid-row: span 1; aspect-ratio: 4/3; }
  .project-3 { grid-column: span 4; grid-row: span 1; aspect-ratio: 4/3; }
  .project-4 { grid-column: span 4; grid-row: span 2; aspect-ratio: 3/4; }
  .project-5 { grid-column: span 8; grid-row: span 1; aspect-ratio: 21/9; }
  .project-6 { grid-column: span 8; grid-row: span 1; aspect-ratio: 21/9; }

  @media (max-width: 1024px) {
    .project-1, .project-4, .project-5, .project-6 { grid-column: span 12; aspect-ratio: 16/9; }
    .project-2, .project-3 { grid-column: span 6; aspect-ratio: 4/3; }
  }

  @media (max-width: 768px) {
    .project-card { grid-column: span 12 !important; aspect-ratio: 16/9 !important; }
  }

  .project-image-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 30px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .project-card:hover .project-img {
    transform: scale(1.05);
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-info {
    transform: translateY(20px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .project-info {
    transform: translateY(0);
  }

  .project-category {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--orange);
    margin-bottom: 8px;
    display: block;
  }

  .project-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--white);
  }

  .view-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--orange);
    color: var(--white);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .view-btn {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .view-btn:hover {
    background: var(--white);
    color: var(--orange);
    transform: translate(-50%, -50%) scale(1.1) !important;
  }

  /* Upwork Integrated Section */
  .upwork-integrated {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    margin-top: 80px;
    padding: 60px;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .upwork-info {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .upwork-desc {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .upwork-badges {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .badge {
    padding: 8px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--lime);
  }

  .upwork-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mini-tablet {
    width: 100%;
    max-width: 400px;
    height: 600px;
    transform: none !important;
    margin: 0;
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
  }

  .auto-scroll {
    overflow: hidden !important;
  }

  .upwork-scroll-track {
    display: flex;
    flex-direction: column;
    gap: 0;
    animation: scrollUpwork 20s linear infinite;
  }

  .upwork-scroll-track:hover {
    animation-play-state: paused;
  }

  .upwork-scroll-img {
    width: 100%;
    height: auto;
    display: block;
    border-bottom: 2px solid #222;
  }

  @keyframes scrollUpwork {
    0% { transform: translateY(0); }
    100% { transform: translateY(-50%); } /* Assuming we duplicate content or just scroll through */
  }

  @media (max-width: 1024px) {
    .upwork-integrated {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 20px;
    }
    .mini-tablet {
      height: 500px;
    }
  }

  /* Tablet Modal */
  .tablet-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .tablet-modal.active {
    opacity: 1;
    pointer-events: all;
  }

  .tablet-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(10px);
  }

  .tablet-container {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .tablet-device {
    width: 100%;
    max-width: 900px;
    height: 85vh;
    background: #1a1a1a;
    border-radius: 32px;
    border: 12px solid #333;
    box-shadow: 
      0 20px 50px rgba(0,0,0,0.5),
      inset 0 0 0 2px rgba(255,255,255,0.1);
    position: relative;
    display: flex;
    flex-direction: column;
    transform: translateY(50px) scale(0.95);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tablet-modal.active .tablet-device {
    transform: translateY(0) scale(1);
  }

  .tablet-camera {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 8px;
    height: 8px;
    background: #000;
    border-radius: 50%;
    border: 1px solid #222;
    z-index: 10;
  }

  .tablet-screen {
    flex: 1;
    background: #000;
    margin: 30px 10px 24px 10px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .tablet-home-button {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 4px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }

  .tablet-scroll-area {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    scrollbar-color: var(--orange) #222;
  }

  .tablet-scroll-area::-webkit-scrollbar {
    width: 6px;
  }
  .tablet-scroll-area::-webkit-scrollbar-track {
    background: #222;
  }
  .tablet-scroll-area::-webkit-scrollbar-thumb {
    background-color: var(--orange);
    border-radius: 10px;
  }

  .tablet-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .tablet-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    color: var(--white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .tablet-close:hover {
    background: var(--orange);
    border-color: var(--orange);
    transform: scale(1.1);
  }

  .tablet-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    width: 64px;
    height: 64px;
    color: var(--white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .tablet-nav:hover {
    background: var(--orange);
    border-color: var(--orange);
    transform: translateY(-50%) scale(1.1);
  }

  .prev-project {
    left: 40px;
  }

  .next-project {
    right: 40px;
  }

  @media (max-width: 1200px) {
    .tablet-nav {
      width: 48px;
      height: 48px;
    }
    .prev-project { left: 20px; }
    .next-project { right: 20px; }
  }

  @media (max-width: 768px) {
    .tablet-device {
      border-width: 8px;
      border-radius: 24px;
      height: 90vh;
    }
    .tablet-screen {
      margin: 20px 5px 5px 5px;
      border-radius: 8px;
    }
    .tablet-close {
      top: 10px;
      right: 10px;
      width: 40px;
      height: 40px;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Animate Web Projects
    const projects = document.querySelectorAll('.project-card');
    
    projects.forEach((project, i) => {
      gsap.to(project, {
        scrollTrigger: {
          trigger: project,
          start: 'top 85%',
          toggleActions: 'play none none reverse'
        },
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: 'power3.out',
        delay: (i % 3) * 0.1 // Stagger effect for items in same row
      });
    });

    // Animate Upwork Integrated Section
    gsap.to('.upwork-integrated', {
      scrollTrigger: {
        trigger: '.upwork-integrated',
        start: 'top 80%',
        toggleActions: 'play none none reverse'
      },
      y: 0,
      opacity: 1,
      duration: 0.8,
      ease: 'power3.out'
    });

    // Tablet Modal Logic
    const modal = document.getElementById('tablet-modal');
    const modalImg = modal?.querySelector('.tablet-img') as HTMLImageElement;
    const closeBtn = modal?.querySelector('.tablet-close');
    const overlay = modal?.querySelector('.tablet-overlay');
    const scrollArea = modal?.querySelector('.tablet-scroll-area');
    const viewBtns = document.querySelectorAll('.view-btn');
    const prevBtn = modal?.querySelector('.prev-project');
    const nextBtn = modal?.querySelector('.next-project');

    let currentProjectIndex = 0;
    const projectImages = Array.from(viewBtns).map(btn => btn.getAttribute('data-src') || '');

    const openModal = (index: number) => {
      if (modal && modalImg && projectImages[index]) {
        currentProjectIndex = index;
        modalImg.src = projectImages[index];
        modal.classList.add('active');
        document.body.style.overflow = 'hidden'; // Prevent body scrolling
        if (scrollArea) scrollArea.scrollTop = 0; // Reset scroll position
      }
    };

    const closeModal = () => {
      if (modal) {
        modal.classList.remove('active');
        document.body.style.overflow = '';
        setTimeout(() => {
          if (modalImg) modalImg.src = '';
        }, 400);
      }
    };

    const showNextProject = () => {
      const nextIndex = (currentProjectIndex + 1) % projectImages.length;
      openModal(nextIndex);
    };

    const showPrevProject = () => {
      const prevIndex = (currentProjectIndex - 1 + projectImages.length) % projectImages.length;
      openModal(prevIndex);
    };

    viewBtns.forEach((btn, index) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        openModal(index);
      });
    });

    closeBtn?.addEventListener('click', closeModal);
    overlay?.addEventListener('click', closeModal);
    nextBtn?.addEventListener('click', showNextProject);
    prevBtn?.addEventListener('click', showPrevProject);
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
      if (modal?.classList.contains('active')) {
        if (e.key === 'ArrowRight') showNextProject();
        if (e.key === 'ArrowLeft') showPrevProject();
      }
    });
  });
</script>

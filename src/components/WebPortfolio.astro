---
const webProjects = [
  { src: '/assets/web/D1_Website_Home_Page-1.jpg', alt: 'Web Project 1', title: 'Корпоративный портал', category: 'Web Development' },
  { src: '/assets/web/D1_Website_Home_Page-2.jpg', alt: 'Web Project 2', title: 'Интернет-магазин', category: 'E-commerce' },
  { src: '/assets/web/D1_Website_Home_Page-3.jpg', alt: 'Web Project 3', title: 'Лендинг', category: 'Landing Page' },
  { src: '/assets/web/Home (4).png', alt: 'Web Project 4', title: 'Сайт-визитка', category: 'Corporate' },
  { src: '/assets/web/home_pk.png', alt: 'Web Project 5', title: 'Многостраничный сайт', category: 'Web Development' },
  { src: '/assets/web/image_2024-03-04_10-56-29.png', alt: 'Web Project 6', title: 'Сложный интерфейс', category: 'UI/UX Design' },
  { src: '/assets/web/1 (11).png', alt: 'Web Project 7', title: 'Дашборд', category: 'Web App' },
  { src: '/assets/web/1 (12).png', alt: 'Web Project 8', title: 'CRM Система', category: 'Web App' },
];

const upworkReviews = [
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (1).png', alt: 'Upwork Review 1' },
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (2).png', alt: 'Upwork Review 2' },
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (3).png', alt: 'Upwork Review 3' },
  { src: '/assets/upwork/Aliaksei Y. - _PREMIUM_ WordPress _ Woocommerce _ Shopify _ Laravel _ PHP Deleloper - Upwork Freelan (4).png', alt: 'Upwork Review 4' },
];
---

<section class="web-portfolio" id="web-portfolio">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Избранные <span class="accent">работы</span></h2>
      <p class="section-desc">Каждый проект — это уникальное решение, созданное с вниманием к деталям, производительности и конверсии.</p>
    </div>

    <!-- Web Projects Grid -->
    <div class="projects-grid">
      {webProjects.map((project, index) => (
        <div class={`project-card project-${index + 1}`}>
          <div class="project-image-wrapper">
            <img src={project.src} alt={project.alt} loading="lazy" class="project-img" />
            <div class="project-overlay">
              <div class="project-info">
                <span class="project-category">{project.category}</span>
                <h3 class="project-name">{project.title}</h3>
              </div>
              <button class="view-btn" data-src={project.src}>
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
              </button>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Upwork Section -->
    <div class="upwork-section">
      <div class="upwork-header">
        <h2 class="section-title">Upwork <span class="accent">Top Rated</span></h2>
        <div class="upwork-badges">
          <div class="badge">100% Job Success</div>
          <div class="badge">Top Rated</div>
        </div>
      </div>
      
      <div class="upwork-grid">
        {upworkReviews.map((review, index) => (
          <div class={`upwork-card review-${index + 1}`}>
            <img src={review.src} alt={review.alt} loading="lazy" class="review-img" />
            <div class="review-overlay">
              <button class="view-btn" data-src={review.src}>
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Lightbox Modal -->
  <div class="lightbox" id="lightbox">
    <div class="lightbox-overlay"></div>
    <div class="lightbox-content">
      <button class="lightbox-close" aria-label="Закрыть">
        <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      <img src="" alt="Full size image" class="lightbox-img" />
    </div>
  </div>
</section>

<style>
  .web-portfolio {
    padding: clamp(80px, 15vw, 150px) 20px;
    background: var(--black);
    position: relative;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: clamp(40px, 8vw, 80px);
    max-width: 800px;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1;
    margin-bottom: 20px;
    color: var(--white);
    letter-spacing: 0.02em;
  }

  .section-desc {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
  }

  /* Projects Grid - Masonry Style */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 24px;
    margin-bottom: clamp(80px, 15vw, 150px);
  }

  .project-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transform: translateY(50px);
    opacity: 0;
  }

  /* Complex Grid Layout */
  .project-1 { grid-column: span 8; grid-row: span 2; aspect-ratio: 16/9; }
  .project-2 { grid-column: span 4; grid-row: span 1; aspect-ratio: 4/3; }
  .project-3 { grid-column: span 4; grid-row: span 1; aspect-ratio: 4/3; }
  .project-4 { grid-column: span 4; grid-row: span 2; aspect-ratio: 3/4; }
  .project-5 { grid-column: span 8; grid-row: span 1; aspect-ratio: 21/9; }
  .project-6 { grid-column: span 4; grid-row: span 1; aspect-ratio: 16/9; }
  .project-7 { grid-column: span 4; grid-row: span 1; aspect-ratio: 16/9; }
  .project-8 { grid-column: span 12; grid-row: span 2; aspect-ratio: 21/9; }

  @media (max-width: 1024px) {
    .project-1, .project-5, .project-8 { grid-column: span 12; aspect-ratio: 16/9; }
    .project-2, .project-3, .project-4, .project-6, .project-7 { grid-column: span 6; aspect-ratio: 4/3; }
  }

  @media (max-width: 768px) {
    .project-card { grid-column: span 12 !important; aspect-ratio: 16/9 !important; }
  }

  .project-image-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 30px;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .project-card:hover .project-img {
    transform: scale(1.05);
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-info {
    transform: translateY(20px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .project-info {
    transform: translateY(0);
  }

  .project-category {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--orange);
    margin-bottom: 8px;
    display: block;
  }

  .project-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--white);
  }

  .view-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.8);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--orange);
    color: var(--white);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .view-btn {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .view-btn:hover {
    background: var(--white);
    color: var(--orange);
    transform: translate(-50%, -50%) scale(1.1) !important;
  }

  /* Upwork Section */
  .upwork-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 40px;
  }

  .upwork-badges {
    display: flex;
    gap: 16px;
  }

  .badge {
    padding: 8px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--lime);
  }

  .upwork-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .upwork-card {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    aspect-ratio: 3/4;
    transform: translateY(50px);
    opacity: 0;
  }

  @media (max-width: 1024px) {
    .upwork-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .upwork-grid { grid-template-columns: 1fr; }
  }

  .review-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.5s ease;
  }

  .review-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .upwork-card:hover .review-img {
    transform: scale(1.05);
  }

  .upwork-card:hover .review-overlay {
    opacity: 1;
  }

  .upwork-card:hover .view-btn {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .lightbox.active {
    opacity: 1;
    pointer-events: all;
  }

  .lightbox-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    backdrop-filter: blur(10px);
  }

  .lightbox-content {
    position: relative;
    z-index: 2;
    max-width: 90vw;
    max-height: 90vh;
    transform: scale(0.95);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lightbox.active .lightbox-content {
    transform: scale(1);
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 8px;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  .lightbox-close {
    position: absolute;
    top: -50px;
    right: 0;
    background: transparent;
    border: none;
    color: var(--white);
    cursor: pointer;
    padding: 10px;
    transition: color 0.3s ease;
  }

  .lightbox-close:hover {
    color: var(--orange);
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Animate Web Projects
    const projects = document.querySelectorAll('.project-card');
    
    projects.forEach((project, i) => {
      gsap.to(project, {
        scrollTrigger: {
          trigger: project,
          start: 'top 85%',
          toggleActions: 'play none none reverse'
        },
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: 'power3.out',
        delay: (i % 3) * 0.1 // Stagger effect for items in same row
      });
    });

    // Animate Upwork Reviews
    const reviews = document.querySelectorAll('.upwork-card');
    
    reviews.forEach((review, i) => {
      gsap.to(review, {
        scrollTrigger: {
          trigger: '.upwork-grid',
          start: 'top 80%',
          toggleActions: 'play none none reverse'
        },
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: 'power3.out',
        delay: i * 0.15
      });
    });

    // Lightbox Logic
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = lightbox?.querySelector('.lightbox-img') as HTMLImageElement;
    const closeBtn = lightbox?.querySelector('.lightbox-close');
    const overlay = lightbox?.querySelector('.lightbox-overlay');
    const viewBtns = document.querySelectorAll('.view-btn');

    const openLightbox = (src: string) => {
      if (lightbox && lightboxImg) {
        lightboxImg.src = src;
        lightbox.classList.add('active');
        document.body.style.overflow = 'hidden'; // Prevent scrolling
      }
    };

    const closeLightbox = () => {
      if (lightbox) {
        lightbox.classList.remove('active');
        document.body.style.overflow = '';
        setTimeout(() => {
          if (lightboxImg) lightboxImg.src = '';
        }, 400);
      }
    };

    viewBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const src = btn.getAttribute('data-src');
        if (src) openLightbox(src);
      });
    });

    closeBtn?.addEventListener('click', closeLightbox);
    overlay?.addEventListener('click', closeLightbox);
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
    });
  });
</script>

---
// GeoTestimonials — Auto-scrolling carousel of 6 GEO case studies
const cases = [
  { company: 'Bright Smile Dental', person: 'Sarah Mitchell, Marketing Director', headline: '12x More AI Recommendations in 45 Days', blurb: 'Bright Smile Dental went from invisible to <strong>12x citation growth</strong> and <strong>+340% patient inquiries</strong> from AI platforms.', m1: '12x', m1l: 'AI citation growth', m2: '+340%', m2l: 'Patient inquiries' },
  { company: 'Ember & Oak Kitchen', person: 'Marcus Rodriguez, Owner', headline: '8x Increase in AI-Referred Reservations', blurb: 'Ember & Oak saw <strong>8x growth</strong> in AI-referred diners and became ChatGPT\'s <strong>#1 recommended restaurant</strong> in Dallas.', m1: '8x', m1l: 'AI-referred reservations', m2: '2,400%', m2l: 'ROI in 90 days' },
  { company: 'Glow Aesthetic Studio', person: 'Jessica Park, Founder & CEO', headline: '340% Growth in AI Visibility in 60 Days', blurb: 'Glow grew AI visibility from 2.1% to 9.2% in 60 days with <strong>23x citation rate</strong> driven by review-first strategy.', m1: '23x', m1l: 'Citation rate growth', m2: '$89k', m2l: 'Media value' },
  { company: 'Sterling Law Group', person: 'David Chen, Managing Partner', headline: '#1 AI Recommendation for Personal Injury in Chicago', blurb: 'Sterling moved from invisible to <strong>#1 in AI Search</strong> for personal injury, generating <strong>28 new cases/month</strong>.', m1: '#1', m1l: 'AI Search position', m2: '1,200%', m2l: 'ROI' },
  { company: 'Pinnacle Realty Group', person: 'Rachel Thompson, VP of Marketing', headline: '5x More Leads from AI Search in 90 Days', blurb: 'Pinnacle saw <strong>5x lead growth</strong> and <strong>$2.1M in closed deals</strong> attributed to AI search.', m1: '5x', m1l: 'Lead growth', m2: '$2.1M', m2l: 'Attributed deals' },
  { company: 'Lumiere Med Spa', person: 'Amanda Foster, Practice Manager', headline: '15x Review-Driven AI Citation Growth', blurb: 'Lumiere generated <strong>92 new reviews</strong> in 60 days, driving <strong>15x AI citation growth</strong>.', m1: '15x', m1l: 'Citation growth', m2: '92', m2l: 'New reviews' },
];
// Double for infinite scroll
const allCases = [...cases, ...cases];
---

<section class="geo-testimonials" id="results">
  <div class="container">
    <div class="geo-testimonials__header reveal">
      <p class="section-tag" data-i18n="geo.sp.tag">Real Results</p>
      <h2 class="geo-testimonials__headline" data-i18n-html="geo.sp.h2">Real businesses. <span class="accent">Real AI visibility.</span></h2>
      <p class="geo-testimonials__sub" data-i18n="geo.sp.sub">These businesses were invisible to AI. Now ChatGPT, Gemini, and Perplexity recommend them by name.</p>
    </div>
  </div>

  <div class="sp-track-wrap">
    <div class="sp-track">
      {allCases.map((c) => (
        <div class="sp-card">
          <div class="sp-profile">
            <div class="sp-avatar-placeholder">{c.company[0]}</div>
            <div>
              <div class="sp-company">{c.company}</div>
              <div class="sp-person">{c.person}</div>
            </div>
          </div>
          <h3 class="sp-headline">{c.headline}</h3>
          <p class="sp-blurb" set:html={c.blurb} />
          <div class="sp-metrics">
            <div class="sp-metric">
              <div class="sp-metric-num">{c.m1}</div>
              <div class="sp-metric-label">{c.m1l}</div>
            </div>
            <div class="sp-metric">
              <div class="sp-metric-num">{c.m2}</div>
              <div class="sp-metric-label">{c.m2l}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="container" style="text-align:center;margin-top:40px">
    <a href="/casestudies/" class="btn-outline reveal" data-i18n="geo.sp.cta">See all case studies →</a>
  </div>
</section>

<style>
  .geo-testimonials {
    background: var(--color-surface);
    padding: var(--section-padding) 0;
    overflow: hidden;
  }
  .container { max-width: var(--container-max); margin: 0 auto; padding: 0 20px; }
  .section-tag {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .geo-testimonials__header { text-align: center; }
  .geo-testimonials__headline {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }
  .accent { color: var(--color-accent); }
  .geo-testimonials__sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--leading-normal);
  }

  .sp-track-wrap {
    overflow: hidden;
    margin-top: var(--space-12);
    position: relative;
  }
  .sp-track-wrap::before,
  .sp-track-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  .sp-track-wrap::before { left: 0; background: linear-gradient(90deg, var(--color-surface), transparent); }
  .sp-track-wrap::after { right: 0; background: linear-gradient(90deg, transparent, var(--color-surface)); }

  .sp-track {
    display: flex;
    gap: 24px;
    animation: spScroll 40s linear infinite;
    width: max-content;
  }
  .sp-track:hover { animation-play-state: paused; }
  @keyframes spScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  .sp-card {
    width: 380px;
    flex-shrink: 0;
    padding: var(--space-8) 28px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-surface-4);
    background: var(--color-surface-2);
    display: flex;
    flex-direction: column;
    gap: 20px;
    transition: transform var(--duration-base), box-shadow var(--duration-base);
    cursor: default;
  }
  .sp-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .sp-profile { display: flex; gap: 12px; align-items: center; }
  .sp-avatar-placeholder {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    flex-shrink: 0;
  }
  .sp-company {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }
  .sp-person { font-size: var(--text-xs); color: var(--color-text-muted); line-height: 1.4; }
  .sp-headline {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-text);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .sp-blurb {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }
  .sp-blurb :global(strong) { color: var(--color-text); font-weight: 600; }

  .sp-metrics { display: flex; gap: 12px; }
  .sp-metric {
    flex: 1;
    padding: var(--space-4);
    background: var(--color-surface-3);
    border-radius: 10px;
  }
  .sp-metric-num {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-text);
    line-height: 1.1;
  }
  .sp-metric-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: 4px;
    line-height: 1.3;
  }
</style>

      // ─── Apply function ────────────────────────────────
      window.__bs_apply = function(lang) {
        var t = window.__TRANS[lang] || window.__TRANS['en'];

        // 1. textContent
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var k = el.getAttribute('data-i18n');
          if (t[k] !== undefined) el.textContent = t[k];
        });
        // 2. innerHTML (for tags with <br> / <span>)
        document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
          var k = el.getAttribute('data-i18n-html');
          if (t[k] !== undefined) el.innerHTML = t[k];
        });
        // 3. placeholder
        document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
          var k = el.getAttribute('data-i18n-ph');
          if (t[k] !== undefined) el.placeholder = t[k];
        });
        // 4. select <option> text
        document.querySelectorAll('[data-i18n-opt]').forEach(function(el) {
          var k = el.getAttribute('data-i18n-opt');
          if (t[k] !== undefined) el.textContent = t[k];
        });
        // 5. Hero heading special (may have char spans after GSAP animation)
        var hl1 = document.querySelector('.hero .line1');
        var hl2 = document.querySelector('.hero .invert');
        var hl3 = document.querySelector('.hero .line3');
        if (hl1 && t['hero.line1']) hl1.textContent = t['hero.line1'];
        if (hl2 && t['hero.line2']) hl2.textContent = t['hero.line2'];
        if (hl3 && t['hero.line3']) hl3.textContent = t['hero.line3'];

        // 6. html attrs
        document.documentElement.setAttribute('data-lang', lang);
        document.documentElement.setAttribute('lang', lang === 'ru' ? 'ru' : 'en');

        // 7. Persist
        try { localStorage.setItem('bs_lang', lang); } catch(e) {}
      };

      // Register DOMContentLoaded FIRST (runs before component scripts in <body>)
      document.addEventListener('DOMContentLoaded', function() {
        window.__bs_apply(__bs_lang);

        // Wire lang toggle buttons
        document.querySelectorAll('.lang-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var newLang = btn.getAttribute('data-lang');
            var curLang = document.documentElement.getAttribute('data-lang');
            if (newLang === curLang) return;

            var main = document.querySelector('main');
            if (main && typeof gsap !== 'undefined') {
              gsap.to(main, {
                opacity: 0.1, duration: 0.18, ease: 'power2.in',
                onComplete: function() {
                  window.__bs_apply(newLang);
                  gsap.to(main, { opacity: 1, duration: 0.32, ease: 'power2.out' });
                }
              });
            } else {
              window.__bs_apply(newLang);
            }
          });
        });
      });
    </script>

import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  page?: 'home' | 'portfolio' | 'knowledge';
  articleTitle?: string;
  articleDescription?: string;
  articleDate?: string;
}

const { title, description, page = 'home', articleTitle, articleDescription, articleDate } = Astro.props;
const SITE = 'https://aggressorbulkit.online';
const canonical = `${SITE}${Astro.url.pathname}`;

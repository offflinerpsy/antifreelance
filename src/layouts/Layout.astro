        gsap.registerPlugin(ScrollTrigger);

        gsap.utils.toArray('.reveal').forEach(function(el) {
          gsap.to(el, {
            opacity: 1, y: 0,
            duration: 0.7, ease: 'power2.out',
            scrollTrigger: { trigger: el, start: 'top 85%', once: true }
          });
        });
      });
    </script>

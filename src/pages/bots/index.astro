---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import LogosCarousel from '../../components/LogosCarousel.astro';
import Cases from '../../components/Cases.astro';
import PhoneDemo from '../../components/PhoneDemo.astro';
import Reviews from '../../components/Reviews.astro';
import CTA from '../../components/CTA.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="AI Chatbots for Business | Override"
  description="Smart AI chatbots with local AI for your business. Sales automation, 24/7 client booking. Launch in 2–3 days."
>
  <Hero />

  <!-- Marquee -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      <span class="marquee-item" data-i18n="mq.1">Instant Response</span>
      <span class="marquee-item" data-i18n="mq.2">24/7 Uptime</span>
      <span class="marquee-item" data-i18n="mq.3">Client Booking</span>
      <span class="marquee-item" data-i18n="mq.4">Local AI</span>
      <span class="marquee-item" data-i18n="mq.5">No ChatGPT</span>
      <span class="marquee-item" data-i18n="mq.6">Launch in 2–3 Days</span>
      <span class="marquee-item" data-i18n="mq.7">15 Years of Experience</span>
      <span class="marquee-item" data-i18n="mq.8">50+ Bots</span>
      <!-- Duplicates for infinite scroll -->
      <span class="marquee-item" data-i18n="mq.1">Instant Response</span>
      <span class="marquee-item" data-i18n="mq.2">24/7 Uptime</span>
      <span class="marquee-item" data-i18n="mq.3">Client Booking</span>
      <span class="marquee-item" data-i18n="mq.4">Local AI</span>
      <span class="marquee-item" data-i18n="mq.5">No ChatGPT</span>
      <span class="marquee-item" data-i18n="mq.6">Launch in 2–3 Days</span>
      <span class="marquee-item" data-i18n="mq.7">15 Years of Experience</span>
      <span class="marquee-item" data-i18n="mq.8">50+ Bots</span>
    </div>
  </div>

  <!-- Features -->
  <section class="features-section" id="features">
    <div class="section-num reveal" data-i18n="feat.label">01 — Features</div>
    <h2 class="section-big-title reveal" data-i18n-html="feat.h2">The bot works<br><span class="accent">while you sleep</span></h2>
    <div class="features-asymmetric">
      <div class="feat-card bg-orange reveal">
        <div class="feat-num">01</div>
        <div class="feat-title" data-i18n="feat.1.title">Instant Response</div>
        <div class="feat-desc"  data-i18n="feat.1.desc">Under 1 second. Every moment you don't reply, a competitor does. Your bot answers before they finish typing.</div>
      </div>
      <div class="feat-card reveal">
        <div class="feat-num">02</div>
        <div class="feat-title" data-i18n="feat.2.title">Private AI</div>
        <div class="feat-desc"  data-i18n="feat.2.desc">Your own AI model. No ChatGPT dependency. No outages. No third-party data risk.</div>
      </div>
      <div class="feat-card reveal">
        <div class="feat-num">03</div>
        <div class="feat-title" data-i18n="feat.3.title">Appointment Booking</div>
        <div class="feat-desc"  data-i18n="feat.3.desc">Clients book themselves 24/7 — no receptionist, no phone tag. Just revenue while you sleep.</div>
      </div>
      <div class="feat-card bg-lime reveal">
        <div class="feat-num">04</div>
        <div class="feat-title" data-i18n="feat.4.title">Plugs Into Everything</div>
        <div class="feat-desc"  data-i18n="feat.4.desc">HubSpot, Salesforce, Google Sheets, Zapier — seamless sync with whatever you already use.</div>
      </div>
      <div class="feat-card reveal feat-wide">
        <div class="feat-num">05</div>
        <div class="feat-title" data-i18n="feat.5.title">Cut Payroll by 80%</div>
        <div class="feat-desc"  data-i18n="feat.5.desc">A bot runs for $50/mo. A human agent costs $500–$1,000. Same work, a fraction of the price.</div>
      </div>
    </div>
  </section>

  <PhoneDemo />

  <Cases />
  <Reviews />

  <!-- FAQ / People Also Ask -->
  <section class="faq-section" id="faq">
    <div class="section-num reveal" data-i18n="faq.label">05 — FAQ</div>
    <h2 class="section-big-title reveal" data-i18n-html="faq.h2">Frequently<br><span class="accent">Asked</span></h2>
    <div class="faq-list">
      <details class="faq-item reveal">
        <summary data-i18n="faq.q1">What is an AI bot for business and how does it work?</summary>
        <p data-i18n="faq.a1">An AI bot is an automated assistant that handles customer conversations, answers questions, and completes tasks 24/7. It connects to your website, WhatsApp, SMS, or other messaging platforms, processes natural language, and responds like a human agent — booking appointments, qualifying leads, and syncing with your CRM.</p>
      </details>
      <details class="faq-item reveal">
        <summary data-i18n="faq.q2">How much does a custom AI bot cost?</summary>
        <p data-i18n="faq.a2">Starting at $50/month to operate — compared to $500–$1,000/month for a human agent. Setup ranges from $500–$800 for a basic bot to $1,500–$3,000 for full CRM integration. Most clients see ROI within the first month.</p>
      </details>
      <details class="faq-item reveal">
        <summary data-i18n="faq.q3">How long does it take to launch?</summary>
        <p data-i18n="faq.a3">A standard bot launches in 2–3 business days. Complex bots with multiple integrations take 5–7 days. We handle everything: setup, AI training, integration, and testing.</p>
      </details>
      <details class="faq-item reveal">
        <summary data-i18n="faq.q4">Does the bot use ChatGPT or a private AI?</summary>
        <p data-i18n="faq.a4">We build bots with your own private AI model — no ChatGPT dependency. No outages when OpenAI goes down, no third-party data risk, faster response times. Your data stays on your infrastructure.</p>
      </details>
      <details class="faq-item reveal">
        <summary data-i18n="faq.q5">Can it integrate with my CRM?</summary>
        <p data-i18n="faq.a5">Yes. Our bots integrate with HubSpot, Salesforce, Google Sheets, Zapier, Calendly, Airtable, and more. Every lead, booking, or conversation is automatically logged — no manual data entry.</p>
      </details>
      <details class="faq-item reveal">
        <summary data-i18n="faq.q6">What types of businesses benefit most?</summary>
        <p data-i18n="faq.a6">Beauty salons, medical clinics, restaurants, auto repair shops, real estate agencies, fitness clubs, and any business receiving repetitive questions or needing 24/7 availability.</p>
      </details>
    </div>
  </section>

  <CTA />
  <ContactForm />
</Layout>

<style>
  /* Marquee */
  .marquee-wrap {
    background: var(--lime);
    padding: 14px 0;
    overflow: hidden;
  }
  .marquee-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker 15s linear infinite;
    width: max-content;
  }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .marquee-item {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.2rem, 3vw, 1.4rem);
    letter-spacing: 0.08em;
    color: var(--black);
    padding: 0 clamp(16px, 4vw, 32px);
    display: flex;
    align-items: center;
    gap: clamp(8px, 2vw, 16px);
    text-transform: uppercase;
  }
  .marquee-item::after { content: '◆'; font-size: 0.6em; opacity: 0.4; }

  /* Features section */
  .features-section {
    background: var(--black);
    padding: clamp(60px, 10vw, 100px) clamp(20px, 5vw, 40px);
  }
  .features-asymmetric {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(16px, 3vw, 24px);
    max-width: 100%;
  }
  .feat-wide {
    grid-column: span 2;
  }
  @media (max-width: 768px) {
    .features-asymmetric { grid-template-columns: 1fr; }
    .feat-wide { grid-column: span 1; }
  }

  .feat-card {
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: clamp(24px, 5vw, 36px);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.3s, transform 0.3s, background 0.3s;
  }
  .feat-card:hover,
  .feat-card:active { border-color: var(--orange); transform: translateY(-4px); }
  .feat-card.bg-orange { background: var(--orange); border-color: var(--orange); }
  .feat-card.bg-lime { background: var(--lime); color: var(--black); border-color: var(--lime); }
  .feat-card.bg-white { background: var(--white); color: var(--black); border-color: var(--white); }

  .feat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 9vw, 6rem);
    line-height: 1;
    opacity: 0.18;
    position: absolute;
    top: clamp(12px, 2vw, 18px);
    right: clamp(16px, 3vw, 24px);
    letter-spacing: -0.03em;
    transition: opacity 0.35s;
  }
  .feat-card:hover .feat-num { opacity: 0.28; }

  .feat-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2rem);
    letter-spacing: 0.02em;
    margin-bottom: 14px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .feat-desc {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.7;
    opacity: 0.92;
    position: relative;
    z-index: 1;
    max-width: 520px;
  }
  .feat-card.bg-orange .feat-desc,
  .feat-card.bg-lime .feat-desc { opacity: 1; }

  /* FAQ Section */
  .faq-section {
    background: var(--black);
    padding: clamp(60px, 10vw, 100px) clamp(20px, 5vw, 40px);
  }
  .faq-list {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .faq-item {
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .faq-item summary {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 600;
    color: var(--white);
    padding: clamp(20px, 4vw, 28px) 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: color 0.3s;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.8rem;
    color: var(--orange);
    flex-shrink: 0;
    transition: transform 0.3s;
  }
  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }
  .faq-item summary:hover { color: var(--orange); }
  .faq-item p {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.7;
    color: rgba(255,255,255,0.7);
    padding: 0 0 clamp(20px, 4vw, 28px);
    max-width: 700px;
  }
</style>

---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((s) => ({
    params: { slug: s.id.replace(/\.md$/, '') },
    props: { entry: s },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const SITE = 'https://aggressorbulkit.online';
const slug = entry.id.replace(/\.md$/, '');

// Cross-link: find matching case study by industry
const allCases = await getCollection('casestudies');
const industryMap: Record<string, string> = {
  'Beauty Salon': 'Beauty & Wellness',
  'Restaurant': 'Food Delivery',
  'Medical Clinic': 'Healthcare',
  'Fitness Club': 'Fitness & Wellness',
  'Real Estate': 'Real Estate',
  'E-commerce': 'SaaS',
  'Delivery': 'Food Delivery',
};
const matchedIndustry = industryMap[d.industry] || d.industry;
const relatedCase = allCases.find(c => c.data.industry === matchedIndustry);

// Build FAQ JSON-LD
const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": d.faq.map((f: { q: string; a: string }) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
});

// Build Service JSON-LD
const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": d.title,
  "description": d.description,
  "provider": { "@type": "Person", "@id": `${SITE}/#person`, "name": "Aliaksei Y." },
  "serviceType": `AI Bot for ${d.industry}`,
  "areaServed": "Worldwide",
  "url": `${SITE}/bots/services/${slug}`
});

// Breadcrumb JSON-LD
const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE },
    { "@type": "ListItem", "position": 2, "name": "AI Chatbots", "item": `${SITE}/bots` },
    { "@type": "ListItem", "position": 3, "name": "Services", "item": `${SITE}/bots/services` },
    { "@type": "ListItem", "position": 4, "name": d.industry, "item": `${SITE}/bots/services/${slug}` }
  ]
});
---

<Layout title={d.title} description={d.description} page="home">
  <!-- Per-page JSON-LD -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={faqSchema} />
    <script type="application/ld+json" set:html={serviceSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </Fragment>

  <section class="service-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <a href="/bots/">AI Chatbots</a>
        <span class="sep">/</span>
        <a href="/bots/services/">Services</a>
        <span class="sep">/</span>
        <span class="current">{d.industry}</span>
      </div>

      <div class="hero-badge">{d.icon} {d.industry}</div>
      <h1 class="hero-title">{d.heroHeadline}</h1>
      <p class="hero-sub">{d.heroSub}</p>

      <div class="hero-cta-row">
        <a href="/#contact" class="btn-primary">{d.cta}</a>
      </div>

      <div class="stats-row">
        {d.stats.map((s: { value: string; label: string }) => (
          <div class="stat-card">
            <div class="stat-value">{s.value}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="benefits-section">
    <div class="container">
      <h2 class="section-title">Why {d.industry} Businesses Choose AI Bots</h2>
      <div class="benefits-grid">
        {d.benefits.map((b: { title: string; text: string }) => (
          <div class="benefit-card">
            <h3>{b.title}</h3>
            <p>{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="container content-container">
      <Content />
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        {d.faq.map((f: { q: string; a: string }) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {relatedCase && (
    <section class="related-case">
      <div class="container">
        <h2 class="section-title">See It In Action</h2>
        <a href={`/casestudies/${relatedCase.id.replace(/\.md$/, '')}/`} class="related-case__card">
          <div class="related-case__icon">{relatedCase.data.icon}</div>
          <div class="related-case__info">
            <div class="related-case__client">{relatedCase.data.client}</div>
            <div class="related-case__title">{relatedCase.data.title}</div>
            <div class="related-case__result">{relatedCase.data.results[0].value} {relatedCase.data.results[0].label}</div>
          </div>
          <div class="related-case__arrow">→</div>
        </a>
      </div>
    </section>
  )}

  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to Automate Your {d.industry}?</h2>
      <p>Get a custom AI bot that works 24/7 — launched in 2–3 days.</p>
      <a href="/#contact" class="btn-primary">{d.cta}</a>
    </div>
  </section>
</Layout>

<style>
  .service-hero {
    padding: clamp(120px, 20vw, 200px) 20px clamp(60px, 10vw, 100px);
    background: var(--color-surface);
  }
  .container { max-width: var(--container-max); margin: 0 auto; }

  .breadcrumb {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-8);
  }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-primary); }
  .breadcrumb .sep { margin: 0 var(--space-2); }
  .breadcrumb .current { color: var(--color-text); }

  .hero-badge {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: rgba(255, 94, 0, 0.12);
    border: 1px solid rgba(255, 94, 0, 0.3);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: var(--space-6);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: var(--leading-tight);
    color: var(--color-text);
    max-width: 900px;
    margin-bottom: var(--space-6);
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 650px;
    line-height: var(--leading-normal);
    margin-bottom: var(--space-8);
  }

  .hero-cta-row { margin-bottom: var(--space-12); }

  .stats-row {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .stat-card {
    background: var(--color-surface-2);
    border: 1px solid var(--color-surface-4);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-8);
    min-width: 160px;
  }
  .stat-value {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: var(--space-1);
  }
  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Benefits */
  .benefits-section {
    padding: clamp(60px, 10vw, 100px) 20px;
    background: var(--color-surface-2);
  }
  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: var(--color-text);
    margin-bottom: var(--space-10);
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }
  .benefit-card {
    background: var(--color-surface);
    border: 1px solid var(--color-surface-4);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
  }
  .benefit-card h3 {
    font-size: var(--text-xl);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }
  .benefit-card p {
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* Content (markdown body) */
  .content-section {
    padding: clamp(60px, 10vw, 100px) 20px;
    background: var(--color-surface);
  }
  .content-container {
    max-width: var(--container-sm);
  }
  .content-container :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-text);
    margin: var(--space-10) 0 var(--space-4);
  }
  .content-container :global(h3) {
    font-size: var(--text-xl);
    color: var(--color-text);
    margin: var(--space-8) 0 var(--space-3);
  }
  .content-container :global(p) {
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }
  .content-container :global(ul), .content-container :global(ol) {
    color: var(--color-text-muted);
    margin: var(--space-4) 0;
    padding-left: var(--space-6);
    line-height: var(--leading-relaxed);
  }
  .content-container :global(strong) { color: var(--color-text); }
  .content-container :global(a) { color: var(--color-accent); }

  /* FAQ */
  .faq-section {
    padding: clamp(60px, 10vw, 100px) 20px;
    background: var(--color-surface-2);
  }
  .faq-list {
    max-width: var(--container-sm);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-surface-4);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .faq-item summary {
    padding: var(--space-5) var(--space-6);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-item summary::after {
    content: '+';
    font-size: var(--text-xl);
    color: var(--color-primary);
    transition: transform var(--duration-base) var(--ease-spring);
  }
  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }
  .faq-item p {
    padding: 0 var(--space-6) var(--space-5);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* Related Case Study */
  .related-case {
    padding: clamp(60px, 10vw, 100px) 20px;
    background: var(--color-surface);
  }
  .related-case__card {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    background: var(--color-surface-2);
    border: 1px solid var(--color-surface-4);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-8);
    text-decoration: none;
    transition: border-color 0.3s, transform 0.3s;
    max-width: var(--container-sm);
  }
  .related-case__card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }
  .related-case__icon { font-size: 2.5rem; }
  .related-case__client {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-1);
  }
  .related-case__title {
    font-size: var(--text-lg);
    color: var(--color-text);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .related-case__result {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 600;
  }
  .related-case__arrow {
    font-size: var(--text-2xl);
    color: var(--color-primary);
    margin-left: auto;
    flex-shrink: 0;
  }
  @media (max-width: 600px) {
    .related-case__card { flex-wrap: wrap; }
    .related-case__arrow { display: none; }
  }

  /* Bottom CTA */
  .bottom-cta {
    padding: clamp(80px, 15vw, 140px) 20px;
    background: var(--color-surface);
    text-align: center;
  }
  .bottom-cta h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 4rem);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }
  .bottom-cta p {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }
</style>

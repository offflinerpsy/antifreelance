---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import LogosCarousel from '../components/LogosCarousel.astro';
import Cases from '../components/Cases.astro';
import Portfolio from '../components/Portfolio.astro';
import Reviews from '../components/Reviews.astro';
import CTA from '../components/CTA.astro';
---

<Layout 
  title="AI Bots for Business | BotStudio" 
  description="Smart Telegram bots with local AI for your business. Sales automation, 24/7 client booking. Launch in 2–3 days."
>
  <!-- RU: title="AI-боты для бизнеса | BotStudio" description="Создание умных Telegram-ботов с локальным AI для бизнеса. Автоматизация продаж, запись клиентов 24/7. Запуск за 2-3 дня." -->
  <Hero />
  
  <!-- Marquee -->
  <!-- RU: Мгновенный ответ | 24/7 работа | Запись клиентов | Локальный AI | Без ChatGPT | 2-3 дня до запуска | 15 лет опыта | 50+ ботов -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      <span class="marquee-item">Instant Response</span>
      <span class="marquee-item">24/7 Uptime</span>
      <span class="marquee-item">Client Booking</span>
      <span class="marquee-item">Local AI</span>
      <span class="marquee-item">No ChatGPT</span>
      <span class="marquee-item">Launch in 2–3 Days</span>
      <span class="marquee-item">15 Years of Experience</span>
      <span class="marquee-item">50+ Bots</span>
      <!-- Duplicates for infinite scroll -->
      <span class="marquee-item">Instant Response</span>
      <span class="marquee-item">24/7 Uptime</span>
      <span class="marquee-item">Client Booking</span>
      <span class="marquee-item">Local AI</span>
      <span class="marquee-item">No ChatGPT</span>
      <span class="marquee-item">Launch in 2–3 Days</span>
      <span class="marquee-item">15 Years of Experience</span>
      <span class="marquee-item">50+ Bots</span>
    </div>
  </div>

  <!-- Features -->
  <section class="features-section" id="features">
    <!-- RU: 01 — Возможности / Бот работает пока вы спите -->
    <div class="section-num reveal">01 — Features</div>
    <h2 class="section-big-title reveal">The bot works<br><span class="accent">while you sleep</span></h2>
    <div class="features-asymmetric">
      <div class="feat-card bg-orange reveal">
        <div class="feat-num">01</div>
        <!-- RU: Мгновенный ответ / Реакция менее 1 секунды. Пока конкуренты спят — вы уже приняли заявку. -->
        <div class="feat-title">Instant Response</div>
        <div class="feat-desc">Under 1 second. Every moment you don't reply, a competitor does. Your bot answers before they finish typing.</div>
      </div>
      <div class="feat-card reveal">
        <div class="feat-num">02</div>
        <!-- RU: Собственный AI / Собственная AI-модель без зависимости от ChatGPT и зарубежных сервисов. -->
        <div class="feat-title">Private AI</div>
        <div class="feat-desc">Your own AI model. No ChatGPT dependency. No outages. No third-party data risk.</div>
      </div>
      <div class="feat-card reveal">
        <div class="feat-num">03</div>
        <!-- RU: Приём записей / Клиент записывается сам через бота в любое время суток. -->
        <div class="feat-title">Appointment Booking</div>
        <div class="feat-desc">Clients book themselves 24/7 — no receptionist, no phone tag. Just revenue while you sleep.</div>
      </div>
      <div class="feat-card bg-lime reveal">
        <div class="feat-num">04</div>
        <!-- RU: Интеграции с CRM / Подключаем к HubSpot, Salesforce, Zapier и любым другим системам. -->
        <div class="feat-title">Plugs Into Everything</div>
        <div class="feat-desc">HubSpot, Salesforce, Google Sheets, Zapier — seamless sync with whatever you already use.</div>
      </div>
      <div class="feat-card reveal feat-wide">
        <div class="feat-num">05</div>
        <!-- RU: В 4–8 раз дешевле менеджера / Обслуживание бота — от $50/мес. Менеджер стоит $500–$1 000/мес. -->
        <div class="feat-title">Cut Payroll by 80%</div>
        <div class="feat-desc">A bot runs for $50/mo. A human agent costs $500–$1,000. Same work, a fraction of the price.</div>
      </div>
    </div>
  </section>

  <Cases />
  <Portfolio />
  <Reviews />
  <CTA />
</Layout>

<style>
  /* Marquee */
  .marquee-wrap {
    background: var(--lime);
    padding: 14px 0;
    overflow: hidden;
  }
  .marquee-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker 15s linear infinite;
    width: max-content;
  }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .marquee-item {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.2rem, 3vw, 1.4rem);
    letter-spacing: 0.08em;
    color: var(--black);
    padding: 0 clamp(16px, 4vw, 32px);
    display: flex;
    align-items: center;
    gap: clamp(8px, 2vw, 16px);
    text-transform: uppercase;
  }
  .marquee-item::after { content: '◆'; font-size: 0.6em; opacity: 0.4; }

  /* Features section */
  .features-section {
    background: var(--black);
    padding: clamp(60px, 10vw, 100px) clamp(20px, 5vw, 40px);
  }
  .features-asymmetric {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(16px, 3vw, 24px);
    max-width: 100%;
  }
  .feat-wide {
    grid-column: span 2;
  }
  @media (max-width: 768px) { 
    .features-asymmetric { grid-template-columns: 1fr; } 
    .feat-wide { grid-column: span 1; }
  }

  .feat-card {
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: clamp(24px, 5vw, 36px);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.3s, transform 0.3s, background 0.3s;
  }
  .feat-card:hover,
  .feat-card:active { border-color: var(--orange); transform: translateY(-4px); }
  .feat-card.bg-orange { background: var(--orange); border-color: var(--orange); }
  .feat-card.bg-lime { background: var(--lime); color: var(--black); border-color: var(--lime); }
  .feat-card.bg-white { background: var(--white); color: var(--black); border-color: var(--white); }

  .feat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 9vw, 6rem);
    line-height: 1;
    opacity: 0.18;
    position: absolute;
    top: clamp(12px, 2vw, 18px); 
    right: clamp(16px, 3vw, 24px);
    letter-spacing: -0.03em;
    transition: opacity 0.35s;
  }
  .feat-card:hover .feat-num { opacity: 0.28; }

  .feat-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2rem);
    letter-spacing: 0.02em;
    margin-bottom: 14px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .feat-desc {
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    line-height: 1.7;
    opacity: 0.92;
    position: relative;
    z-index: 1;
    max-width: 520px;
  }
  .feat-card.bg-orange .feat-desc,
  .feat-card.bg-lime .feat-desc { opacity: 1; }
</style>
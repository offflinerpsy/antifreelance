---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import LogosCarousel from '../components/LogosCarousel.astro';
import Cases from '../components/Cases.astro';
import Portfolio from '../components/Portfolio.astro';
import Reviews from '../components/Reviews.astro';
import CTA from '../components/CTA.astro';
---

<Layout 
  title="AI Bots for Business | BotStudio" 
  description="Smart Telegram bots with local AI for your business. Sales automation, 24/7 client booking. Launch in 2–3 days."
>
  <!-- RU: title="AI-боты для бизнеса | BotStudio" description="Создание умных Telegram-ботов с локальным AI для бизнеса. Автоматизация продаж, запись клиентов 24/7. Запуск за 2-3 дня." -->
  <Hero />
  
  <!-- Marquee -->
  <!-- RU: Мгновенный ответ | 24/7 работа | Запись клиентов | Локальный AI | Без ChatGPT | 2-3 дня до запуска | 15 лет опыта | 50+ ботов -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      <span class="marquee-item">Instant Response</span>
      <span class="marquee-item">24/7 Uptime</span>
      <span class="marquee-item">Client Booking</span>
      <span class="marquee-item">Local AI</span>
      <span class="marquee-item">No ChatGPT</span>
      <span class="marquee-item">Launch in 2–3 Days</span>
      <span class="marquee-item">15 Years of Experience</span>
      <span class="marquee-item">50+ Bots</span>
      <!-- Duplicates for infinite scroll -->
      <span class="marquee-item">Instant Response</span>
      <span class="marquee-item">24/7 Uptime</span>
      <span class="marquee-item">Client Booking</span>
      <span class="marquee-item">Local AI</span>
      <span class="marquee-item">No ChatGPT</span>
      <span class="marquee-item">Launch in 2–3 Days</span>
      <span class="marquee-item">15 Years of Experience</span>
      <span class="marquee-item">50+ Bots</span>
    </div>
  </div>

  <!-- Features -->
  <section class="features-section" id="features">
    <!-- RU: 01 — Возможности / Бот работает пока вы спите -->
    <div class="section-num reveal">01 — Features</div>
    <h2 class="section-big-title reveal">The bot works<br><span class="accent">while you sleep</span></h2>
    <div class="features-asymmetric">
      <div class="feat-card bg-orange reveal">
        <div class="feat-num">01</div>
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <!-- RU: Мгновенный ответ / Реакция менее 1 секунды. Пока конкуренты спят — вы уже приняли заявку. -->
        <div class="feat-title">Instant Response</div>
        <div class="feat-desc">Under 1-second reply time. While competitors sleep, you're already capturing leads.</div>
      </div>
      <div class="feat-card reveal">
        <div class="feat-num">02</div>
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.9.5H7a2.5 2.5 0 0 1-.5-4.9H6a2.5 2.5 0 0 1 0-5h.5A2.5 2.5 0 0 1 7 5.5h.1A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.9.5h.1a2.5 2.5 0 0 0 .5-4.9h.5a2.5 2.5 0 0 0 0-5h-.5a2.5 2.5 0 0 0-.5-4.9h-.1A2.5 2.5 0 0 0 14.5 2Z"/></svg>
        </div>
        <!-- RU: Локальный AI / Собственная AI-модель без зависимости от ChatGPT и зарубежных сервисов. -->
        <div class="feat-title">Local AI</div>
        <div class="feat-desc">Your own AI model with zero dependency on ChatGPT or third-party services.</div>
      </div>
      <div class="feat-card reveal">
        <div class="feat-num">03</div>
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <!-- RU: Приём записей / Клиент записывается сам через бота в любое время суток. -->
        <div class="feat-title">Appointment Booking</div>
        <div class="feat-desc">Clients book themselves through the bot at any time of day or night.</div>
      </div>
      <div class="feat-card bg-lime reveal">
        <div class="feat-num">04</div>
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </div>
        <!-- RU: Интеграции с CRM / Подключаем к AmoCRM, Bitrix24, Google Sheets и любым другим системам. -->
        <div class="feat-title">CRM Integrations</div>
        <div class="feat-desc">Connect to AmoCRM, Bitrix24, Google Sheets, and any other system you use.</div>
      </div>
      <div class="feat-card reveal feat-wide">
        <div class="feat-num">05</div>
        <div class="feat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <!-- RU: В 4–8 раз дешевле менеджера / Обслуживание бота — от 5 000 ₽/мес. Менеджер стоит 40 000–80 000 ₽. Экономия очевидна. -->
        <div class="feat-title">4–8x Cheaper Than a Human Agent</div>
        <div class="feat-desc">Bot maintenance starts at $50/mo. A human agent costs $500–$1,000/mo. The savings are obvious.</div>
      </div>
    </div>
  </section>

  <Cases />
  <Portfolio />
  <Reviews />
  <CTA />
</Layout>

<style>
  /* Marquee */
  .marquee-wrap {
    background: var(--lime);
    padding: 14px 0;
    overflow: hidden;
  }
  .marquee-track {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker 15s linear infinite;
    width: max-content;
  }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  .marquee-item {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.2rem, 3vw, 1.4rem);
    letter-spacing: 0.08em;
    color: var(--black);
    padding: 0 clamp(16px, 4vw, 32px);
    display: flex;
    align-items: center;
    gap: clamp(8px, 2vw, 16px);
    text-transform: uppercase;
  }
  .marquee-item::after { content: '◆'; font-size: 0.6em; opacity: 0.4; }

  /* Features section */
  .features-section {
    background: var(--black);
    padding: clamp(60px, 10vw, 100px) clamp(20px, 5vw, 40px);
  }
  .features-asymmetric {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(16px, 3vw, 24px);
    max-width: 1200px;
  }
  .feat-wide {
    grid-column: span 2;
  }
  @media (max-width: 768px) { 
    .features-asymmetric { grid-template-columns: 1fr; } 
    .feat-wide { grid-column: span 1; }
  }

  .feat-card {
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: clamp(24px, 5vw, 36px);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s, background 0.3s;
  }
  .feat-card:hover { border-color: var(--orange); transform: translateY(-4px); }
  .feat-card.bg-orange { background: var(--orange); border-color: var(--orange); }
  .feat-card.bg-lime { background: var(--lime); color: var(--black); border-color: var(--lime); }
  .feat-card.bg-white { background: var(--white); color: var(--black); border-color: var(--white); }

  .feat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 8vw, 5rem);
    line-height: 1;
    opacity: 0.15;
    position: absolute;
    top: clamp(16px, 3vw, 20px); 
    right: clamp(16px, 4vw, 24px);
    letter-spacing: -0.03em;
  }
  
  /* SVG Animations */
  .feat-icon { margin-bottom: clamp(16px, 3vw, 20px); display: inline-block; }
  .feat-icon svg {
    width: clamp(32px, 6vw, 40px); 
    height: clamp(32px, 6vw, 40px);
    stroke: var(--white);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), stroke 0.3s ease;
  }
  .feat-card.bg-orange .feat-icon svg,
  .feat-card.bg-lime .feat-icon svg,
  .feat-card.bg-white .feat-icon svg { stroke: var(--black); }
  
  .feat-card:hover .feat-icon svg {
    transform: scale(1.15) translateY(-4px);
    stroke: var(--orange);
  }
  .feat-card.bg-orange:hover .feat-icon svg { stroke: var(--white); }
  .feat-card.bg-lime:hover .feat-icon svg { stroke: var(--orange); }
  .feat-card.bg-white:hover .feat-icon svg { stroke: var(--orange); }

  .feat-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.5rem, 4vw, 1.8rem);
    letter-spacing: 0.02em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }
  .feat-desc { font-size: clamp(0.85rem, 2vw, 0.95rem); line-height: 1.65; opacity: 0.8; }
</style>
---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const knowledgeEntries = await getCollection('knowledge');
  return knowledgeEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} | BotStudio`} description={entry.data.description}>
  <article class="kb-article">
    <div class="kb-article-header reveal">
      <!-- RU: ← Назад в Базу знаний -->
      <a href="/knowledge" class="kb-back">← Back to Knowledge Base</a>
      <div class="kb-meta">
        <span class="kb-date">
          {entry.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </span>
        {entry.data.tags && (
          <div class="kb-tags">
            {entry.data.tags.map((tag) => (
              <span class="kb-tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
      <h1 class="kb-title">{entry.data.title}</h1>
      <p class="kb-desc">{entry.data.description}</p>
    </div>

    <div class="kb-content reveal">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  .kb-article {
    background: var(--black);
    color: var(--white);
    padding: clamp(120px, 15vw, 180px) clamp(20px, 5vw, 40px) clamp(80px, 10vw, 120px);
    min-height: 100vh;
  }
  .kb-article-header {
    max-width: 800px;
    margin: 0 auto clamp(40px, 8vw, 80px);
  }
  .kb-back {
    display: inline-block;
    color: var(--orange);
    text-decoration: none;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 32px;
    transition: color 0.3s;
  }
  .kb-back:hover { color: var(--lime); }

  .kb-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .kb-date {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    font-family: monospace;
  }
  .kb-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .kb-tag {
    font-size: 0.75rem;
    padding: 4px 10px;
    background: rgba(221, 245, 22, 0.1);
    color: var(--lime);
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .kb-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin-bottom: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .kb-desc {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
  }

  /* Markdown Content Styles */
  .kb-content {
    max-width: 800px;
    margin: 0 auto;
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.8;
    color: rgba(255,255,255,0.85);
  }
  .kb-content h1, .kb-content h2, .kb-content h3 {
    color: var(--white);
    margin-top: 2em;
    margin-bottom: 1em;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .kb-content h1 { font-size: 2.5em; }
  .kb-content h2 { font-size: 2em; }
  .kb-content h3 { font-size: 1.5em; }
  
  .kb-content p { margin-bottom: 1.5em; }
  
  .kb-content ul, .kb-content ol {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }
  .kb-content li { margin-bottom: 0.5em; }
  
  .kb-content blockquote {
    border-left: 4px solid var(--orange);
    padding: 1em 1.5em;
    margin: 2em 0;
    background: rgba(255, 94, 0, 0.05);
    border-radius: 0 12px 12px 0;
    font-style: italic;
    color: var(--white);
  }
  
  .kb-content img, .kb-content video {
    max-width: 100%;
    height: auto;
    border-radius: 16px;
    margin: 2em 0;
    border: 1px solid rgba(255,255,255,0.1);
  }
  
  .kb-content strong { color: var(--white); font-weight: 700; }
  .kb-content a { color: var(--lime); text-decoration: underline; text-underline-offset: 4px; }
  .kb-content a:hover { color: var(--orange); }
</style>

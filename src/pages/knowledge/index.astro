---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('knowledge');
// Sort by date descending
allArticles.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout 
  title="База знаний | BotStudio" 
  description="Полезные статьи, кейсы и инсайты о внедрении AI и Telegram-ботов в бизнес."
>
  <section class="kb-header">
    <div class="section-num reveal">04 — База знаний</div>
    <h1 class="section-big-title reveal">Инсайты и<br><span class="accent">Кейсы</span></h1>
    <p class="kb-desc reveal">Как мы автоматизируем бизнес, внедряем AI и создаем продукты, которые приносят деньги.</p>
  </section>

  <section class="kb-grid reveal">
    {allArticles.map((article) => (
      <a href={`/knowledge/${article.slug}`} class="kb-card">
        <div class="kb-card-content">
          <div class="kb-meta">
            <span class="kb-date">
              {article.data.pubDate.toLocaleDateString('ru-RU', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </span>
            {article.data.tags && (
              <div class="kb-tags">
                {article.data.tags.map((tag) => (
                  <span class="kb-tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <h2>{article.data.title}</h2>
          <p>{article.data.description}</p>
          <div class="kb-read-more">Читать статью →</div>
        </div>
      </a>
    ))}
  </section>
</Layout>

<style>
  .kb-header {
    padding: clamp(120px, 15vw, 180px) clamp(20px, 5vw, 40px) clamp(40px, 8vw, 80px);
    background: var(--black);
  }
  .kb-desc {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.7);
    max-width: 600px;
    line-height: 1.6;
    margin-top: -20px;
  }

  .kb-grid {
    padding: 0 clamp(20px, 5vw, 40px) clamp(80px, 10vw, 120px);
    background: var(--black);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(clamp(280px, 40vw, 400px), 1fr));
    gap: clamp(20px, 4vw, 32px);
  }

  .kb-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 24px;
    padding: clamp(24px, 4vw, 32px);
    text-decoration: none;
    color: var(--white);
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
    height: 100%;
  }
  .kb-card:hover {
    background: rgba(255,255,255,0.05);
    border-color: var(--orange);
    transform: translateY(-4px);
  }

  .kb-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .kb-date {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
    font-family: monospace;
  }
  .kb-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .kb-tag {
    font-size: 0.75rem;
    padding: 4px 10px;
    background: rgba(221, 245, 22, 0.1);
    color: var(--lime);
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .kb-card h2 {
    font-size: clamp(1.3rem, 2.5vw, 1.6rem);
    line-height: 1.3;
    margin-bottom: 16px;
    font-weight: 600;
  }
  .kb-card p {
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin-bottom: 32px;
    flex-grow: 1;
  }
  .kb-read-more {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    color: var(--orange);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-top: auto;
  }
</style>

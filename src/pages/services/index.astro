---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const services = await getCollection('services');
const sorted = services.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="AI Bot Services by Industry | BotStudio" description="Custom AI bots for every industry: beauty salons, restaurants, clinics, real estate, fitness, and more. Launch in 2–3 days from $50/month." page="home">
  <section class="services-hero">
    <div class="container">
      <h1 class="page-title">AI Bot <span class="accent">Services</span></h1>
      <p class="page-sub">Custom AI bots tailored to your industry. Pick your niche below and see exactly how automation saves you time and money.</p>
    </div>
  </section>

  <section class="services-grid-section">
    <div class="container">
      <div class="services-grid">
        {sorted.map((s) => (
          <a href={`/services/${s.id.replace(/\.md$/, '')}/`} class="service-card">
            <div class="card-icon">{s.data.icon}</div>
            <h2 class="card-title">{s.data.industry}</h2>
            <p class="card-desc">{s.data.description}</p>
            <span class="card-link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .services-hero {
    padding: clamp(120px, 20vw, 200px) 20px clamp(40px, 8vw, 80px);
    background: var(--color-surface);
  }
  .container { max-width: var(--container-max); margin: 0 auto; }
  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 6vw, 5rem);
    color: var(--color-text);
    line-height: 1;
    margin-bottom: var(--space-5);
  }
  .accent { color: var(--color-accent); }
  .page-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 600px;
    line-height: var(--leading-normal);
  }

  .services-grid-section {
    padding: 0 20px clamp(80px, 15vw, 150px);
    background: var(--color-surface);
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }
  .service-card {
    background: var(--color-surface-2);
    border: 1px solid var(--color-surface-4);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    text-decoration: none;
    transition: border-color var(--duration-base) var(--ease-smooth),
                transform var(--duration-base) var(--ease-spring);
  }
  .service-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-4px);
  }
  .card-icon { font-size: 2.5rem; margin-bottom: var(--space-4); }
  .card-title {
    font-size: var(--text-xl);
    color: var(--color-text);
    font-weight: 600;
    margin-bottom: var(--space-3);
  }
  .card-desc {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }
  .card-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
  }
</style>
